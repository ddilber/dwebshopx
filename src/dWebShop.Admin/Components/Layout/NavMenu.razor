@inject NavigationManager Nav

<aside class="shell-nav">
    <div class="shell-nav-brand">
        <div class="shell-brand-mark">d</div>
        <div class="shell-brand-text">
            <div class="shell-brand-name">dWebShop</div>
            <div class="shell-brand-sub">Admin console</div>
        </div>
    </div>

    <nav class="shell-nav-list">

        <NavLink href="/" Match="NavLinkMatch.All" class="shell-nav-item" ActiveClass="is-active">
            <span class="shell-nav-icon">@IcoHome</span>
            <span class="shell-nav-label">Dashboard</span>
        </NavLink>

        <div class="shell-nav-group">
            <button class="shell-nav-item is-group" @onclick="() => _cat = !_cat">
                <span class="shell-nav-icon">@IcoFolder</span>
                <span class="shell-nav-label">Catalogue</span>
                <span class="shell-nav-chev">@(_cat ? IcoChevUp : IcoChevDown)</span>
            </button>
            @if (_cat)
            {
                <div class="shell-nav-children">
                    <NavLink href="/products" class="shell-nav-item is-child" ActiveClass="is-active">
                        <span class="shell-nav-icon">@IcoTag</span>
                        <span class="shell-nav-label">Products</span>
                    </NavLink>
                    <NavLink href="/categories" class="shell-nav-item is-child" ActiveClass="is-active">
                        <span class="shell-nav-icon">@IcoFolder</span>
                        <span class="shell-nav-label">Categories</span>
                    </NavLink>
                    <NavLink href="/brands" class="shell-nav-item is-child" ActiveClass="is-active">
                        <span class="shell-nav-icon">@IcoStar</span>
                        <span class="shell-nav-label">Brands</span>
                    </NavLink>
                </div>
            }
        </div>

        <div class="shell-nav-group">
            <button class="shell-nav-item is-group" @onclick="() => _com = !_com">
                <span class="shell-nav-icon">@IcoCart</span>
                <span class="shell-nav-label">Commerce</span>
                <span class="shell-nav-chev">@(_com ? IcoChevUp : IcoChevDown)</span>
            </button>
            @if (_com)
            {
                <div class="shell-nav-children">
                    <NavLink href="/orders" class="shell-nav-item is-child" ActiveClass="is-active">
                        <span class="shell-nav-icon">@IcoReceipt</span>
                        <span class="shell-nav-label">Orders</span>
                    </NavLink>
                    <NavLink href="/pricelists" class="shell-nav-item is-child" ActiveClass="is-active">
                        <span class="shell-nav-icon">@IcoMoney</span>
                        <span class="shell-nav-label">Pricelists</span>
                    </NavLink>
                    <NavLink href="/clients" class="shell-nav-item is-child" ActiveClass="is-active">
                        <span class="shell-nav-icon">@IcoBuilding</span>
                        <span class="shell-nav-label">Clients</span>
                    </NavLink>
                </div>
            }
        </div>

        <div class="shell-nav-group">
            <button class="shell-nav-item is-group" @onclick="() => _con = !_con">
                <span class="shell-nav-icon">@IcoDoc</span>
                <span class="shell-nav-label">Content</span>
                <span class="shell-nav-chev">@(_con ? IcoChevUp : IcoChevDown)</span>
            </button>
            @if (_con)
            {
                <div class="shell-nav-children">
                    <NavLink href="/blog" class="shell-nav-item is-child" ActiveClass="is-active">
                        <span class="shell-nav-icon">@IcoDoc</span>
                        <span class="shell-nav-label">Blog</span>
                    </NavLink>
                    <NavLink href="/inspirations" class="shell-nav-item is-child" ActiveClass="is-active">
                        <span class="shell-nav-icon">@IcoStar</span>
                        <span class="shell-nav-label">Inspirations</span>
                    </NavLink>
                </div>
            }
        </div>

        <div class="shell-nav-group">
            <button class="shell-nav-item is-group" @onclick="() => _sys = !_sys">
                <span class="shell-nav-icon">@IcoSettings</span>
                <span class="shell-nav-label">System</span>
                <span class="shell-nav-chev">@(_sys ? IcoChevUp : IcoChevDown)</span>
            </button>
            @if (_sys)
            {
                <div class="shell-nav-children">
                    <NavLink href="/users" class="shell-nav-item is-child" ActiveClass="is-active">
                        <span class="shell-nav-icon">@IcoUsers</span>
                        <span class="shell-nav-label">Users</span>
                    </NavLink>
                    <NavLink href="/register" class="shell-nav-item is-child" ActiveClass="is-active">
                        <span class="shell-nav-icon">@IcoLock</span>
                        <span class="shell-nav-label">Register Admin</span>
                    </NavLink>
                </div>
            }
        </div>

    </nav>

    <div class="shell-nav-foot">
        <div class="shell-store">
            <div class="shell-store-row">
                <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14">
                    <path d="M10 1a9 9 0 100 18A9 9 0 0010 1zm0 1.5a7.5 7.5 0 110 15 7.5 7.5 0 010-15z"/>
                </svg>
                <span>dwebshop.local</span>
            </div>
            <div class="shell-store-row">
                <span class="shell-dot is-up"></span>
                <span>All systems normal</span>
            </div>
        </div>
    </div>
</aside>

@code {
    [Parameter] public bool Collapsed { get; set; }

    private bool _cat = true;
    private bool _com = true;
    private bool _con = true;
    private bool _sys = true;

    private RenderFragment IcoHome     => __b => { __b.AddMarkupContent(0, @"<svg viewBox=""0 0 20 20"" fill=""currentColor"" width=""18"" height=""18""><path d=""M10 2.5L2.5 9.25H4.5V17h4v-5h3v5h4V9.25H17.5L10 2.5z""/></svg>"); };
    private RenderFragment IcoFolder   => __b => { __b.AddMarkupContent(0, @"<svg viewBox=""0 0 20 20"" fill=""currentColor"" width=""18"" height=""18""><path d=""M2 6a2 2 0 012-2h4l2 2h6a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z""/></svg>"); };
    private RenderFragment IcoTag      => __b => { __b.AddMarkupContent(0, @"<svg viewBox=""0 0 20 20"" fill=""currentColor"" width=""18"" height=""18""><path d=""M4 3h6.586a1 1 0 01.707.293l6 6a1 1 0 010 1.414l-5.586 5.586a1 1 0 01-1.414 0l-6-6A1 1 0 014 9.586V3zm2 2v4.172l5.5 5.5 4.672-4.672-5.5-5.5H6zm1.5 2a1 1 0 110-2 1 1 0 010 2z""/></svg>"); };
    private RenderFragment IcoStar     => __b => { __b.AddMarkupContent(0, @"<svg viewBox=""0 0 20 20"" fill=""currentColor"" width=""18"" height=""18""><path d=""M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z""/></svg>"); };
    private RenderFragment IcoCart     => __b => { __b.AddMarkupContent(0, @"<svg viewBox=""0 0 20 20"" fill=""currentColor"" width=""18"" height=""18""><path d=""M3 2.5a.75.75 0 000 1.5h1.33l2.474 8.626A2.25 2.25 0 008.97 14.5h5.56a2.25 2.25 0 002.166-1.628l1.15-4.025A.75.75 0 0017.125 8H5.73l-.47-1.634A.75.75 0 004.536 6H3V2.5zm5.5 12a1 1 0 110 2 1 1 0 010-2zm5.5 0a1 1 0 110 2 1 1 0 010-2z""/></svg>"); };
    private RenderFragment IcoReceipt  => __b => { __b.AddMarkupContent(0, @"<svg viewBox=""0 0 20 20"" fill=""currentColor"" width=""18"" height=""18""><path d=""M4 3a1 1 0 00-1 1v12a1 1 0 001.576.82L6 15.572l1.424.949a1 1 0 001.152 0L10 15.572l1.424.949a1 1 0 001.152 0L14 15.572l1.424.949A1 1 0 0017 16V4a1 1 0 00-1-1H4zm2 4h8v1.5H6V7zm0 3h8v1.5H6V10zm0 3h5v1.5H6V13z""/></svg>"); };
    private RenderFragment IcoMoney    => __b => { __b.AddMarkupContent(0, @"<svg viewBox=""0 0 20 20"" fill=""currentColor"" width=""18"" height=""18""><path d=""M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267zm0-9.98a1 1 0 00-2 0v.87a5.44 5.44 0 00-1.424.536C6.628 4.73 6 5.596 6 6.75c0 1.154.628 2.02 1.576 2.524A5.44 5.44 0 009 9.81v2.065a1.88 1.88 0 01-.67-.386C8.059 11.24 8 11.003 8 10.75a1 1 0 10-2 0c0 1.154.628 2.02 1.576 2.524A5.44 5.44 0 009 13.81V15a1 1 0 002 0v-.87a5.44 5.44 0 001.424-.536C13.372 13.27 14 12.404 14 11.25c0-1.154-.628-2.02-1.576-2.524A5.44 5.44 0 0011 8.19V6.125c.235.063.45.17.67.386.267.256.33.503.33.739a1 1 0 102 0c0-1.154-.628-2.02-1.576-2.524A5.44 5.44 0 0011 4.19V2.87z""/></svg>"); };
    private RenderFragment IcoBuilding => __b => { __b.AddMarkupContent(0, @"<svg viewBox=""0 0 20 20"" fill=""currentColor"" width=""18"" height=""18""><path d=""M3 4.25A2.25 2.25 0 015.25 2h9.5A2.25 2.25 0 0117 4.25v11.5A2.25 2.25 0 0114.75 18H5.25A2.25 2.25 0 013 15.75V4.25zm2.25-.75a.75.75 0 00-.75.75v11.5c0 .414.336.75.75.75h1.5V3.5h-1.5zm3 0v12.25h3.5V3.5h-3.5zm5 0v12.25h1.5a.75.75 0 00.75-.75V4.25a.75.75 0 00-.75-.75h-1.5z""/></svg>"); };
    private RenderFragment IcoDoc      => __b => { __b.AddMarkupContent(0, @"<svg viewBox=""0 0 20 20"" fill=""currentColor"" width=""18"" height=""18""><path d=""M4 2a2 2 0 00-2 2v12a2 2 0 002 2h12a2 2 0 002-2V7.414A2 2 0 0017.414 6L14 2.586A2 2 0 0012.586 2H4zm0 1.5h8v4a.5.5 0 00.5.5h4V16a.5.5 0 01-.5.5H4a.5.5 0 01-.5-.5V4a.5.5 0 01.5-.5zm8.5 3.5V3.621L15.879 7H12.5zM6 10.5h8v1H6v-1zm0 2.5h5v1H6v-1z""/></svg>"); };
    private RenderFragment IcoSettings => __b => { __b.AddMarkupContent(0, @"<svg viewBox=""0 0 20 20"" fill=""currentColor"" width=""18"" height=""18""><path d=""M10 2a.75.75 0 01.75.75v.84a6.25 6.25 0 014.41 4.41h.84a.75.75 0 010 1.5h-.84a6.25 6.25 0 01-4.41 4.41v.84a.75.75 0 01-1.5 0v-.84a6.25 6.25 0 01-4.41-4.41H4.25a.75.75 0 010-1.5h.84a6.25 6.25 0 014.41-4.41V2.75A.75.75 0 0110 2zm0 5a3 3 0 100 6 3 3 0 000-6zm0 1.5a1.5 1.5 0 110 3 1.5 1.5 0 010-3z""/></svg>"); };
    private RenderFragment IcoUsers    => __b => { __b.AddMarkupContent(0, @"<svg viewBox=""0 0 20 20"" fill=""currentColor"" width=""18"" height=""18""><path d=""M9 6a3 3 0 11-6 0 3 3 0 016 0zm-9 9a6 6 0 1112 0H0zm16-9a3 3 0 11-6 0 3 3 0 016 0zm-5.5 9a6.5 6.5 0 00-1.74-4.21A5 5 0 0115 11a5 5 0 014.5 2.83A6.9 6.9 0 0120 15h-9.5z""/></svg>"); };
    private RenderFragment IcoLock     => __b => { __b.AddMarkupContent(0, @"<svg viewBox=""0 0 20 20"" fill=""currentColor"" width=""18"" height=""18""><path d=""M10 1a4 4 0 00-4 4v2H4a2 2 0 00-2 2v8a2 2 0 002 2h12a2 2 0 002-2V9a2 2 0 00-2-2h-2V5a4 4 0 00-4-4zm2.5 6H7.5V5a2.5 2.5 0 015 0v2zm-3.25 5.25a.75.75 0 011.5 0v2a.75.75 0 01-1.5 0v-2z""/></svg>"); };
    private RenderFragment IcoChevDown => __b => { __b.AddMarkupContent(0, @"<svg viewBox=""0 0 14 14"" fill=""none"" stroke=""currentColor"" stroke-width=""1.5"" width=""14"" height=""14""><path d=""M2 4.5l5 5 5-5""/></svg>"); };
    private RenderFragment IcoChevUp   => __b => { __b.AddMarkupContent(0, @"<svg viewBox=""0 0 14 14"" fill=""none"" stroke=""currentColor"" stroke-width=""1.5"" width=""14"" height=""14""><path d=""M2 9.5l5-5 5 5""/></svg>"); };
}
