@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Antiforgery
@inject IAntiforgery Antiforgery
@inject IHttpContextAccessor HttpContextAccessor

<div class="shell @(_collapsed ? "is-collapsed" : "")">

    <NavMenu Collapsed="@_collapsed" />

    <header class="shell-top">
        <div class="shell-top-left">
            <button class="shell-icon-btn" title="Toggle navigation" @onclick="ToggleNav">
                <svg viewBox="0 0 20 20" fill="currentColor" width="18" height="18">
                    <path d="M2 4.5h16v1.5H2V4.5zm0 5h16V11H2v-1.5zm0 5h16V16H2v-1.5z"/>
                </svg>
            </button>
            <div class="shell-search">
                <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14">
                    <path d="M8.5 3a5.5 5.5 0 014.383 8.823l3.647 3.647a.75.75 0 01-1.06 1.06l-3.647-3.647A5.5 5.5 0 118.5 3zm0 1.5a4 4 0 100 8 4 4 0 000-8z"/>
                </svg>
                <input placeholder="Search products, orders, clients…" />
                <kbd>⌘K</kbd>
            </div>
        </div>
        <div class="shell-top-right">
            <button class="shell-icon-btn" title="Refresh">
                <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
                    <path d="M3.5 10a6.5 6.5 0 0011.14-4.596.75.75 0 011.498.096A8 8 0 113.5 10zm0 0a.75.75 0 01-1.5 0A8 8 0 0116.5 10a.75.75 0 01-1.5 0 6.5 6.5 0 10-13 0z"/>
                </svg>
            </button>
            <div class="shell-bell shell-icon-btn" title="Notifications">
                <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
                    <path d="M10 2a6 6 0 00-6 6v2.586l-1.707 1.707A1 1 0 003 14h14a1 1 0 00.707-1.707L16 10.586V8a6 6 0 00-6-6zm0 16a2 2 0 002-2H8a2 2 0 002 2z"/>
                </svg>
                <span class="shell-bell-dot"></span>
            </div>
            <div class="shell-divider"></div>
            <AuthorizeView>
                <Authorized>
                    <div class="shell-user">
                        <span class="shell-avatar" title="@context.User.Identity?.Name">
                            @(context.User.Identity?.Name?.Length > 0 ? context.User.Identity.Name[0].ToString().ToUpper() : "A")
                        </span>
                        <div class="shell-user-meta">
                            <div class="shell-user-name">@context.User.Identity?.Name</div>
                            <div class="shell-user-role">Admin</div>
                        </div>
                    </div>
                    <form method="post" action="/logout" style="display:contents">
                        @if (HttpContextAccessor.HttpContext is not null)
                        {
                            <input type="hidden" name="__RequestVerificationToken"
                                   value="@Antiforgery.GetAndStoreTokens(HttpContextAccessor.HttpContext!).RequestToken" />
                        }
                        <button type="submit" class="shell-icon-btn" title="Sign out">
                            <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
                                <path d="M3 3.75A.75.75 0 013.75 3h6.5a.75.75 0 010 1.5H4.5v11h5.75a.75.75 0 010 1.5h-6.5A.75.75 0 013 16.25V3.75zM13.22 7.22a.75.75 0 011.06 0l2.75 2.75a.75.75 0 010 1.06l-2.75 2.75a.75.75 0 11-1.06-1.06l1.47-1.47H7.75a.75.75 0 010-1.5h6.94l-1.47-1.47a.75.75 0 010-1.06z"/>
                            </svg>
                        </button>
                    </form>
                </Authorized>
            </AuthorizeView>
        </div>
    </header>

    <main class="shell-main">
        <div class="shell-main-inner">
            <ErrorBoundary>
                <ChildContent>@Body</ChildContent>
                <ErrorContent>
                    <div style="color: var(--danger); padding: 1rem;">An unexpected error occurred. Please refresh the page.</div>
                </ErrorContent>
            </ErrorBoundary>
        </div>
    </main>

</div>
@* Add all FluentUI Blazor Providers *@
<FluentProviders />

@code {
    private bool _collapsed;

    private void ToggleNav() => _collapsed = !_collapsed;
}
