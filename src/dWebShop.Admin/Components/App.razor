<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["dWebShop.Admin.styles.css"]" />
    <link rel="stylesheet" href="_content/Microsoft.FluentUI.AspNetCore.Components/css/reboot.css" />
    <link href="_content/Microsoft.FluentUI.AspNetCore.Components/Microsoft.FluentUI.AspNetCore.Components.bundle.scp.css" rel="stylesheet" />
    <ImportMap />
    <HeadOutlet />
    <script>
        // Disable browser scroll restoration as early as possible (before any layout/paint).
        if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
    </script>
</head>

<body>
    <Routes @rendermode="RenderModeForPage" />
    <ReconnectModal />
    <script src="_content/Microsoft.FluentUI.AspNetCore.Components/js/loading-theme.js" type="module"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script>
        // Scroll to top on Blazor navigation. Admin runs InteractiveServer at root, so navigation
        // happens via the circuit and the browser never auto-scrolls. Blazor's NavigationManager
        // calls history.pushState for forward nav, so we hook it. popstate is left alone so
        // back/forward keep native scroll restoration.
        (function() {
            function toTop() { window.scrollTo({ top: 0, behavior: 'instant' }); }
            toTop();
            window.addEventListener('load', toTop);

            document.addEventListener('enhancedload', toTop);

            var origPush = history.pushState;
            history.pushState = function() {
                var ret = origPush.apply(this, arguments);
                toTop();
                return ret;
            };

            window.addEventListener('popstate', toTop);
        })();
    </script>
</body>

</html>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    private IComponentRenderMode? RenderModeForPage => HttpContext.Request.Path.StartsWithSegments("/Account")
        ? null
        : new InteractiveServerRenderMode(false);
}