@using MediatR
@using dWebShop.Application.Dto.Images
@using dWebShop.Application.Queries.Images
@inject IJSRuntime JS
@inject IMediator Mediator

<FluentDialog @ref="_dialog" TrapFocus="true" Modal="true" PreventScroll="true"
              Style="--dialog-width: 960px; --dialog-height: auto;">
    <FluentDialogBody Style="padding: 0;">
        <FluentStack Orientation="Orientation.Vertical" Style="gap: 0; height: 100%;">

            {{-- Title row --}}
            <FluentStack Orientation="Orientation.Horizontal"
                         VerticalAlignment="VerticalAlignment.Center"
                         Style="padding: 12px 16px; border-bottom: 1px solid var(--colorNeutralStroke1);">
                <FluentLabel Style="font-size: 18px; font-weight: 600;">Odabir slika</FluentLabel>
                <FluentSpacer />
                <FluentButton Appearance="ButtonAppearance.Transparent"
                              IconStart="@(new Icons.Regular.Size20.Dismiss())"
                              OnClick="Hide" />
            </FluentStack>

            {{-- Search + Upload row --}}
            <FluentStack Orientation="Orientation.Horizontal"
                         VerticalAlignment="VerticalAlignment.Center"
                         Style="padding: 8px 16px; border-bottom: 1px solid var(--colorNeutralStroke1); gap: 8px;">
                <FluentTextField @bind-Value="_searchFilter"
                                 Placeholder="Naziv slike"
                                 Style="flex: 1;"
                                 IconStart="@(new Icons.Regular.Size20.Search())" />
                <FluentButton Appearance="ButtonAppearance.Primary" OnClick="OpenFilePicker">
                    Upload
                </FluentButton>
            </FluentStack>

            {{-- Image grid --}}
            <div style="max-height: 500px; overflow-y: auto; padding: 12px 16px;">
                @if (_images.Count > 0)
                {
                    <div style="display: flex; flex-wrap: wrap; gap: 8px;">
                        @foreach (var image in FilteredImages)
                        {
                            var selected = IsSelected(image.Filename);
                            <div style="cursor: pointer; position: relative; border: 2px solid @(selected ? "var(--colorBrandBackground)" : "var(--colorNeutralStroke1)"); border-radius: 4px; overflow: hidden; width: 148px;"
                                 @onclick="@(() => SelectImage(image.Filename))">
                                <img src="@($"/{image.Filename}")"
                                     width="144" height="144"
                                     title="@image.Name"
                                     style="object-fit: cover; display: block;" />
                                <div style="padding: 3px 4px; font-size: 12px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"
                                     title="@image.Name">
                                    @image.Name
                                </div>
                                @if (selected)
                                {
                                    <div style="position: absolute; top: 4px; right: 4px; background: var(--colorBrandBackground); border-radius: 50%; width: 22px; height: 22px; display: flex; align-items: center; justify-content: center;">
                                        <FluentIcon Value="@(new Icons.Regular.Size16.Checkmark())"
                                                    Style="color: white;" />
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    <FluentLabel>Nema pronađenih slika.</FluentLabel>
                }
            </div>

            <FluentDivider />

            {{-- Footer --}}
            <FluentStack Orientation="Orientation.Horizontal"
                         Style="padding: 12px 16px; gap: 8px;">
                <FluentButton Appearance="ButtonAppearance.Primary" OnClick="Accepted">
                    Prihvati
                </FluentButton>
                <FluentButton OnClick="Hide">Odustani</FluentButton>
                <InputFile id="@_fileInputId" style="display:none;" OnChange="OnFileSelected" multiple />
            </FluentStack>

        </FluentStack>
    </FluentDialogBody>
</FluentDialog>

@code {
    private List<ImageFileDto> _images = new();
    private List<string> _selectedImages = new();
    private string _searchFilter = "";
    private FluentDialog? _dialog;
    private readonly string _fileInputId = $"img-picker-{Guid.NewGuid():N}";

    [Parameter] public EventCallback<List<string>> OnAccepted { get; set; }

    private IEnumerable<ImageFileDto> FilteredImages =>
        string.IsNullOrWhiteSpace(_searchFilter)
            ? _images
            : _images.Where(i => i.Name.Contains(_searchFilter, StringComparison.OrdinalIgnoreCase));

    public async Task Show()
    {
        _selectedImages.Clear();
        _searchFilter = "";
        await LoadImagesAsync();
        _dialog?.Show();
    }

    public void Hide() => _dialog?.Hide();

    private async Task LoadImagesAsync()
    {
        var query = new GetImagesQuery { FolderPath = "wwwroot/post_images" };
        var result = await Mediator.Send(query);
        if (result.Successful && result.Items != null)
            _images = result.Items.ToList();
        else
            Console.Error.WriteLine("Failed to load images: " + result.Error);
    }

    private async Task OpenFilePicker()
        => await JS.InvokeVoidAsync("eval", $"document.getElementById('{_fileInputId}').click()");

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        var folder = Path.Combine("wwwroot", "post_images");
        Directory.CreateDirectory(folder);

        foreach (var file in e.GetMultipleFiles(maxAllowedFiles: 20))
        {
            var fullPath = Path.Combine(folder, Path.GetFileName(file.Name));
            await using var stream = new FileStream(fullPath, FileMode.Create);
            await file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(stream);
        }

        await LoadImagesAsync();
        StateHasChanged();
    }

    private void SelectImage(string filename)
    {
        if (_selectedImages.Contains(filename))
            _selectedImages.Remove(filename);
        else
            _selectedImages.Add(filename);
    }

    private bool IsSelected(string filename) => _selectedImages.Contains(filename);

    private async Task Accepted()
    {
        await OnAccepted.InvokeAsync(new List<string>(_selectedImages));
        Hide();
    }
}
