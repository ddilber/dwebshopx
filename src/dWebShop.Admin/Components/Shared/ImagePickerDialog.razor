@using MediatR
@using dWebShop.Application.Features.Images.Queries
@inject IJSRuntime JS
@inject IMediator Mediator
@inject IWebHostEnvironment Env

@if (_visible)
{
    <div class="img-picker-overlay" @onclick="Hide">
        <div class="img-picker-dialog" @onclick:stopPropagation="true">

            @* Title row *@
            <div class="img-picker-header">
                <span style="font-size: 18px; font-weight: 600;">Odabir slika</span>
                <FluentButton Appearance="ButtonAppearance.Transparent"
                              IconStart="@(new Icons.Regular.Size20.Dismiss())"
                              OnClick="Hide" />
            </div>

            @* Search + Upload row *@
            <div class="img-picker-toolbar">
                <FluentIcon Value="@(new Icons.Regular.Size20.Search())" Style="color: var(--colorNeutralForeground3); flex-shrink:0;" />
                <input type="search" class="admin-search-input" style="flex:1;"
                       placeholder="Naziv slike"
                       @bind="_searchFilter" @bind:event="oninput" />
                <FluentButton Appearance="ButtonAppearance.Primary" OnClick="OpenFilePicker">
                    Upload
                </FluentButton>
            </div>

            @* Image grid *@
            <div class="img-picker-grid-wrap">
                @if (FilteredImages.Any())
                {
                    <div class="img-picker-grid">
                        @foreach (var image in FilteredImages)
                        {
                            var filename = image.Filename;
                            var selected = IsSelected(filename);
                            <div class="img-picker-item @(selected ? "is-selected" : "")"
                                 @onclick="@(() => SelectImage(filename))">
                                <img src="@($"/{filename}")" width="144" height="144"
                                     title="@image.Name"
                                     style="object-fit: cover; display: block;" />
                                <div class="img-picker-name" title="@image.Name">@image.Name</div>
                                @if (selected)
                                {
                                    <div class="img-picker-check">
                                        <FluentIcon Value="@(new Icons.Regular.Size16.Checkmark())" Style="color: white;" />
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p style="color: var(--colorNeutralForeground3); padding: 24px; text-align: center;">Nema pronađenih slika.</p>
                }
            </div>

            @* Footer *@
            <div class="img-picker-footer">
                <FluentButton Appearance="ButtonAppearance.Primary" OnClick="Accepted">Prihvati</FluentButton>
                <FluentButton OnClick="Hide">Odustani</FluentButton>
                <InputFile id="@_fileInputId" style="display:none;" OnChange="OnFileSelected" multiple />
            </div>

        </div>
    </div>
}

@code {
    private List<ImageFileDto> _images = new();
    private List<string> _selectedImages = new();
    private string _searchFilter = "";
    private bool _visible;
    private readonly string _fileInputId = $"img-picker-{Guid.NewGuid():N}";

    [Parameter] 
    public EventCallback<List<string>> OnAccepted { get; set; }
    [Parameter]
    public string SubFolder { get; set; } = "post_images";
    [Parameter]
    public bool SingleSelect { get; set; } = false;

    private IEnumerable<ImageFileDto> FilteredImages =>
        string.IsNullOrWhiteSpace(_searchFilter)
            ? _images
            : _images.Where(i => i.Name.Contains(_searchFilter, StringComparison.OrdinalIgnoreCase));

    public async Task Show()
    {
        _selectedImages.Clear();
        _searchFilter = "";
        await LoadImagesAsync();
        _visible = true;
        StateHasChanged();
    }

    public void Hide()
    {
        _visible = false;
        StateHasChanged();
    }

    private async Task LoadImagesAsync()
    {        
        var result = await Mediator.Send(new GetImagesQuery
        {
            FolderPath = Path.Combine(Env.WebRootPath, SubFolder),
            SubFolder = SubFolder
        });
        _images = result;
    }

    private async Task OpenFilePicker()
        => await JS.InvokeVoidAsync("eval", $"document.getElementById('{_fileInputId}').click()");

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        var folder = Path.Combine(Env.WebRootPath, SubFolder);
        Directory.CreateDirectory(folder);

        foreach (var file in e.GetMultipleFiles(20))
        {
            var fullPath = Path.Combine(folder, Path.GetFileName(file.Name));
            await using var stream = new FileStream(fullPath, FileMode.Create);
            await file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(stream);
        }

        await LoadImagesAsync();
        StateHasChanged();
    }

    private void SelectImage(string filename)
    {
        if (_selectedImages.Contains(filename))
        {
            _selectedImages.Remove(filename);
        }
        else
        {
            if (SingleSelect) _selectedImages.Clear();
            _selectedImages.Add(filename);
        }
    }

    private bool IsSelected(string filename) => _selectedImages.Contains(filename);

    private async Task Accepted()
    {
        await OnAccepted.InvokeAsync(new List<string>(_selectedImages));
        await Hide();
    }
}
