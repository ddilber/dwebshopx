@page "/categories"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@using MediatR
@using dWebShop.Application.Features.Categories.Queries
@using dWebShop.Application.Features.Categories.Commands
@inject IMediator Mediator

<PageTitle>Categories — dWebShop Admin</PageTitle>

<FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="margin-bottom: 16px;">
    <FluentLabel Style="font-size: 22px; font-weight: 600;">Categories</FluentLabel>
    <FluentSpacer />
    <FluentButton Appearance="ButtonAppearance.Primary" IconStart="@(new Icons.Regular.Size16.Add())" OnClick="OpenCreate">
        Add Category
    </FluentButton>
</FluentStack>
<FluentDivider Style="margin-bottom: 24px;" />

@if (_loading)
{
    <FluentProgressRing />
}
else if (_categories is not null)
{
    <FluentDataGrid Items="@_categories.AsQueryable()" TGridItem="CategoryDto">
        <PropertyColumn Title="Name" Property="@(c => c.Name)" Sortable="true" />
        <PropertyColumn Title="Slug" Property="@(c => c.Slug)" />
        <PropertyColumn Title="Parent" Property="@(c => c.ParentName)" />
        <TemplateColumn Title="Actions">
            <FluentButton IconStart="@(new Icons.Regular.Size16.Edit())" OnClick="@(() => OpenEdit(context))">Edit</FluentButton>
        </TemplateColumn>
    </FluentDataGrid>
}

@if (_dialogOpen)
{
    <div class="img-picker-overlay" @onclick="CloseDialog">
        <div class="img-picker-dialog" style="width: 420px;" @onclick:stopPropagation="true">
            <div class="img-picker-header">
                <span style="font-size: 18px; font-weight: 600;">@(_editModel.Id == 0 ? "Add Category" : "Edit Category")</span>
                <FluentButton Appearance="ButtonAppearance.Transparent" IconStart="@(new Icons.Regular.Size16.Dismiss())" OnClick="CloseDialog" />
            </div>
            <div style="padding: 16px; display: flex; flex-direction: column; gap: 12px;">
                <FluentTextInput @bind-Value="_editModel.Name" Label="Name" Style="width: 100%" />
                <FluentTextInput @bind-Value="_editModel.Slug" Label="Slug" Style="width: 100%" />
            </div>
            <div class="img-picker-footer">
                <FluentButton Appearance="ButtonAppearance.Primary" OnClick="Save">Save</FluentButton>
                <FluentButton OnClick="CloseDialog">Cancel</FluentButton>
            </div>
        </div>
    </div>
}

@code {
    private List<CategoryDto>? _categories;
    private bool _loading = true;
    private bool _dialogOpen;
    private CategoryEditModel _editModel = new();

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        var result = await Mediator.Send(new GetCategoriesQuery());
        _categories = result.ToList();
        _loading = false;
    }

    private void OpenCreate() { _editModel = new(); _dialogOpen = true; }

    private void OpenEdit(CategoryDto category)
    {
        _editModel = new() { Id = category.Id, Name = category.Name, Slug = category.Slug };
        _dialogOpen = true;
    }

    private void CloseDialog() => _dialogOpen = false;

    private async Task Save()
    {
        if (_editModel.Id == 0)
            await Mediator.Send(new CreateCategoryCommand(_editModel.Name, _editModel.Slug, "", null, null));
        else
            await Mediator.Send(new UpdateCategoryCommand(_editModel.Id, _editModel.Name, _editModel.Slug, "", null, null));

        _dialogOpen = false;
        await LoadAsync();
    }

    private class CategoryEditModel
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string Slug { get; set; } = "";
    }
}
