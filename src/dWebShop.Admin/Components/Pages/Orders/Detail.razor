@page "/orders/{OrderGuid:guid}"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@using MediatR
@using dWebShop.Application.Features.Orders.Queries
@using dWebShop.Application.Features.Orders.Commands
@using dWebShop.Application.Features.Products.Queries
@using dWebShop.Domain.Entities.Orders
@inject IMediator Mediator
@inject NavigationManager Navigation

<PageTitle>Order Detail — dWebShop Admin</PageTitle>

@if (_loading)
{
    <div style="padding: 48px; text-align: center; color: var(--fg-3);">Loading…</div>
}
else if (_order is null)
{
    <p>Order not found.</p>
}
else
{
    <div class="admin-page-head">
        <div>
            <nav class="admin-breadcrumb">
                <a href="/orders" style="color: inherit; text-decoration: none;">Commerce</a>
                &nbsp;›&nbsp;
                <a href="/orders" style="color: inherit; text-decoration: none;">Orders</a>
                &nbsp;›&nbsp; #@_order.Id
            </nav>
            <div class="admin-detail-title-row">
                <h1 class="admin-page-title" style="margin: 4px 0 0;">@($"#{_order.Id}")</h1>
                <span class="order-badge status-@_order.Status.ToString().ToLower()">@_order.Status</span>
                <span class="order-badge payment-@_order.PaymentStatus.ToLower()">@_order.PaymentStatus</span>
            </div>
            <p class="admin-page-sub">Placed @_order.Created.ToString("dd MMM yyyy, HH:mm") · @_order.Channel · @_order.Items.Count items</p>
        </div>
        <div class="admin-page-actions">
            <FluentButton Appearance="ButtonAppearance.Transparent"
                          IconStart="@(new Icons.Regular.Size16.ArrowLeft())"
                          OnClick="@(() => Navigation.NavigateTo("/orders"))">Back</FluentButton>
            <FluentButton Appearance="ButtonAppearance.Transparent" IconStart="@(new Icons.Regular.Size16.ArrowDownload())">Print invoice</FluentButton>
            <FluentButton Appearance="ButtonAppearance.Transparent" IconStart="@(new Icons.Regular.Size16.Mail())">Resend confirmation</FluentButton>
            <select class="admin-search-input" style="min-width: 130px;" @onchange="OnStatusChanged">
                @foreach (var s in Enum.GetValues<OrderStatus>())
                {
                    <option value="@s" selected="@(_order.Status == s)">@s</option>
                }
            </select>
            @if (NextStatus.HasValue)
            {
                <FluentButton Appearance="ButtonAppearance.Primary"
                              IconStart="@(new Icons.Regular.Size16.CheckmarkCircle())"
                              OnClick="AdvanceStatus">@NextActionLabel</FluentButton>
            }
        </div>
    </div>

    @* ── Timeline ──────────────────────────────────────── *@
    <FluentCard Style="margin-bottom: 16px; padding: 20px 24px;">
        <div class="order-timeline">
            @foreach (var (step, idx) in _timelineSteps.Select((s, i) => (s, i)))
            {
                var done = IsStepDone(idx);
                var isLast = idx == _timelineSteps.Length - 1;
                <div class="tl-step @(done ? "is-done" : "") @(isLast ? "is-last" : "")">
                    <div class="tl-dot">
                        @if (done)
                        {
                            <FluentIcon Value="@(new Icons.Regular.Size12.Checkmark())" Style="color:white;" />
                        }
                        else
                        {
                            <span>@(idx + 1)</span>
                        }
                    </div>
                    <div class="tl-meta">
                        <div class="tl-label">@step.Label</div>
                        <div class="tl-time">@(done ? step.Time(_order) : "—")</div>
                    </div>
                </div>
            }
        </div>
    </FluentCard>

    @* ── Detail grid ───────────────────────────────────── *@
    <div class="admin-detail-grid">

        @* Main column *@
        <div class="admin-detail-main">

            @* Items *@
            <FluentCard>
                <div class="order-card-head">
                    <span class="order-card-title">Items</span>
                    <div style="display:flex; align-items:center; gap: 12px;">
                        <span style="color: var(--colorNeutralForeground3); font-size: 13px;">@_order.Items.Count items · @_order.Items.Sum(i => i.Price * i.Quantity).ToString("C2")</span>
                        <FluentButton Appearance="ButtonAppearance.Transparent"
                                      IconStart="@(new Icons.Regular.Size16.Add())"
                                      Style="font-size: 12px;"
                                      OnClick="OpenAddItem">Add item</FluentButton>
                    </div>
                </div>
                <div class="order-items">
                    @foreach (var item in _order.Items)
                    {
                        <div class="oi-row">
                            <div class="oi-thumb"></div>
                            <div class="oi-main">
                                <div class="oi-name">@item.ProductName</div>
                                <div class="oi-sub"><span class="oi-mono">@item.SKU</span></div>
                            </div>
                            <div class="oi-qty">×@((int)item.Quantity)</div>
                            <div class="oi-price">@item.Price.ToString("C2")</div>
                        </div>
                    }
                </div>
                <div class="order-totals">
                    @{ var subtotal = _order.Items.Sum(i => i.Price * i.Quantity); }
                    <div><span>Subtotal</span><span>@subtotal.ToString("C2")</span></div>
                    <div><span>Shipping (Standard)</span><span>$0.00</span></div>
                    <div><span>Tax</span><span>$0.00</span></div>
                    <div class="grand">
                        <span>Total</span>
                        <span>@subtotal.ToString("C2")</span>
                    </div>
                </div>
            </FluentCard>

            @* Activity *@
            <FluentCard>
                <div class="order-card-title" style="margin-bottom: 16px;">Activity</div>
                <div class="order-activity">
                    <div class="act-row">
                        <span class="order-avatar act-avatar">SY</span>
                        <div class="act-main">
                            <div><strong>System</strong> Order placed and payment captured</div>
                            <div class="act-time">@_order.Created.ToString("dd MMM, HH:mm")</div>
                        </div>
                    </div>
                    <div class="act-row">
                        <span class="order-avatar act-avatar">SY</span>
                        <div class="act-main">
                            <div><strong>System</strong> Order confirmation sent to customer</div>
                            <div class="act-time">@_order.Created.ToString("dd MMM, HH:mm")</div>
                        </div>
                    </div>
                </div>
                <div class="act-note-row">
                    <span class="order-avatar act-avatar">A</span>
                    <input class="act-note-input" placeholder="Add an internal note…" />
                </div>
            </FluentCard>

        </div>

        @* Sidebar *@
        <div class="admin-detail-side">

            @* Customer *@
            <FluentCard>
                <div class="order-card-title" style="margin-bottom: 12px;">Customer</div>
                <div class="order-cust-block">
                    <span class="order-avatar" title="@_order.PartnerName">@GetInitials(_order.PartnerName)</span>
                    <div>
                        <div style="font-weight: 600;">@_order.PartnerName</div>
                        <div style="font-size: 12px; color: var(--colorNeutralForeground3);">Customer</div>
                    </div>
                </div>
                <div class="order-kv">
                    <FluentIcon Value="@(new Icons.Regular.Size16.Mail())" Style="color:var(--colorNeutralForeground3);" />
                    <span>@_order.PartnerEmail</span>
                </div>
                @if (!string.IsNullOrEmpty(_order.PartnerPhone))
                {
                    <div class="order-kv">
                        <FluentIcon Value="@(new Icons.Regular.Size16.Phone())" Style="color:var(--colorNeutralForeground3);" />
                        <span>@_order.PartnerPhone</span>
                    </div>
                }
            </FluentCard>

            @* Shipping address *@
            <FluentCard>
                <div class="order-card-title" style="margin-bottom: 8px;">Shipping address</div>
                @if (!string.IsNullOrEmpty(_order.DeliveryAddress))
                {
                    <div class="order-addr">@_order.DeliveryAddress</div>
                }
                else
                {
                    <div style="color: var(--colorNeutralForeground3); font-size: 13px;">No shipping address on file</div>
                }
                <FluentButton Appearance="ButtonAppearance.Transparent"
                              IconStart="@(new Icons.Regular.Size16.Edit())"
                              Style="margin-top: 8px; font-size: 12px;"
                              OnClick="OpenAddressEdit">Edit</FluentButton>
            </FluentCard>

            @* Payment *@
            <FluentCard>
                <div class="order-card-title" style="margin-bottom: 12px;">Payment</div>
                <div class="order-kv">
                    <FluentIcon Value="@(new Icons.Regular.Size16.Payment())" Style="color:var(--colorNeutralForeground3);" />
                    <span>@_order.Channel</span>
                </div>
                <div class="order-kv">
                    <FluentIcon Value="@(new Icons.Regular.Size16.DocumentText())" Style="color:var(--colorNeutralForeground3);" />
                    <span style="font-size:12px; color:var(--colorNeutralForeground2);">Payment reference</span>
                </div>
                <div style="margin-top: 8px;">
                    <span class="order-badge payment-@_order.PaymentStatus.ToLower()">@_order.PaymentStatus · @_order.Items.Sum(i => i.Price * i.Quantity).ToString("C2")</span>
                </div>
            </FluentCard>

            @* Notes / Tags *@
            @if (!string.IsNullOrEmpty(_order.Notes))
            {
                <FluentCard>
                    <div class="order-card-title" style="margin-bottom: 8px;">Notes</div>
                    <div style="font-size: 13px; color: var(--colorNeutralForeground2); line-height: 1.5;">@_order.Notes</div>
                </FluentCard>
            }


        </div>
    </div>
}

@if (_addrDialogOpen)
{
    <div class="img-picker-overlay" @onclick="CloseAddressEdit">
        <div class="img-picker-dialog" style="width: 440px;" @onclick:stopPropagation="true">
            <div class="img-picker-header">
                <span style="font-size: 18px; font-weight: 600;">Edit shipping address</span>
                <FluentButton Appearance="ButtonAppearance.Transparent" IconStart="@(new Icons.Regular.Size16.Dismiss())" OnClick="CloseAddressEdit" />
            </div>
            <div style="padding: 16px; display: flex; flex-direction: column; gap: 12px;">
                <div style="display: flex; flex-direction: column; gap: 4px;">
                    <label style="font-size: 12px; font-weight: 500; color: var(--colorNeutralForeground2);">Address line 1</label>
                    <input class="admin-search-input" style="width:100%;" @bind="_addrModel.Address1" placeholder="Street address" />
                </div>
                <div style="display: flex; flex-direction: column; gap: 4px;">
                    <label style="font-size: 12px; font-weight: 500; color: var(--colorNeutralForeground2);">Address line 2</label>
                    <input class="admin-search-input" style="width:100%;" @bind="_addrModel.Address2" placeholder="Apartment, suite, etc. (optional)" />
                </div>
                <div style="display: flex; gap: 12px;">
                    <div style="flex: 1; display: flex; flex-direction: column; gap: 4px;">
                        <label style="font-size: 12px; font-weight: 500; color: var(--colorNeutralForeground2);">ZIP / Postal code</label>
                        <input class="admin-search-input" style="width:100%;" @bind="_addrModel.ZipCode" placeholder="00000" />
                    </div>
                    <div style="flex: 2; display: flex; flex-direction: column; gap: 4px;">
                        <label style="font-size: 12px; font-weight: 500; color: var(--colorNeutralForeground2);">City</label>
                        <input class="admin-search-input" style="width:100%;" @bind="_addrModel.City" placeholder="City" />
                    </div>
                </div>
                <div style="display: flex; flex-direction: column; gap: 4px;">
                    <label style="font-size: 12px; font-weight: 500; color: var(--colorNeutralForeground2);">Country</label>
                    <input class="admin-search-input" style="width:100%;" @bind="_addrModel.Country" placeholder="Country" />
                </div>
                @if (_addrSaveError is not null)
                {
                    <div class="create-order-error">@_addrSaveError</div>
                }
            </div>
            <div class="img-picker-footer">
                <FluentButton Appearance="ButtonAppearance.Primary" OnClick="SaveAddress" Disabled="@_addrSaving">
                    @(_addrSaving ? "Saving…" : "Save")
                </FluentButton>
                <FluentButton OnClick="CloseAddressEdit">Cancel</FluentButton>
            </div>
        </div>
    </div>
}

@if (_addItemDialogOpen)
{
    <div class="img-picker-overlay" @onclick="CloseAddItem">
        <div class="img-picker-dialog" style="width: 500px;" @onclick:stopPropagation="true">
            <div class="img-picker-header">
                <span style="font-size: 18px; font-weight: 600;">Add item</span>
                <FluentButton Appearance="ButtonAppearance.Transparent" IconStart="@(new Icons.Regular.Size16.Dismiss())" OnClick="CloseAddItem" />
            </div>
            <div style="padding: 16px; display: flex; flex-direction: column; gap: 14px;">

                @* Product search *@
                <div style="display: flex; gap: 8px;">
                    <input class="admin-search-input" style="flex: 1;"
                           @bind="_productSearch"
                           @bind:event="oninput"
                           @onkeyup="@(async e => { if (e.Key == "Enter") await SearchProducts(); })"
                           placeholder="Search products by name or SKU…" />
                    <FluentButton Appearance="ButtonAppearance.Transparent"
                                  IconStart="@(new Icons.Regular.Size16.Search())"
                                  OnClick="SearchProducts">Search</FluentButton>
                </div>

                @* Search results *@
                @if (_productSearchResults is not null)
                {
                    @if (_productSearchResults.Count == 0)
                    {
                        <div style="font-size: 13px; color: var(--colorNeutralForeground3);">No products found.</div>
                    }
                    else
                    {
                        <div style="display: flex; flex-direction: column; gap: 4px; max-height: 200px; overflow-y: auto;">
                            @foreach (var p in _productSearchResults)
                            {
                                var prod = p;
                                var isSelected = _selectedProduct?.Id == prod.Id;
                                <div class="oi-row @(isSelected ? "is-selected" : "")"
                                     style="cursor: pointer; border-radius: 6px; padding: 8px; @(isSelected ? "background: var(--colorBrandBackground2);" : "")"
                                     @onclick="@(() => SelectProduct(prod))">
                                    <div class="oi-main">
                                        <div class="oi-name">@prod.Name</div>
                                        <div class="oi-sub"><span class="oi-mono">@prod.SKU</span></div>
                                    </div>
                                    @if (prod.MinPrice.HasValue)
                                    {
                                        <div class="oi-price">@prod.MinPrice.Value.ToString("C2")</div>
                                    }
                                </div>
                            }
                        </div>
                    }
                }

                @* SKU + Qty + Price (shown once a product is selected) *@
                @if (_selectedProduct is not null && _skuOptions is not null)
                {
                    <div style="display: flex; flex-direction: column; gap: 4px;">
                        <label style="font-size: 12px; font-weight: 500; color: var(--colorNeutralForeground2);">SKU</label>
                        <select class="admin-search-input" @onchange="OnSkuChanged">
                            @foreach (var sku in _skuOptions)
                            {
                                <option value="@sku.Id" selected="@(_selectedSkuId == sku.Id)">
                                    @sku.SKU@(string.IsNullOrWhiteSpace(sku.Name) ? "" : $" — {sku.Name}") · @sku.Price.ToString("C2")
                                </option>
                            }
                        </select>
                    </div>
                    <div style="display: flex; gap: 12px;">
                        <div style="flex: 1; display: flex; flex-direction: column; gap: 4px;">
                            <label style="font-size: 12px; font-weight: 500; color: var(--colorNeutralForeground2);">Quantity</label>
                            <input class="admin-search-input" type="number" min="1" style="width:100%;"
                                   @bind="_addItemQty" />
                        </div>
                        <div style="flex: 1; display: flex; flex-direction: column; gap: 4px;">
                            <label style="font-size: 12px; font-weight: 500; color: var(--colorNeutralForeground2);">Unit price</label>
                            <input class="admin-search-input" type="number" min="0" step="0.01" style="width:100%;"
                                   @bind="_addItemPrice" />
                        </div>
                    </div>
                }

                @if (_addItemError is not null)
                {
                    <div class="create-order-error">@_addItemError</div>
                }
            </div>
            <div class="img-picker-footer">
                <FluentButton Appearance="ButtonAppearance.Primary"
                              OnClick="SaveAddItem"
                              Disabled="@(_addItemSaving || _selectedProduct is null || !_selectedSkuId.HasValue)">
                    @(_addItemSaving ? "Adding…" : "Add item")
                </FluentButton>
                <FluentButton OnClick="CloseAddItem">Cancel</FluentButton>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid OrderGuid { get; set; }

    private OrderDetailDto? _order;
    private bool _loading = true;
    private bool _updating;
    private string _note = "";

    private bool IsProcessingDone => _order?.Status is OrderStatus.Processing or OrderStatus.Shipped or OrderStatus.Delivered;
    private bool IsShippedDone => _order?.Status is OrderStatus.Shipped or OrderStatus.Delivered;
    private bool IsDeliveredDone => _order?.Status == OrderStatus.Delivered;

    private record TimelineStep(string Label, Func<OrderDetailDto, string> Time);

    private static readonly TimelineStep[] _timelineSteps =
    [
        new("Placed",     o => o.Created.ToString("dd MMM, HH:mm")),
        new("Paid",       o => o.Created.ToString("dd MMM, HH:mm")),
        new("Processing", o => "—"),
        new("Shipped",    o => "—"),
        new("Delivered",  o => "—"),
    ];

    private int StatusRank => _order?.Status switch
    {
        OrderStatus.Pending    => 1,
        OrderStatus.Processing => 2,
        OrderStatus.Shipped    => 3,
        OrderStatus.Delivered  => 4,
        _                      => 1,
    };

    private bool IsStepDone(int stepIndex) => stepIndex < StatusRank;

    private OrderStatus? NextStatus => _order?.Status switch
    {
        OrderStatus.Pending    => OrderStatus.Processing,
        OrderStatus.Processing => OrderStatus.Shipped,
        OrderStatus.Shipped    => OrderStatus.Delivered,
        _                      => null,
    };

    private string NextActionLabel => NextStatus switch
    {
        OrderStatus.Processing => "Process Order",
        OrderStatus.Shipped    => "Mark Shipped",
        OrderStatus.Delivered  => "Mark Delivered",
        _                      => "",
    };

    protected override async Task OnInitializedAsync()
    {
        _order = await Mediator.Send(new GetOrderByGuidQuery(OrderGuid));
        _loading = false;
    }

    private async Task AdvanceStatus()
    {
        if (_order is null || !NextStatus.HasValue) return;
        await Mediator.Send(new UpdateOrderStatusCommand(_order.Id, NextStatus.Value));
        _order = await Mediator.Send(new GetOrderByGuidQuery(OrderGuid));
        StateHasChanged();
    }

    private async Task OnStatusChanged(ChangeEventArgs e)
    {
        if (_order is null) return;
        if (Enum.TryParse<OrderStatus>(e.Value?.ToString(), out var newStatus) && newStatus != _order.Status)
        {
            await Mediator.Send(new UpdateOrderStatusCommand(_order.Id, newStatus));
            _order = await Mediator.Send(new GetOrderByGuidQuery(OrderGuid));
            StateHasChanged();
        }
    }

    // ── Add item ──────────────────────────────────────────
    private bool _addItemDialogOpen;
    private bool _addItemSaving;
    private string? _addItemError;
    private string _productSearch = "";
    private List<ProductListItemDto>? _productSearchResults;
    private ProductListItemDto? _selectedProduct;
    private List<OrderItemSkuDto>? _skuOptions;
    private int? _selectedSkuId;
    private decimal _addItemQty = 1;
    private decimal _addItemPrice;

    private void OpenAddItem()
    {
        _productSearch = "";
        _productSearchResults = null;
        _selectedProduct = null;
        _skuOptions = null;
        _selectedSkuId = null;
        _addItemQty = 1;
        _addItemPrice = 0;
        _addItemError = null;
        _addItemDialogOpen = true;
    }

    private void CloseAddItem()
    {
        _addItemDialogOpen = false;
        _addItemError = null;
    }

    private async Task SearchProducts()
    {
        if (string.IsNullOrWhiteSpace(_productSearch)) return;
        var result = await Mediator.Send(new GetProductsQuery(Search: _productSearch, Count: 10, IncludePrice: true));
        _productSearchResults = result.Items;
        _selectedProduct = null;
        _skuOptions = null;
        _selectedSkuId = null;
    }

    private async Task SelectProduct(ProductListItemDto product)
    {
        _selectedProduct = product;
        _skuOptions = await Mediator.Send(new GetSkusForOrderItemQuery(product.Id));
        var first = _skuOptions.FirstOrDefault();
        _selectedSkuId = first?.Id;
        _addItemPrice = first?.Price ?? 0;
    }

    private void OnSkuChanged(ChangeEventArgs e)
    {
        if (!int.TryParse(e.Value?.ToString(), out var skuId)) return;
        _selectedSkuId = skuId;
        var sku = _skuOptions?.FirstOrDefault(s => s.Id == skuId);
        if (sku is not null) _addItemPrice = sku.Price;
    }

    private async Task SaveAddItem()
    {
        if (_order is null || _selectedProduct is null || !_selectedSkuId.HasValue) return;
        _addItemSaving = true;
        _addItemError = null;
        try
        {
            await Mediator.Send(new AddOrderItemCommand(
                _order.Id,
                _selectedProduct.Id,
                _selectedSkuId.Value,
                _addItemQty,
                _addItemPrice));
            _addItemDialogOpen = false;
            _order = await Mediator.Send(new GetOrderByGuidQuery(OrderGuid));
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _addItemError = ex.Message;
        }
        _addItemSaving = false;
    }

    private bool _addrDialogOpen;
    private bool _addrSaving;
    private string? _addrSaveError;
    private AddressModel _addrModel = new();

    private void OpenAddressEdit()
    {
        _addrModel = new AddressModel
        {
            Address1 = _order?.DeliveryAddress1 ?? "",
            Address2 = _order?.DeliveryAddress2 ?? "",
            ZipCode  = _order?.DeliveryZipCode  ?? "",
            City     = _order?.DeliveryCity     ?? "",
            Country  = _order?.DeliveryCountry  ?? "",
        };
        _addrSaveError = null;
        _addrDialogOpen = true;
    }

    private void CloseAddressEdit()
    {
        _addrDialogOpen = false;
        _addrSaveError = null;
    }

    private async Task SaveAddress()
    {
        if (_order is null) return;
        _addrSaving = true;
        _addrSaveError = null;
        try
        {
            await Mediator.Send(new UpdateOrderAddressCommand(
                _order.Id,
                _addrModel.Address1,
                _addrModel.Address2,
                _addrModel.ZipCode,
                _addrModel.City,
                _addrModel.Country));
            _addrDialogOpen = false;
            _order = await Mediator.Send(new GetOrderByGuidQuery(OrderGuid));
        }
        catch (Exception ex)
        {
            _addrSaveError = ex.Message;
        }
        _addrSaving = false;
    }

    private static string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{char.ToUpper(parts[0][0])}{char.ToUpper(parts[^1][0])}"
            : $"{char.ToUpper(name[0])}";
    }

    private class AddressModel
    {
        public string Address1 { get; set; } = "";
        public string Address2 { get; set; } = "";
        public string ZipCode  { get; set; } = "";
        public string City     { get; set; } = "";
        public string Country  { get; set; } = "";
    }
}
