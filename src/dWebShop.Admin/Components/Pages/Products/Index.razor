@code {

    private bool _loading = true;
    private string _tab = "all";
    private string _search = "";
    private ProductStatus? _statusFilter = null;

    private int _page = 1;
    private int _totalPages = 1;
    bool _clearItems = false;

    FluentDataGrid<ProductListItemDto> grid = default!;
    string nameFilter = string.Empty;

    PaginationState pagination = new PaginationState { ItemsPerPage = 10 };

    Func<ProductListItemDto, string?> rowClass = x => x.Status == ProductStatus.Draft ? null : null;
    Func<ProductListItemDto, string?> rowStyle = x => x.Status == ProductStatus.Active ? null : null;

    // Filter state
    private List<BrandDto> _brands = [];
    private List<CategoryDto> _categories = [];
    private HashSet<int> _selectedBrandIds = [];
    private HashSet<int> _selectedCategoryIds = [];
    private string _openFilter = "";

    protected override async Task OnInitializedAsync()
    {
        _brands = await Mediator.Send(new GetBrandsQuery());
        _categories = await Mediator.Send(new GetCategoriesQuery());
    }

    private async Task LoadAsync()
    {
        if (grid is not null)
            await grid.RefreshDataAsync();
    }

    protected async ValueTask<GridItemsProviderResult<ProductListItemDto>> RefreshItemsAsync(GridItemsProviderRequest<ProductListItemDto> req)
    {
        _loading = true;
        await InvokeAsync(StateHasChanged);

        string? sort = null;
        var s = req.GetSortByProperties().FirstOrDefault();
        if (req.SortByColumn != null && !string.IsNullOrEmpty(s.PropertyName))
            sort = s.PropertyName + (s.Direction == DataGridSortDirection.Ascending ? ":asc" : ":desc");

        var result = await Mediator.Send(new GetProductsQuery(
            StartIndex: req.StartIndex,
            Count: req.Count ?? 10,
            Search: string.IsNullOrEmpty(_search) ? null : _search,
            Status: _statusFilter,
            Sort: sort,
            BrandIds: _selectedBrandIds.Count > 0 ? [.. _selectedBrandIds] : null,
            CategoryIds: _selectedCategoryIds.Count > 0 ? [.. _selectedCategoryIds] : null,
            IncludePrice: true));

        await pagination.SetTotalItemCountAsync(result.TotalCount);

        _loading = false;
        await InvokeAsync(StateHasChanged);

        return GridItemsProviderResult.From(result.Items, result.TotalCount);
    }

    private void HandleRowClick(FluentDataGridRow<ProductListItemDto> row)
    {
        Console.WriteLine($"[Custom comparer] Row focused: {row.Item?.Name}");
        Navigation.NavigateTo($"/products/{row.Item.Slug}");
    }

    private async Task SetTab(string tab) 
    { 
        _tab = tab; _page = 1;
        if (_tab.Equals("active"))
            _statusFilter = ProductStatus.Active;
        else
            _statusFilter = null;

		await LoadAsync();
    }

    private async Task OnSearch() { _page = 1; await LoadAsync(); }
    private async Task PrevPage() { if (_page > 1) { _page--; await LoadAsync(); } }
    private async Task NextPage() { if (_page < _totalPages) { _page++; await LoadAsync(); } }
    private async Task GoToPage(int pg) { _page = pg; await LoadAsync(); }

    // Filter helpers
    private void ToggleFilter(string name) =>
        _openFilter = _openFilter == name ? "" : name;

    private void CloseFilter() => _openFilter = "";

    private async Task ToggleBrandId(int id, bool add)
    {
        if (add) _selectedBrandIds.Add(id); else _selectedBrandIds.Remove(id);
        await LoadAsync();
    }

    private async Task ToggleCategoryId(int id, bool add)
    {
        if (add) _selectedCategoryIds.Add(id); else _selectedCategoryIds.Remove(id);
        await LoadAsync();
    }

    private async Task ClearBrands()
    {
        _selectedBrandIds.Clear();
        await LoadAsync();
    }

    private async Task ClearCategories()
    {
        _selectedCategoryIds.Clear();
        await LoadAsync();
    }

}

