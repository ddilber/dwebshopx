@page "/inspirations/new"
@page "/inspirations/{Id:int}"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@using MediatR
@using dWebShop.Application.Features.Inspirations.Commands
@using dWebShop.Application.Features.Inspirations.Queries
@using dWebShop.Domain.Entities.Inspirations
@using dWebShop.Admin.Components.Shared
@using System.Text.Json
@inject IMediator Mediator
@inject NavigationManager Navigation

<PageTitle>@(_isNew ? "New Inspiration" : _title) — dWebShop Admin</PageTitle>

<ImagePickerDialog @ref="_coverPicker"   OnAccepted="SetCoverImage"  SubFolder="inspiration_images" SingleSelect="true" />
<ImagePickerDialog @ref="_ogPicker"      OnAccepted="SetOgImage"     SubFolder="inspiration_images" SingleSelect="true" />
<ImagePickerDialog @ref="_galleryPicker" OnAccepted="AddGalleryImages" SubFolder="inspiration_images" />

@if (_loading)
{
    <div style="padding:48px;text-align:center;color:var(--fg-3);">Loading…</div>
}
else
{
    <div class="page-head">
        <div>
            <div class="fui-breadcrumb">
                <a href="/inspirations" style="color:var(--fg-3);text-decoration:none">Inspirations</a>
                <span class="fui-breadcrumb-sep">/</span>
                <span>@(_isNew ? "New article" : _title)</span>
            </div>
            <h1 class="page-title">@(_isNew ? "New article" : _title)</h1>
        </div>
        <div class="page-actions">
            <button class="ds-btn ds-btn-subtle" @onclick="@(() => Navigation.NavigateTo("/inspirations"))">Cancel</button>
            @if (!_isNew)
            {
                <button class="ds-btn" style="color:var(--danger);border-color:var(--danger)" @onclick="DeleteConfirm">Delete</button>
            }
            <button class="ds-btn" style="background:var(--accent-rest);color:white;border-color:var(--accent-rest)" @onclick="Save" disabled="@_saving">
                @(_saving ? "Saving…" : (_isNew ? "Create" : "Save changes"))
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div style="background:var(--danger-bg);color:var(--danger);border:1px solid var(--danger);border-radius:var(--r-md);padding:var(--sp-12) var(--sp-16);margin-bottom:var(--sp-16);font-size:var(--fs-300)">
            @_error
        </div>
    }

    <div class="detail-grid">

        <!-- MAIN COLUMN -->
        <div class="detail-main">

            <!-- Article content -->
            <div class="ds-card">
                <div class="card-head">
                    <div class="card-title">Article content</div>
                </div>
                <div class="form-grid">
                    <div class="field span-2">
                        <label class="field-label">Title *</label>
                        <input class="ds-input" placeholder="e.g. ETICS sistem za energetsku sanaciju fasade" @bind="_title" />
                    </div>
                    <div class="field span-2">
                        <label class="field-label">Slug *</label>
                        <input class="ds-input" placeholder="e.g. etics-sistem-energetska-sanacija" @bind="_slug" />
                        <span class="field-hint">Lowercase letters, numbers and hyphens only.</span>
                    </div>
                    <div class="field span-2">
                        <label class="field-label">Lede (subtitle)</label>
                        <textarea class="ds-textarea" rows="3" placeholder="Short intro shown in card and article header…" @bind="_lede"></textarea>
                    </div>
                    <div class="field span-2">
                        <label class="field-label">Hero label</label>
                        <input class="ds-input" placeholder="e.g. fasada / etics sistem" @bind="_heroLabel" />
                        <span class="field-hint">Small label shown on the article card.</span>
                    </div>
                </div>
            </div>

            <!-- Cover image -->
            <div class="ds-card" style="margin-top:var(--sp-16)">
                <div class="card-head">
                    <div class="card-title">Cover image</div>
                    <button class="ds-btn" @onclick="@(async () => await _coverPicker.Show())">Pick image</button>
                </div>
                @if (!string.IsNullOrWhiteSpace(_coverImage))
                {
                    <div style="position:relative;display:inline-block;">
                        <img src="/@_coverImage" alt="Cover"
                             style="width:100%;max-height:280px;object-fit:cover;border-radius:var(--r-md);display:block;" />
                        <button @onclick="@(() => _coverImage = "")"
                                style="position:absolute;top:8px;right:8px;background:rgba(0,0,0,.55);color:white;border:none;border-radius:var(--r-sm);padding:4px 8px;cursor:pointer;font-size:12px;">
                            Remove
                        </button>
                    </div>
                }
                else
                {
                    <div style="border:2px dashed var(--stroke-1);border-radius:var(--r-lg);padding:40px;text-align:center;color:var(--fg-3)">
                        <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" width="40" height="40" style="display:block;margin:0 auto 12px;opacity:.4">
                            <rect x="4" y="4" width="40" height="40" rx="8"/>
                            <circle cx="16" cy="18" r="4"/>
                            <path d="M4 32l10-10 8 8 6-6 16 16"/>
                        </svg>
                        <p style="margin:0;font-size:var(--fs-300)">No cover image — click <strong>Pick image</strong></p>
                    </div>
                }
            </div>

            <!-- Gallery -->
            <div class="ds-card" style="margin-top:var(--sp-16)">
                <div class="card-head">
                    <div class="card-title">Gallery</div>
                    <button class="ds-btn" @onclick="@(async () => await _galleryPicker.Show())">Add images</button>
                </div>
                @if (_gallery.Count > 0)
                {
                    <div class="media-grid">
                        @for (int i = 0; i < _gallery.Count; i++)
                        {
                            var idx = i;
                            var img = _gallery[idx];
                            <div class="media-cell" style="position:relative;">
                                <img src="/@img.Url" alt="@img.Caption" />
                                <div class="media-overlay">
                                    <button class="media-overlay-btn" title="Move left" disabled="@(idx == 0)"
                                            @onclick="@(() => MoveGalleryImage(idx, -1))" @onclick:stopPropagation="true">
                                        <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14"><path d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z"/></svg>
                                    </button>
                                    <button class="media-overlay-btn media-overlay-btn--danger" title="Remove"
                                            @onclick="@(() => _gallery.RemoveAt(idx))" @onclick:stopPropagation="true">
                                        <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14"><path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zm-1 7a1 1 0 112 0v3a1 1 0 11-2 0V9zm4 0a1 1 0 10-2 0v3a1 1 0 102 0V9z" clip-rule="evenodd"/></svg>
                                    </button>
                                    <button class="media-overlay-btn" title="Move right" disabled="@(idx == _gallery.Count - 1)"
                                            @onclick="@(() => MoveGalleryImage(idx, 1))" @onclick:stopPropagation="true">
                                        <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14"><path d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"/></svg>
                                    </button>
                                </div>
                            </div>
                        }
                        <div class="media-cell media-add" @onclick="@(async () => await _galleryPicker.Show())">
                            <svg viewBox="0 0 20 20" fill="currentColor" width="24" height="24">
                                <path d="M10.75 4.75a.75.75 0 00-1.5 0v4.5h-4.5a.75.75 0 000 1.5h4.5v4.5a.75.75 0 001.5 0v-4.5h4.5a.75.75 0 000-1.5h-4.5v-4.5z"/>
                            </svg>
                        </div>
                    </div>
                }
                else
                {
                    <div style="border:2px dashed var(--stroke-1);border-radius:var(--r-lg);padding:40px;text-align:center;color:var(--fg-3)">
                        <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" width="40" height="40" style="display:block;margin:0 auto 12px;opacity:.4">
                            <rect x="4" y="4" width="40" height="40" rx="8"/>
                            <circle cx="16" cy="18" r="4"/>
                            <path d="M4 32l10-10 8 8 6-6 16 16"/>
                        </svg>
                        <p style="margin:0;font-size:var(--fs-300)">No gallery images — click <strong>Add images</strong></p>
                    </div>
                }
            </div>

            <!-- Body JSON -->
            <div class="ds-card" style="margin-top:var(--sp-16)">
                <div class="card-head">
                    <div class="card-title">Content (JSON sections)</div>
                </div>
                <div style="font-size:var(--fs-200);color:var(--fg-3);margin-bottom:var(--sp-8)">
                    Array of: <code>{"type":"paragraph","text":"…"}</code> · <code>{"type":"heading","text":"…"}</code> · <code>{"type":"bulletlist","items":["…"]}</code> · <code>{"type":"callout","label":"…","text":"…"}</code>
                </div>
                <textarea class="ds-textarea" rows="20" style="font-family:monospace;font-size:12px;" @bind="_content"></textarea>
            </div>

        </div>

        <!-- SIDE COLUMN -->
        <div class="detail-side">

            <!-- Publication -->
            <div class="ds-card" style="padding:var(--sp-16)">
                <div style="font-size:var(--fs-300);font-weight:var(--fw-semibold);margin-bottom:var(--sp-12)">Publication</div>

                <div class="field" style="margin-bottom:var(--sp-12)">
                    <label class="field-label">Brand slug *</label>
                    <input class="ds-input" placeholder="sto, xypex, cortec" @bind="_brandSlug" />
                </div>

                <div class="field" style="margin-bottom:var(--sp-12)">
                    <label class="field-label">Content type</label>
                    <select class="ds-input" @bind="_contentTypeStr">
                        <option value="Story">Story — Priča</option>
                        <option value="Reference">Reference — Referenca</option>
                        <option value="Collection">Collection — Kolekcija</option>
                    </select>
                </div>

                <div class="field" style="margin-bottom:var(--sp-12)">
                    <label class="field-label">Published at</label>
                    <input class="ds-input" placeholder="2024-01-15" @bind="_publishedAt" />
                </div>

                <div class="field" style="margin-bottom:var(--sp-16)">
                    <label class="field-label">Read time (minutes)</label>
                    <input class="ds-input" type="number" min="1" @bind="_readMinStr" />
                </div>

                <div style="display:flex;flex-direction:column;gap:var(--sp-8)">
                    <label style="display:flex;align-items:center;gap:var(--sp-8);cursor:pointer;font-size:var(--fs-300)">
                        <input type="checkbox" @bind="_isFeatured" /> Featured
                    </label>
                    <label style="display:flex;align-items:center;gap:var(--sp-8);cursor:pointer;font-size:var(--fs-300)">
                        <input type="checkbox" @bind="_published" /> Published
                    </label>
                </div>
            </div>

            <!-- Metadata -->
            <div class="ds-card" style="padding:var(--sp-16);margin-top:var(--sp-16)">
                <div style="font-size:var(--fs-300);font-weight:var(--fw-semibold);margin-bottom:var(--sp-12)">Metadata</div>

                <div class="field" style="margin-bottom:var(--sp-12)">
                    <label class="field-label">Authors</label>
                    <input class="ds-input" placeholder="Tehnicki tim ASGifiks|STO" @bind="_authors" />
                    <span class="field-hint">Pipe-separated</span>
                </div>

                <div class="field" style="margin-bottom:var(--sp-12)">
                    <label class="field-label">Tags</label>
                    <input class="ds-input" placeholder="Energetska efikasnost|ETICS" @bind="_tags" />
                    <span class="field-hint">Pipe-separated</span>
                </div>

                <div class="field">
                    <label class="field-label">Linked product slugs</label>
                    <input class="ds-input" placeholder="sto-armat-classic|sto-eps-100" @bind="_linkedProductSlugs" />
                    <span class="field-hint">Pipe-separated</span>
                </div>
            </div>

            <!-- SEO -->
            <div class="ds-card" style="padding:var(--sp-16);margin-top:var(--sp-16)">
                <div style="font-size:var(--fs-300);font-weight:var(--fw-semibold);margin-bottom:var(--sp-12)">SEO</div>

                <div class="field" style="margin-bottom:var(--sp-12)">
                    <label class="field-label">Meta title</label>
                    <input class="ds-input" placeholder="Defaults to article title if empty" @bind="_metaTitle" />
                    <span class="field-hint">@(_metaTitle.Length)/60 chars</span>
                </div>

                <div class="field" style="margin-bottom:var(--sp-12)">
                    <label class="field-label">Meta description</label>
                    <textarea class="ds-textarea" rows="3" placeholder="Defaults to lede if empty" @bind="_metaDescription"></textarea>
                    <span class="field-hint">@(_metaDescription.Length)/160 chars</span>
                </div>

                <div class="field">
                    <label class="field-label">OG image</label>
                    @if (!string.IsNullOrWhiteSpace(_ogImage))
                    {
                        <div style="display:flex;align-items:center;gap:var(--sp-8);margin-bottom:var(--sp-8)">
                            <img src="/@_ogImage" alt="OG" style="width:64px;height:40px;object-fit:cover;border-radius:var(--r-sm);border:1px solid var(--stroke-1);" />
                            <button class="ds-btn ds-btn-subtle" style="font-size:var(--fs-200)" @onclick="@(() => _ogImage = "")">Remove</button>
                        </div>
                    }
                    <button class="ds-btn ds-btn-subtle" @onclick="@(async () => await _ogPicker.Show())">
                        @(string.IsNullOrWhiteSpace(_ogImage) ? "Pick OG image" : "Change OG image")
                    </button>
                    <span class="field-hint">Recommended 1200×630 px. Defaults to cover image if empty.</span>
                </div>
            </div>

        </div>
    </div>
}

@code {
    [Parameter] public int? Id { get; set; }

    private ImagePickerDialog _coverPicker = default!;
    private ImagePickerDialog _ogPicker = default!;
    private ImagePickerDialog _galleryPicker = default!;

    private bool _isNew;
    private bool _loading = true;
    private bool _saving;
    private string _error = "";

    private string _title = "";
    private string _slug = "";
    private string _lede = "";
    private string _heroLabel = "";
    private string _publishedAt = DateTime.Today.ToString("yyyy-MM-dd");
    private string _readMinStr = "5";
    private string _authors = "";
    private string _tags = "";
    private string _content = "[]";
    private string _linkedProductSlugs = "";
    private string _contentTypeStr = "Story";
    private bool _isFeatured;
    private bool _published;
    private string _brandSlug = "";
    private string _coverImage = "";
    private string _metaTitle = "";
    private string _metaDescription = "";
    private string _ogImage = "";
    private List<GalleryItem> _gallery = [];

    private record GalleryItem(string Url, string Caption = "");

    private InspirationContentType ContentType =>
        Enum.TryParse<InspirationContentType>(_contentTypeStr, out var t) ? t : InspirationContentType.Story;

    private int ReadMin => int.TryParse(_readMinStr, out var n) ? n : 5;

    private string GalleryJson => _gallery.Count == 0
        ? "[]"
        : JsonSerializer.Serialize(_gallery.Select(x => new { url = x.Url, caption = x.Caption }));

    protected override async Task OnInitializedAsync()
    {
        _isNew = Id is null;
        if (!_isNew)
        {
            var dto = await Mediator.Send(new GetInspirationByIdQuery(Id!.Value));
            if (dto is not null)
            {
                _title = dto.Title;
                _slug = dto.Slug;
                _lede = dto.Lede;
                _heroLabel = dto.HeroLabel;
                _publishedAt = dto.PublishedAt;
                _readMinStr = dto.ReadMin.ToString();
                _authors = string.Join("|", dto.Authors);
                _tags = string.Join("|", dto.Tags);
                _linkedProductSlugs = string.Join("|", dto.LinkedProductSlugs);
                _contentTypeStr = dto.ContentType.ToString();
                _isFeatured = dto.IsFeatured;
                _published = dto.Published;
                _brandSlug = dto.BrandSlug;
                _coverImage = dto.CoverImage;
                _metaTitle = dto.MetaTitle;
                _metaDescription = dto.MetaDescription;
                _ogImage = dto.OgImage;
                _gallery = dto.Gallery.Select(x => new GalleryItem(x.Url, x.Caption)).ToList();

                _content = dto.Sections.Length > 0
                    ? JsonSerializer.Serialize(dto.Sections,
                        new JsonSerializerOptions { WriteIndented = true })
                    : "[]";
            }
        }
        _loading = false;
    }

    private void SetCoverImage(List<string> files)
    {
        if (files.Count > 0) _coverImage = files[0];
    }

    private void SetOgImage(List<string> files)
    {
        if (files.Count > 0) _ogImage = files[0];
    }

    private void AddGalleryImages(List<string> files)
    {
        var existing = _gallery.Select(x => x.Url).ToHashSet();
        foreach (var f in files)
            if (!existing.Contains(f))
                _gallery.Add(new GalleryItem(f));
    }

    private void MoveGalleryImage(int idx, int direction)
    {
        var newIdx = idx + direction;
        if (newIdx < 0 || newIdx >= _gallery.Count) return;
        (_gallery[idx], _gallery[newIdx]) = (_gallery[newIdx], _gallery[idx]);
    }

    private async Task Save()
    {
        _saving = true;
        _error = "";
        try
        {
            if (_isNew)
            {
                var id = await Mediator.Send(new CreateInspirationCommand(
                    _title, _slug, _lede, _heroLabel, _publishedAt, ReadMin,
                    _authors, _tags, _content, _linkedProductSlugs,
                    ContentType, _isFeatured, _published, _brandSlug,
                    _coverImage, GalleryJson, _metaTitle, _metaDescription, _ogImage));
                Navigation.NavigateTo($"/inspirations/{id}");
            }
            else
            {
                await Mediator.Send(new UpdateInspirationCommand(
                    Id!.Value, _title, _slug, _lede, _heroLabel, _publishedAt, ReadMin,
                    _authors, _tags, _content, _linkedProductSlugs,
                    ContentType, _isFeatured, _published, _brandSlug,
                    _coverImage, GalleryJson, _metaTitle, _metaDescription, _ogImage));
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        _saving = false;
    }

    private async Task DeleteConfirm()
    {
        try
        {
            await Mediator.Send(new DeleteInspirationCommand(Id!.Value));
            Navigation.NavigateTo("/inspirations");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }
}
