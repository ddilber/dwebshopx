@page "/login"
@layout LoginLayout
@using Microsoft.AspNetCore.Antiforgery
@inject IAntiforgery Antiforgery
@inject IHttpContextAccessor HttpContextAccessor

<PageTitle>Login — dWebShop Admin</PageTitle>

<div style="display: flex; align-items: center; justify-content: center; min-height: 100vh; background: var(--colorNeutralBackground2);">
    <FluentCard Style="width: 380px; padding: 32px;">
        <form method="post" action="/account/login">
            <input type="hidden" name="__RequestVerificationToken"
                   value="@Antiforgery.GetAndStoreTokens(HttpContextAccessor.HttpContext!).RequestToken" />
            <input type="hidden" name="returnUrl" value="@ReturnUrl" />

            <FluentStack Orientation="Orientation.Vertical" Style="gap: 20px;">
                <FluentLabel Style="font-size: 22px; font-weight: 600; text-align: center; display: block;">
                    dWebShop Admin
                </FluentLabel>

                @if (!string.IsNullOrEmpty(Error))
                {
                    <FluentMessageBar Intent="MessageBarIntent.Error">@Error</FluentMessageBar>
                }

                <FluentTextInput Name="email" Label="Email" TextInputType="TextInputType.Email"
                                 Placeholder="admin@dwebshop.local" Style="width: 100%" />

                <FluentTextInput Name="password" Label="Password" TextInputType="TextInputType.Password"
                                 Style="width: 100%" />

                <FluentButton Type="ButtonType.Submit" Appearance="ButtonAppearance.Primary" Style="width: 100%;">
                    Sign In
                </FluentButton>
            </FluentStack>
        </form>
    </FluentCard>
</div>

@code {
    [SupplyParameterFromQuery] private string? ReturnUrl { get; set; }
    [SupplyParameterFromQuery] private string? Error { get; set; }
}
