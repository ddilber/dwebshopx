@page "/register"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Identity
@using dWebShop.Domain.Entities.Users
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation

<PageTitle>Register Admin — dWebShop Admin</PageTitle>

<FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="margin-bottom: 16px;">
    <FluentLabel Style="font-size: 22px; font-weight: 600;">Register Admin User</FluentLabel>
</FluentStack>
<FluentDivider Style="margin-bottom: 24px;" />

<div style="max-width: 480px;">
    <FluentStack Orientation="Orientation.Vertical" Style="gap: 16px;">

        @if (!string.IsNullOrEmpty(_error))
        {
            <FluentMessageBar Intent="MessageBarIntent.Error">@_error</FluentMessageBar>
        }

        @if (!string.IsNullOrEmpty(_success))
        {
            <FluentMessageBar Intent="MessageBarIntent.Success">@_success</FluentMessageBar>
        }

        <FluentTextInput @bind-Value="_email" Label="Email" TextInputType="TextInputType.Email"
                         Placeholder="user@example.com" Style="width: 100%" />

        <FluentTextInput @bind-Value="_password" Label="Password" TextInputType="TextInputType.Password"
                         Style="width: 100%" />

        <FluentTextInput @bind-Value="_confirmPassword" Label="Confirm Password" TextInputType="TextInputType.Password"
                         Style="width: 100%" />

        <FluentStack Orientation="Orientation.Horizontal" Style="gap: 8px; margin-top: 8px;">
            <FluentButton Appearance="ButtonAppearance.Primary" OnClick="RegisterAsync">
                @if (_loading) { <FluentProgressRing Style="width:16px;height:16px;" /> } else { <span>Create Account</span> }
            </FluentButton>
            <FluentButton OnClick="@(() => Navigation.NavigateTo("/users"))">Cancel</FluentButton>
        </FluentStack>

    </FluentStack>
</div>

@code {
    private string _email = "";
    private string _password = "";
    private string _confirmPassword = "";
    private string _error = "";
    private string _success = "";
    private bool _loading;

    private async Task RegisterAsync()
    {
        _error = "";
        _success = "";

        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_password))
        {
            _error = "Email and password are required.";
            return;
        }

        if (_password != _confirmPassword)
        {
            _error = "Passwords do not match.";
            return;
        }

        _loading = true;

        var user = new ApplicationUser
        {
            UserName = _email,
            Email = _email,
            IsApproved = true
        };

        var result = await UserManager.CreateAsync(user, _password);

        if (result.Succeeded)
        {
            await UserManager.AddToRoleAsync(user, "Admin");
            _success = $"Account created for {_email}.";
            _email = "";
            _password = "";
            _confirmPassword = "";
        }
        else
        {
            _error = string.Join(" ", result.Errors.Select(e => e.Description));
        }

        _loading = false;
    }
}
