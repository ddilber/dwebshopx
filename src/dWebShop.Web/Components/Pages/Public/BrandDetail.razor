@page "/brands/{Slug}"
@layout PublicLayout
@rendermode InteractiveServer
@using dWebShop.Application.Features.Brands.Queries
@inject IMediator Mediator
@inject NavigationManager Nav

<PageTitle>@(_brand?.Name ?? "Brand") — dWebShop</PageTitle>
<HeadContent>
    <meta name="description" content="@(_brand?.Description ?? string.Empty)" />
</HeadContent>

<LoadingSpinner Visible="_loading" />

@if (!_loading)
{
    @if (_brand is null)
    {
        <MudAlert Severity="Severity.Warning">Brand not found.</MudAlert>
        <MudButton Href="/brands" StartIcon="@Icons.Material.Filled.ArrowBack" Class="mt-4">Back to Brands</MudButton>
    }
    else
    {
        <!-- Breadcrumbs -->
        <MudBreadcrumbs Items="_breadcrumbs" Class="px-0 mb-4" />

        <!-- Brand header -->
        <MudGrid Spacing="4" Class="mb-6">
            <MudItem xs="12" sm="3" Class="d-flex align-center justify-center">
                @if (!string.IsNullOrWhiteSpace(_brand.LogoImage))
                {
                    <img src="/product_images/brands/@_brand.LogoImage"
                         alt="@_brand.Name logo"
                         style="max-width:200px; max-height:120px; object-fit:contain;" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.Store" Style="font-size:80px;" Color="Color.Primary" />
                }
            </MudItem>
            <MudItem xs="12" sm="9">
                <MudText Typo="Typo.h4" Style="font-weight:700;">@_brand.Name</MudText>
                @if (!string.IsNullOrWhiteSpace(_brand.Description))
                {
                    <MudText Typo="Typo.body1" Class="mt-2 mud-text-secondary">@_brand.Description</MudText>
                }
            </MudItem>
        </MudGrid>

        <MudDivider Class="mb-6" />

        <!-- Categories -->
        @if (_brand.Categories.Count == 0)
        {
            <MudAlert Severity="Severity.Info">No categories available for this brand yet.</MudAlert>
        }
        else
        {
            <MudText Typo="Typo.h5" Class="mb-4">Product Categories</MudText>
            <MudGrid Spacing="3">
                @foreach (var cat in _brand.Categories.Where(c => c.ParentCategoryId == null))
                {
                    var subCats = _brand.Categories.Where(c => c.ParentCategoryId == cat.Id).ToList();
                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Outlined="true">
                            <MudCardContent>
                                <MudLink Href="@($"/brands/{_brand.Slug}/categories/{cat.Slug}")"
                                         Underline="Underline.None">
                                    <MudText Typo="Typo.h6" Style="font-weight:600;">@cat.Name</MudText>
                                </MudLink>
                                @if (!string.IsNullOrWhiteSpace(cat.Description))
                                {
                                    <MudText Typo="Typo.body2" Class="mud-text-secondary mt-1">@cat.Description</MudText>
                                }
                                @if (subCats.Any())
                                {
                                    <MudList T="CategorySummaryDto" Dense="true" Class="mt-2 pa-0">
                                        @foreach (var sub in subCats)
                                        {
                                            <MudListItem T="CategorySummaryDto" Value="sub"
                                                         Icon="@Icons.Material.Filled.ChevronRight"
                                                         Dense="true">
                                                <MudLink Href="@($"/brands/{_brand.Slug}/categories/{sub.Slug}")"
                                                         Underline="Underline.Hover">
                                                    @sub.Name
                                                </MudLink>
                                            </MudListItem>
                                        }
                                    </MudList>
                                }
                            </MudCardContent>
                            <MudCardActions>
                                <MudButton Variant="Variant.Text" Color="Color.Primary"
                                           EndIcon="@Icons.Material.Filled.ArrowForward"
                                           Href="@($"/brands/{_brand.Slug}/categories/{cat.Slug}")">
                                    Browse
                                </MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>

            <!-- Categories with no parent that are children (show flat if all are leafs) -->
            @if (!_brand.Categories.Any(c => c.ParentCategoryId == null) && _brand.Categories.Any())
            {
                <MudGrid Spacing="3">
                    @foreach (var cat in _brand.Categories)
                    {
                        <MudItem xs="12" sm="6" md="4">
                            <MudCard Outlined="true">
                                <MudCardContent>
                                    <MudLink Href="@($"/brands/{_brand.Slug}/categories/{cat.Slug}")"
                                             Underline="Underline.None">
                                        <MudText Typo="Typo.h6" Style="font-weight:600;">@cat.Name</MudText>
                                    </MudLink>
                                    @if (!string.IsNullOrWhiteSpace(cat.Description))
                                    {
                                        <MudText Typo="Typo.body2" Class="mud-text-secondary mt-1">@cat.Description</MudText>
                                    }
                                </MudCardContent>
                                <MudCardActions>
                                    <MudButton Variant="Variant.Text" Color="Color.Primary"
                                               EndIcon="@Icons.Material.Filled.ArrowForward"
                                               Href="@($"/brands/{_brand.Slug}/categories/{cat.Slug}")">
                                        Browse
                                    </MudButton>
                                </MudCardActions>
                            </MudCard>
                        </MudItem>
                    }
                </MudGrid>
            }
        }
    }
}

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;

    private BrandWithCategoriesDto? _brand;
    private bool _loading = true;
    private List<BreadcrumbItem> _breadcrumbs = [];

    protected override async Task OnInitializedAsync()
    {
        _brand = await Mediator.Send(new GetBrandBySlugQuery(Slug));
        _breadcrumbs =
        [
            new BreadcrumbItem("Home", href: "/"),
            new BreadcrumbItem("Brands", href: "/brands"),
            new BreadcrumbItem(_brand?.Name ?? Slug, href: null, disabled: true)
        ];
        _loading = false;
    }
}
