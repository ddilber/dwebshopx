@page "/about"
@layout MainLayout

<PageTitle>About Us — dWebShop</PageTitle>
<HeadContent>
    <meta name="description" content="Learn about ASGifiks d.o.o., exclusive distributor of STO, XYPEX and CORTEC brands in Bosnia and Herzegovina." />
</HeadContent>

<!-- Hero -->
<MudPaper Elevation="0" Class="pa-8 mb-6 rounded-lg"
          Style="background: linear-gradient(135deg, #1a3c6e 0%, #2e6db4 100%); color: white;">
    <MudText Typo="Typo.h3" Style="font-weight:800; color:white;">About ASGifiks</MudText>
    <MudText Typo="Typo.h6" Style="color: rgba(255,255,255,0.85); font-weight:400;" Class="mt-2">
        Professional construction solutions since 1998
    </MudText>
</MudPaper>

<MudGrid Spacing="4">
    <!-- Story -->
    <MudItem xs="12" md="7">
        <MudText Typo="Typo.h5" Class="mb-3" Style="font-weight:700;">Our Story</MudText>
        <MudText Typo="Typo.body1" Class="mb-3">
            ASGifiks d.o.o. is a company headquartered in Tomislavgrad, Bosnia and Herzegovina,
            founded in 1998 with the vision of providing premium construction solutions to the
            regional market.
        </MudText>
        <MudText Typo="Typo.body1" Class="mb-3">
            As the exclusive distributor for the global brands STO, XYPEX and CORTEC,
            we offer comprehensive solutions for façade systems, thermal insulation,
            concrete waterproofing and corrosion protection. Our expert team ensures
            technical support and consulting at every stage of your project.
        </MudText>
        <MudText Typo="Typo.body1">
            With over 25 years of experience and hundreds of completed projects across
            Bosnia and Herzegovina, we are the trusted partner for engineers, contractors,
            and project managers seeking quality, reliability and expertise.
        </MudText>
    </MudItem>

    <!-- Stats -->
    <MudItem xs="12" md="5">
        <MudGrid Spacing="3">
            <MudItem xs="6">
                <MudPaper Outlined="true" Class="pa-4 text-center rounded-lg">
                    <MudText Typo="Typo.h3" Color="Color.Primary" Style="font-weight:800;">25+</MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">Years of Experience</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6">
                <MudPaper Outlined="true" Class="pa-4 text-center rounded-lg">
                    <MudText Typo="Typo.h3" Color="Color.Primary" Style="font-weight:800;">3</MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">World Brands</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6">
                <MudPaper Outlined="true" Class="pa-4 text-center rounded-lg">
                    <MudText Typo="Typo.h3" Color="Color.Primary" Style="font-weight:800;">500+</MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">Satisfied Clients</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6">
                <MudPaper Outlined="true" Class="pa-4 text-center rounded-lg">
                    <MudText Typo="Typo.h3" Color="Color.Primary" Style="font-weight:800;">1000+</MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">Completed Projects</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudItem>
</MudGrid>

<MudDivider Class="my-8" />

<!-- What we offer -->
<MudText Typo="Typo.h5" Class="mb-4" Style="font-weight:700;">What We Offer</MudText>
<MudGrid Spacing="3">
    <MudItem xs="12" sm="6" md="3">
        <MudCard Outlined="true" Class="pa-2 text-center">
            <MudCardContent>
                <MudIcon Icon="@Icons.Material.Filled.Home" Color="Color.Primary" Style="font-size:48px;" />
                <MudText Typo="Typo.subtitle1" Class="mt-2" Style="font-weight:600;">Façade Systems</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary">
                    Complete ETICS systems and decorative plasters for energy-efficient facades.
                </MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudCard Outlined="true" Class="pa-2 text-center">
            <MudCardContent>
                <MudIcon Icon="@Icons.Material.Filled.WaterDrop" Color="Color.Primary" Style="font-size:48px;" />
                <MudText Typo="Typo.subtitle1" Class="mt-2" Style="font-weight:600;">Waterproofing</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary">
                    Crystalline concrete waterproofing for foundations, tunnels and water structures.
                </MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudCard Outlined="true" Class="pa-2 text-center">
            <MudCardContent>
                <MudIcon Icon="@Icons.Material.Filled.Shield" Color="Color.Primary" Style="font-size:48px;" />
                <MudText Typo="Typo.subtitle1" Class="mt-2" Style="font-weight:600;">Corrosion Protection</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary">
                    Advanced VpCI technology solutions for industrial and construction corrosion protection.
                </MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudCard Outlined="true" Class="pa-2 text-center">
            <MudCardContent>
                <MudIcon Icon="@Icons.Material.Filled.Description" Color="Color.Primary" Style="font-size:48px;" />
                <MudText Typo="Typo.subtitle1" Class="mt-2" Style="font-weight:600;">Technical Consulting</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary">
                    Individual project approach with support from certified specialists and applicators.
                </MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

<MudDivider Class="my-8" />

<!-- Contact CTA -->
<MudPaper Outlined="true" Class="pa-6 text-center rounded-lg">
    <MudText Typo="Typo.h5" Class="mb-2" Style="font-weight:700;">Ready to start a project?</MudText>
    <MudText Typo="Typo.body1" Class="mud-text-secondary mb-4">
        Contact us today and find out how our products can improve your project.
    </MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/contact"
               StartIcon="@Icons.Material.Filled.Email" Size="Size.Large">
        Contact Us
    </MudButton>
    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="/brands"
               StartIcon="@Icons.Material.Filled.Store" Size="Size.Large" Class="ml-3">
        Browse Brands
    </MudButton>
</MudPaper>
