@page "/portal/profile"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin,Client")]
@layout PortalLayout
@rendermode InteractiveServer
@using dWebShop.Application.Features.Profile.Commands
@using dWebShop.Application.Features.Profile.Queries
@using dWebShop.Domain.Entities.Users
@using Microsoft.AspNetCore.Identity
@inject IMediator Mediator
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Profile — Portal</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">My Profile</MudText>

<LoadingSpinner Visible="_loading" />

@if (!_loading)
{
    @if (_profile is null)
    {
        <MudAlert Severity="Severity.Warning">Your account is not linked to a partner profile. Please contact support.</MudAlert>
    }
    else
    {
        <MudGrid>
            <!-- Contact Details -->
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4 mb-4" Elevation="1">
                    <MudText Typo="Typo.h6" Class="mb-3">Contact Details</MudText>

                    @if (!string.IsNullOrEmpty(_contactSuccess))
                    {
                        <MudAlert Severity="Severity.Success" Class="mb-3" Dense="true">@_contactSuccess</MudAlert>
                    }
                    @if (!string.IsNullOrEmpty(_contactError))
                    {
                        <MudAlert Severity="Severity.Error" Class="mb-3" Dense="true">@_contactError</MudAlert>
                    }

                    <MudTextField @bind-Value="_contactModel.FirstName"
                                  Label="First Name"
                                  Variant="Variant.Outlined"
                                  Class="mb-3" />
                    <MudTextField @bind-Value="_contactModel.LastName"
                                  Label="Last Name"
                                  Variant="Variant.Outlined"
                                  Class="mb-3" />
                    <MudTextField @bind-Value="_contactModel.Email"
                                  Label="Email"
                                  InputType="InputType.Email"
                                  Variant="Variant.Outlined"
                                  Class="mb-3" />
                    <MudTextField @bind-Value="_contactModel.Phone"
                                  Label="Phone"
                                  Variant="Variant.Outlined"
                                  Class="mb-3" />
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               OnClick="SaveContactDetails"
                               Disabled="_contactBusy">
                        @(_contactBusy ? "Saving..." : "Save Changes")
                    </MudButton>
                </MudPaper>
            </MudItem>

            <!-- Change Password -->
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4 mb-4" Elevation="1">
                    <MudText Typo="Typo.h6" Class="mb-3">Change Password</MudText>

                    @if (!string.IsNullOrEmpty(_passwordSuccess))
                    {
                        <MudAlert Severity="Severity.Success" Class="mb-3" Dense="true">@_passwordSuccess</MudAlert>
                    }
                    @if (!string.IsNullOrEmpty(_passwordError))
                    {
                        <MudAlert Severity="Severity.Error" Class="mb-3" Dense="true">@_passwordError</MudAlert>
                    }

                    <MudTextField @bind-Value="_currentPassword"
                                  Label="Current Password"
                                  InputType="InputType.Password"
                                  Variant="Variant.Outlined"
                                  Class="mb-3" />
                    <MudTextField @bind-Value="_newPassword"
                                  Label="New Password"
                                  InputType="InputType.Password"
                                  Variant="Variant.Outlined"
                                  Class="mb-3" />
                    <MudTextField @bind-Value="_confirmPassword"
                                  Label="Confirm New Password"
                                  InputType="InputType.Password"
                                  Variant="Variant.Outlined"
                                  Class="mb-3" />
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               OnClick="ChangePassword"
                               Disabled="_passwordBusy">
                        @(_passwordBusy ? "Changing..." : "Change Password")
                    </MudButton>
                </MudPaper>
            </MudItem>

            <!-- Delivery Addresses -->
            <MudItem xs="12">
                <MudPaper Class="pa-4" Elevation="1">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
                        <MudText Typo="Typo.h6">Delivery Addresses</MudText>
                        <MudSpacer />
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="OpenAddAddress">
                            Add Address
                        </MudButton>
                    </MudStack>

                    @if (!string.IsNullOrEmpty(_addrSuccess))
                    {
                        <MudAlert Severity="Severity.Success" Class="mb-3" Dense="true">@_addrSuccess</MudAlert>
                    }
                    @if (!string.IsNullOrEmpty(_addrError))
                    {
                        <MudAlert Severity="Severity.Error" Class="mb-3" Dense="true">@_addrError</MudAlert>
                    }

                    @if (_profile.DeliveryAddresses.Count == 0)
                    {
                        <MudText Class="mud-text-secondary">No delivery addresses on file.</MudText>
                    }
                    else
                    {
                        <MudTable Items="_profile.DeliveryAddresses" Dense="true" Outlined="true">
                            <HeaderContent>
                                <MudTh>Label</MudTh>
                                <MudTh>Street</MudTh>
                                <MudTh>City</MudTh>
                                <MudTh>Postal Code</MudTh>
                                <MudTh>Country</MudTh>
                                <MudTh></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd><MudChip T="string" Size="Size.Small" Color="Color.Default">@context.Label</MudChip></MudTd>
                                <MudTd>@context.Address1</MudTd>
                                <MudTd>@context.City</MudTd>
                                <MudTd>@context.ZipCode</MudTd>
                                <MudTd>@context.Country</MudTd>
                                <MudTd>
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                   Size="Size.Small"
                                                   Color="Color.Primary"
                                                   OnClick="@(() => OpenEditAddress(context))" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Size="Size.Small"
                                                   Color="Color.Error"
                                                   OnClick="@(() => DeleteAddress(context.Id))" />
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>

        <!-- Add/Edit Address Dialog -->
        <MudDialog @bind-Visible="_addrDialogOpen">
            <TitleContent>
                <MudText Typo="Typo.h6">@(_editingAddressId.HasValue ? "Edit Address" : "Add Address")</MudText>
            </TitleContent>
            <DialogContent>
                <MudTextField @bind-Value="_addrModel.Label"
                              Label="Label (e.g. Home, Office, Warehouse)"
                              Variant="Variant.Outlined"
                              Class="mb-3" />
                <MudTextField @bind-Value="_addrModel.Address1"
                              Label="Street"
                              Variant="Variant.Outlined"
                              Class="mb-3" />
                <MudTextField @bind-Value="_addrModel.ZipCode"
                              Label="Postal Code"
                              Variant="Variant.Outlined"
                              Class="mb-3" />
                <MudTextField @bind-Value="_addrModel.City"
                              Label="City"
                              Variant="Variant.Outlined"
                              Class="mb-3" />
                <MudTextField @bind-Value="_addrModel.Country"
                              Label="Country"
                              Variant="Variant.Outlined"
                              Class="mb-3" />
            </DialogContent>
            <DialogActions>
                <MudButton OnClick="@(() => _addrDialogOpen = false)">Cancel</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAddress" Disabled="_addrBusy">
                    @(_addrBusy ? "Saving..." : "Save")
                </MudButton>
            </DialogActions>
        </MudDialog>
    }
}

@code {
    private ProfileDto? _profile;
    private bool _loading = true;
    private ApplicationUser? _appUser;

    // Contact
    private ContactModel _contactModel = new();
    private bool _contactBusy;
    private string _contactSuccess = string.Empty;
    private string _contactError = string.Empty;

    // Password
    private string _currentPassword = string.Empty;
    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;
    private bool _passwordBusy;
    private string _passwordSuccess = string.Empty;
    private string _passwordError = string.Empty;

    // Addresses
    private bool _addrDialogOpen;
    private int? _editingAddressId;
    private AddressFormModel _addrModel = new();
    private bool _addrBusy;
    private string _addrSuccess = string.Empty;
    private string _addrError = string.Empty;

    private class ContactModel
    {
        public string FirstName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Phone { get; set; } = string.Empty;
    }

    private class AddressFormModel
    {
        public string Label { get; set; } = string.Empty;
        public string Address1 { get; set; } = string.Empty;
        public string ZipCode { get; set; } = string.Empty;
        public string City { get; set; } = string.Empty;
        public string Country { get; set; } = string.Empty;
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _appUser = await UserManager.GetUserAsync(authState.User);

        if (_appUser?.PartnerId is int partnerId)
        {
            _profile = await Mediator.Send(new GetProfileQuery(partnerId));
            if (_profile is not null)
            {
                _contactModel = new ContactModel
                {
                    FirstName = _profile.FirstName,
                    LastName = _profile.LastName,
                    Email = _profile.Email,
                    Phone = _profile.Phone,
                };
            }
        }

        _loading = false;
    }

    private async Task SaveContactDetails()
    {
        _contactSuccess = string.Empty;
        _contactError = string.Empty;
        _contactBusy = true;

        try
        {
            await Mediator.Send(new UpdateContactDetailsCommand(
                _profile!.PartnerId,
                _contactModel.FirstName,
                _contactModel.LastName,
                _contactModel.Email,
                _contactModel.Phone));

            _profile = _profile with
            {
                FirstName = _contactModel.FirstName,
                LastName = _contactModel.LastName,
                Email = _contactModel.Email,
                Phone = _contactModel.Phone,
            };
            _contactSuccess = "Contact details updated successfully.";
        }
        catch (Exception ex)
        {
            _contactError = ex.Message;
        }
        finally
        {
            _contactBusy = false;
        }
    }

    private async Task ChangePassword()
    {
        _passwordSuccess = string.Empty;
        _passwordError = string.Empty;

        if (_newPassword != _confirmPassword)
        {
            _passwordError = "New password and confirmation do not match.";
            return;
        }
        if (string.IsNullOrWhiteSpace(_newPassword) || _newPassword.Length < 6)
        {
            _passwordError = "New password must be at least 6 characters.";
            return;
        }

        _passwordBusy = true;

        try
        {
            var result = await UserManager.ChangePasswordAsync(_appUser!, _currentPassword, _newPassword);
            if (result.Succeeded)
            {
                _passwordSuccess = "Password changed successfully.";
                _currentPassword = string.Empty;
                _newPassword = string.Empty;
                _confirmPassword = string.Empty;
            }
            else
            {
                _passwordError = string.Join(" ", result.Errors.Select(e => e.Description));
            }
        }
        catch (Exception ex)
        {
            _passwordError = ex.Message;
        }
        finally
        {
            _passwordBusy = false;
        }
    }

    private void OpenAddAddress()
    {
        _editingAddressId = null;
        _addrModel = new AddressFormModel();
        _addrDialogOpen = true;
    }

    private void OpenEditAddress(DeliveryAddressDto address)
    {
        _editingAddressId = address.Id;
        _addrModel = new AddressFormModel
        {
            Label = address.Label,
            Address1 = address.Address1,
            ZipCode = address.ZipCode,
            City = address.City,
            Country = address.Country,
        };
        _addrDialogOpen = true;
    }

    private async Task SaveAddress()
    {
        _addrSuccess = string.Empty;
        _addrError = string.Empty;
        _addrBusy = true;

        try
        {
            if (_editingAddressId.HasValue)
            {
                await Mediator.Send(new UpdateDeliveryAddressCommand(
                    _editingAddressId.Value,
                    _addrModel.Label,
                    _addrModel.Address1,
                    _addrModel.ZipCode,
                    _addrModel.City,
                    _addrModel.Country));

                var idx = _profile!.DeliveryAddresses.FindIndex(a => a.Id == _editingAddressId.Value);
                if (idx >= 0)
                {
                    _profile.DeliveryAddresses[idx] = new DeliveryAddressDto(
                        _editingAddressId.Value,
                        _addrModel.Label,
                        _addrModel.Address1,
                        _addrModel.ZipCode,
                        _addrModel.City,
                        _addrModel.Country);
                }
                _addrSuccess = "Address updated.";
            }
            else
            {
                var newId = await Mediator.Send(new AddDeliveryAddressCommand(
                    _profile!.PartnerId,
                    _addrModel.Label,
                    _addrModel.Address1,
                    _addrModel.ZipCode,
                    _addrModel.City,
                    _addrModel.Country));

                _profile.DeliveryAddresses.Add(new DeliveryAddressDto(
                    newId,
                    _addrModel.Label,
                    _addrModel.Address1,
                    _addrModel.ZipCode,
                    _addrModel.City,
                    _addrModel.Country));
                _addrSuccess = "Address added.";
            }

            _addrDialogOpen = false;
        }
        catch (Exception ex)
        {
            _addrError = ex.Message;
        }
        finally
        {
            _addrBusy = false;
        }
    }

    private async Task DeleteAddress(int addressId)
    {
        _addrSuccess = string.Empty;
        _addrError = string.Empty;

        try
        {
            await Mediator.Send(new DeleteDeliveryAddressCommand(addressId, _profile!.PartnerId));
            _profile.DeliveryAddresses.RemoveAll(a => a.Id == addressId);
            _addrSuccess = "Address deleted.";
        }
        catch (Exception ex)
        {
            _addrError = ex.Message;
        }
    }
}
