@page "/portal/products"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin,Client")]
@layout PortalLayout
@rendermode InteractiveServer
@using dWebShop.Application.Features.Brands.Queries
@using dWebShop.Application.Features.Categories.Queries
@using dWebShop.Application.Features.Products.Queries
@using dWebShop.Domain.Entities.Users
@using Microsoft.AspNetCore.Identity
@inject IMediator Mediator
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<PageTitle>Products — Portal</PageTitle>

@if (_checkingApproval)
{
    <LoadingSpinner Visible="true" />
}
else if (!_isApproved)
{
    <MudAlert Severity="Severity.Warning" Class="mb-4">
        Your account is pending admin approval. You cannot browse products yet.
        <MudLink Href="/pending-approval" Class="ml-2">Learn more</MudLink>
    </MudAlert>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
        <MudText Typo="Typo.h5">Products</MudText>
        <MudSpacer />
        <MudText Typo="Typo.caption" Class="mud-text-secondary">
            @if (_pagedResult is not null)
            {
                @($"{_pagedResult.TotalCount} product(s) found")
            }
        </MudText>
    </MudStack>

    <MudGrid Spacing="3">
        <!-- Sidebar filters -->
        <MudItem xs="12" md="3">
            <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                <MudText Typo="Typo.subtitle2" Class="mb-3" Style="font-weight:700;">Filters</MudText>

                <SearchBar Value="@_search"
                           OnSearch="OnSearchChanged"
                           Label="Search"
                           Placeholder="Name, SKU or description…"
                           Class="mb-4" />

                <MudText Typo="Typo.caption" Class="mud-text-secondary mb-1">Brand</MudText>
                <MudList T="BrandDto" Dense="true" Class="mb-3">
                    @foreach (var brand in _brands)
                    {
                        <MudListItem T="BrandDto" Dense="true">
                            <MudCheckBox T="bool"
                                         Value="@_selectedBrandIds.Contains(brand.Id)"
                                         ValueChanged="@(v => ToggleBrand(brand.Id, v))"
                                         Label="@brand.Name"
                                         Size="Size.Small"
                                         Color="Color.Primary" />
                        </MudListItem>
                    }
                </MudList>

                <MudText Typo="Typo.caption" Class="mud-text-secondary mb-1">Category</MudText>
                <MudList T="CategoryDto" Dense="true">
                    @foreach (var cat in _categories)
                    {
                        <MudListItem T="CategoryDto" Dense="true">
                            <MudCheckBox T="bool"
                                         Value="@_selectedCategoryIds.Contains(cat.Id)"
                                         ValueChanged="@(v => ToggleCategory(cat.Id, v))"
                                         Label="@cat.Name"
                                         Size="Size.Small"
                                         Color="Color.Primary" />
                        </MudListItem>
                    }
                </MudList>

                @if (_selectedBrandIds.Count > 0 || _selectedCategoryIds.Count > 0)
                {
                    <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small"
                               OnClick="ClearFilters" StartIcon="@Icons.Material.Filled.FilterAltOff" Class="mt-2">
                        Clear Filters
                    </MudButton>
                }
            </MudPaper>
        </MudItem>

        <!-- Product grid -->
        <MudItem xs="12" md="9">
            <LoadingSpinner Visible="_loading" />

            @if (!_loading)
            {
                @if (_pagedResult?.Items.Count == 0)
                {
                    <MudAlert Severity="Severity.Info">No products found matching your criteria.</MudAlert>
                }
                else
                {
                    <MudGrid Spacing="3">
                        @foreach (var product in _pagedResult?.Items ?? [])
                        {
                            <MudItem xs="12" sm="6" lg="4">
                                <ProductCard Product="product"
                                             DetailHrefBase="/portal/products">
                                    <AdditionalActions Context="p">
                                        @if (p.MinPrice.HasValue)
                                        {
                                            <div class="d-flex align-center px-2">
                                                <PriceDisplay Price="p.MinPrice" Prefix="From " PriceTypo="Typo.caption" />
                                            </div>
                                        }
                                    </AdditionalActions>
                                </ProductCard>
                            </MudItem>
                        }
                    </MudGrid>

                    <PaginatedList CurrentPage="_page"
                                   TotalCount="_pagedResult!.TotalCount"
                                   PageSize="20"
                                   OnPageChange="OnPageChanged" />
                }
            }
        </MudItem>
    </MudGrid>
}

@code {
    private List<BrandDto> _brands = [];
    private List<CategoryDto> _categories = [];
    private PagedResult<ProductListItemDto>? _pagedResult;

    private bool _checkingApproval = true;
    private bool _isApproved;
    private bool _loading = true;

    private string _search = string.Empty;
    private int _page = 1;
    private HashSet<int> _selectedBrandIds = [];
    private HashSet<int> _selectedCategoryIds = [];

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.IsInRole("Admin"))
        {
            _isApproved = true;
        }
        else
        {
            var user = await UserManager.GetUserAsync(authState.User);
            _isApproved = user?.IsApproved ?? false;
        }
        _checkingApproval = false;

        if (!_isApproved) return;

        var brandsTask = Mediator.Send(new GetBrandsQuery());
        var categoriesTask = Mediator.Send(new GetCategoriesQuery());
        await Task.WhenAll(brandsTask, categoriesTask);

        _brands = brandsTask.Result;
        _categories = categoriesTask.Result;

        await LoadProductsAsync();
        _loading = false;
    }

    private async Task LoadProductsAsync()
    {
        _pagedResult = await Mediator.Send(new GetProductsQuery(
            Page: _page,
            PageSize: 20,
            Search: _search,
            BrandIds: _selectedBrandIds.Count > 0 ? [.. _selectedBrandIds] : null,
            CategoryIds: _selectedCategoryIds.Count > 0 ? [.. _selectedCategoryIds] : null,
            IncludePrice: true));
    }

    private async Task OnSearchChanged(string search)
    {
        _search = search;
        _page = 1;
        _loading = true;
        StateHasChanged();
        await LoadProductsAsync();
        _loading = false;
    }

    private async Task OnPageChanged(int page)
    {
        _page = page;
        _loading = true;
        StateHasChanged();
        await LoadProductsAsync();
        _loading = false;
    }

    private async Task ToggleBrand(int id, bool selected)
    {
        if (selected) _selectedBrandIds.Add(id);
        else _selectedBrandIds.Remove(id);
        _page = 1;
        _loading = true;
        StateHasChanged();
        await LoadProductsAsync();
        _loading = false;
    }

    private async Task ToggleCategory(int id, bool selected)
    {
        if (selected) _selectedCategoryIds.Add(id);
        else _selectedCategoryIds.Remove(id);
        _page = 1;
        _loading = true;
        StateHasChanged();
        await LoadProductsAsync();
        _loading = false;
    }

    private async Task ClearFilters()
    {
        _selectedBrandIds.Clear();
        _selectedCategoryIds.Clear();
        _search = string.Empty;
        _page = 1;
        _loading = true;
        StateHasChanged();
        await LoadProductsAsync();
        _loading = false;
    }
}
