@page "/portal/checkout"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin,Client")]
@layout PortalLayout
@rendermode InteractiveServer
@using dWebShop.Application.Features.Orders.Commands
@using dWebShop.Application.Features.ShoppingCart.Queries
@using dWebShop.Domain.Entities.Partners
@using dWebShop.Domain.Entities.Users
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using dWebShop.Application.Common.Interfaces
@inject IMediator Mediator
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject IAppDbContext Db

<PageTitle>Checkout — Portal</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Checkout</MudText>

<LoadingSpinner Visible="_loading" />

@if (!_loading)
{
    @if (_cartItems.Count == 0)
    {
        <MudAlert Severity="Severity.Warning">
            Your cart is empty. <MudLink Href="/portal/cart">Go back to cart</MudLink>.
        </MudAlert>
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" md="7">
                <!-- Cart Summary -->
                <MudText Typo="Typo.h6" Class="mb-2">Order Summary</MudText>
                <MudTable Items="_cartItems" Dense="true" Outlined="true" Class="mb-4">
                    <HeaderContent>
                        <MudTh>Product</MudTh>
                        <MudTh Style="text-align:right">Unit Price</MudTh>
                        <MudTh Style="text-align:center">Qty</MudTh>
                        <MudTh Style="text-align:right">Total</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>
                            <strong>@context.Name</strong><br />
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@context.SKU</MudText>
                        </MudTd>
                        <MudTd Style="text-align:right"><PriceDisplay Price="context.Price" PriceTypo="Typo.body2" /></MudTd>
                        <MudTd Style="text-align:center">@context.Quantity</MudTd>
                        <MudTd Style="text-align:right"><PriceDisplay Price="@(context.Price * context.Quantity)" PriceTypo="Typo.body2" /></MudTd>
                    </RowTemplate>
                    <FooterContent>
                        <MudTd colspan="3" Style="text-align:right"><strong>Grand Total</strong></MudTd>
                        <MudTd Style="text-align:right">
                            <PriceDisplay Price="_total" PriceTypo="Typo.subtitle1" />
                        </MudTd>
                    </FooterContent>
                </MudTable>
            </MudItem>

            <MudItem xs="12" md="5">
                <!-- Delivery Address Selection -->
                <MudText Typo="Typo.h6" Class="mb-2">Delivery Address</MudText>
                <MudPaper Class="pa-4 mb-4" Elevation="1">
                    @if (_addresses.Count == 0)
                    {
                        <MudAlert Severity="Severity.Info" Dense="true">No addresses on file. Order will use default billing address.</MudAlert>
                    }
                    else
                    {
                        <MudSelect T="int?" Label="Select delivery address" @bind-Value="_selectedAddressId" Variant="Variant.Outlined" Clearable="true">
                            @foreach (var addr in _addresses)
                            {
                                <MudSelectItem T="int?" Value="@addr.Id">@addr.Label</MudSelectItem>
                            }
                        </MudSelect>
                    }

                    <MudTextField @bind-Value="_notes"
                                  Label="Notes (optional)"
                                  Variant="Variant.Outlined"
                                  Lines="3"
                                  Class="mt-3" />
                </MudPaper>

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Class="mb-3">@_errorMessage</MudAlert>
                }

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large"
                           StartIcon="@Icons.Material.Filled.CheckCircle"
                           OnClick="PlaceOrder"
                           Disabled="_busy">
                    @(_busy ? "Placing Order..." : "Confirm Order")
                </MudButton>
                <MudButton Variant="Variant.Text"
                           FullWidth="true"
                           Href="/portal/cart"
                           Class="mt-2">
                    Back to Cart
                </MudButton>
            </MudItem>
        </MudGrid>
    }
}

@code {
    private List<CartItemDto> _cartItems = [];
    private List<AddressOption> _addresses = [];
    private int? _selectedAddressId;
    private string _notes = string.Empty;
    private bool _loading = true;
    private bool _busy;
    private string _errorMessage = string.Empty;
    private int _userId;
    private int _partnerId;

    private decimal _total => _cartItems.Sum(x => x.Price * x.Quantity);

    private record AddressOption(int Id, string Label);

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);
        if (user is null) { Nav.NavigateTo("/login"); return; }

        _userId = user.Id;

        if (user.PartnerId.HasValue)
        {
            _partnerId = user.PartnerId.Value;
            var partner = await Db.Partners
                .Include(p => p.Address)
                .Include(p => p.DeliveryAddresses)
                .FirstOrDefaultAsync(p => p.Id == _partnerId);

            if (partner?.DeliveryAddresses is not null)
            {
                _addresses = partner.DeliveryAddresses
                    .Select(a => new AddressOption(a.Id, $"{a.Address1}, {a.ZipCode} {a.City}, {a.Country}"))
                    .ToList();
            }

            if (_addresses.Count == 0 && partner?.Address is not null)
            {
                var a = partner.Address;
                _addresses = [new AddressOption(a.Id, $"{a.Address1}, {a.ZipCode} {a.City}, {a.Country}")];
            }
        }

        _cartItems = await Mediator.Send(new GetCartQuery(_userId));
        _loading = false;
    }

    private async Task PlaceOrder()
    {
        if (_cartItems.Count == 0) return;
        if (_partnerId == 0)
        {
            _errorMessage = "Your account is not linked to a partner profile. Please contact support.";
            return;
        }

        _busy = true;
        _errorMessage = string.Empty;

        try
        {
            var orderGuid = await Mediator.Send(new PlaceOrderCommand(_userId, _partnerId, _selectedAddressId, _notes));
            Nav.NavigateTo($"/portal/orders/{orderGuid}");
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to place order: {ex.Message}";
            _busy = false;
        }
    }
}
