@page "/portal/orders/{GuidStr}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin,Client")]
@layout PortalLayout
@rendermode InteractiveServer
@using dWebShop.Application.Features.Orders.Queries
@using dWebShop.Domain.Entities.Orders
@using dWebShop.Domain.Entities.Users
@using Microsoft.AspNetCore.Identity
@inject IMediator Mediator
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<PageTitle>Order Detail — Portal</PageTitle>

<LoadingSpinner Visible="_loading" />

@if (!_loading)
{
    @if (_order is null)
    {
        <MudAlert Severity="Severity.Error">Order not found.</MudAlert>
        <MudButton Href="/portal/orders" Class="mt-3">Back to Orders</MudButton>
    }
    else
    {
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
            <MudText Typo="Typo.h5">Order #@_order.Guid.ToString()[..8].ToUpper()</MudText>
            <MudSpacer />
            <MudChip T="string" Color="@StatusColor(_order.Status)">@_order.Status</MudChip>
        </MudStack>

        <MudGrid>
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Elevation="1">
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Order Info</MudText>
                    <MudText Typo="Typo.body2"><strong>Placed:</strong> @_order.Created.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</MudText>
                    <MudText Typo="Typo.body2"><strong>Status:</strong> @_order.Status</MudText>
                    @if (!string.IsNullOrEmpty(_order.DeliveryAddress))
                    {
                        <MudText Typo="Typo.body2"><strong>Delivery Address:</strong> @_order.DeliveryAddress</MudText>
                    }
                    @if (!string.IsNullOrEmpty(_order.Notes))
                    {
                        <MudText Typo="Typo.body2"><strong>Notes:</strong> @_order.Notes</MudText>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudText Typo="Typo.h6" Class="mt-4 mb-2">Items</MudText>
        <MudTable Items="_order.Items" Dense="true" Outlined="true" Striped="true">
            <HeaderContent>
                <MudTh>Product</MudTh>
                <MudTh>SKU</MudTh>
                <MudTh Style="text-align:right">Unit Price</MudTh>
                <MudTh Style="text-align:center">Qty</MudTh>
                <MudTh Style="text-align:right">Line Total</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.ProductName</MudTd>
                <MudTd><MudText Typo="Typo.caption">@context.SKU</MudText></MudTd>
                <MudTd Style="text-align:right"><PriceDisplay Price="context.Price" PriceTypo="Typo.body2" /></MudTd>
                <MudTd Style="text-align:center">@context.Quantity.ToString("F2")</MudTd>
                <MudTd Style="text-align:right"><PriceDisplay Price="@(context.Price * context.Quantity)" PriceTypo="Typo.body2" /></MudTd>
            </RowTemplate>
            <FooterContent>
                <MudTd colspan="4" Style="text-align:right"><strong>Total</strong></MudTd>
                <MudTd Style="text-align:right">
                    <PriceDisplay Price="@_order.Items.Sum(i => i.Price * i.Quantity)" PriceTypo="Typo.subtitle1" />
                </MudTd>
            </FooterContent>
        </MudTable>

        <MudButton Variant="Variant.Text" Href="/portal/orders" Class="mt-4">
            ← Back to Orders
        </MudButton>
    }
}

@code {
    [Parameter] public string GuidStr { get; set; } = string.Empty;

    private OrderDetailDto? _order;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        if (!Guid.TryParse(GuidStr, out var guid))
        {
            _loading = false;
            return;
        }

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);

        // Admins can view any order; clients only their own
        int? partnerId = null;
        if (user is not null && !authState.User.IsInRole("Admin"))
            partnerId = user.PartnerId;

        _order = await Mediator.Send(new GetOrderByGuidQuery(guid, partnerId));
        _loading = false;
    }

    private static Color StatusColor(OrderStatus status) => status switch
    {
        OrderStatus.Pending => Color.Default,
        OrderStatus.Confirmed => Color.Info,
        OrderStatus.Shipped => Color.Primary,
        OrderStatus.Delivered => Color.Success,
        OrderStatus.Cancelled => Color.Error,
        _ => Color.Default
    };
}
