@page "/portal/orders"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin,Client")]
@layout PortalLayout
@rendermode InteractiveServer
@using dWebShop.Application.Features.Orders.Queries
@using dWebShop.Domain.Entities.Orders
@using dWebShop.Domain.Entities.Users
@using Microsoft.AspNetCore.Identity
@inject IMediator Mediator
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Orders — Portal</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">My Orders</MudText>

<LoadingSpinner Visible="_loading" />

@if (!_loading)
{
    @if (_orders.Count == 0)
    {
        <MudAlert Severity="Severity.Info">
            You have no orders yet. <MudLink Href="/portal/products">Browse products</MudLink> to get started.
        </MudAlert>
    }
    else
    {
        <MudTable Items="_orders" Dense="true" Outlined="true" Striped="true" Hover="true">
            <HeaderContent>
                <MudTh>Order Ref</MudTh>
                <MudTh>Date</MudTh>
                <MudTh Style="text-align:center">Items</MudTh>
                <MudTh Style="text-align:right">Total</MudTh>
                <MudTh Style="text-align:center">Status</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudText Typo="Typo.body2" Style="font-family:monospace">#@context.Guid.ToString()[..8].ToUpper()</MudText>
                </MudTd>
                <MudTd>@context.Created.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</MudTd>
                <MudTd Style="text-align:center">@context.ItemCount</MudTd>
                <MudTd Style="text-align:right"><PriceDisplay Price="context.Total" PriceTypo="Typo.body2" /></MudTd>
                <MudTd Style="text-align:center">
                    <MudChip T="string" Color="@StatusColor(context.Status)" Size="Size.Small">@context.Status</MudChip>
                </MudTd>
                <MudTd>
                    <MudButton Variant="Variant.Text"
                               Color="Color.Primary"
                               Size="Size.Small"
                               Href="@($"/portal/orders/{context.Guid}")">
                        View
                    </MudButton>
                </MudTd>
            </RowTemplate>
        </MudTable>

        @if (_totalPages > 1)
        {
            <MudPagination Count="_totalPages" @bind-Selected="_page" Class="mt-4" OnChange="LoadOrders" />
        }
    }
}

@code {
    private List<OrderListDto> _orders = [];
    private bool _loading = true;
    private int _partnerId;
    private int _page = 1;
    private int _totalPages = 1;
    private const int PageSize = 10;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);
        if (user?.PartnerId is null) { _loading = false; return; }

        _partnerId = user.PartnerId.Value;
        await LoadOrders();
        _loading = false;
    }

    private async Task LoadOrders()
    {
        var (items, total) = await Mediator.Send(new GetPartnerOrdersQuery(_partnerId, _page, PageSize));
        _orders = items;
        _totalPages = (int)Math.Ceiling(total / (double)PageSize);
    }

    private static Color StatusColor(OrderStatus status) => status switch
    {
        OrderStatus.Pending => Color.Default,
        OrderStatus.Confirmed => Color.Info,
        OrderStatus.Shipped => Color.Primary,
        OrderStatus.Delivered => Color.Success,
        OrderStatus.Cancelled => Color.Error,
        _ => Color.Default
    };
}
