@page "/portal/cart"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin,Client")]
@layout PortalLayout
@rendermode InteractiveServer
@using dWebShop.Application.Features.ShoppingCart.Commands
@using dWebShop.Application.Features.ShoppingCart.Queries
@using dWebShop.Domain.Entities.Users
@using Microsoft.AspNetCore.Identity
@inject IMediator Mediator
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<PageTitle>Cart — Portal</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h5">Shopping Cart</MudText>
    <MudSpacer />
    @if (_items.Count > 0)
    {
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Error"
                   Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.DeleteSweep"
                   OnClick="ClearCart"
                   Disabled="_busy">
            Clear Cart
        </MudButton>
    }
</MudStack>

<LoadingSpinner Visible="_loading" />

@if (!_loading)
{
    @if (_items.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Class="mb-4">
            Your cart is empty. <MudLink Href="/portal/products">Browse products</MudLink> to add items.
        </MudAlert>
    }
    else
    {
        <MudTable Items="_items" Dense="true" Outlined="true" Striped="true" Class="mb-4">
            <HeaderContent>
                <MudTh></MudTh>
                <MudTh>Product / SKU</MudTh>
                <MudTh Style="text-align:right">Unit Price</MudTh>
                <MudTh Style="text-align:center">Quantity</MudTh>
                <MudTh Style="text-align:right">Line Total</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    @if (!string.IsNullOrWhiteSpace(context.ImagePath))
                    {
                        <img src="/product_images/@context.ImagePath"
                             style="width:48px;height:48px;object-fit:cover;border-radius:4px;" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Inventory2" Style="font-size:40px;" Color="Color.Secondary" />
                    }
                </MudTd>
                <MudTd>
                    <MudLink Href="@($"/portal/products/{context.ProductSlug}")" Underline="Underline.Hover">
                        <strong>@context.Name</strong>
                    </MudLink>
                    <br />
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@context.SKU</MudText>
                </MudTd>
                <MudTd Style="text-align:right">
                    <PriceDisplay Price="context.Price" PriceTypo="Typo.body2" />
                </MudTd>
                <MudTd Style="text-align:center">
                    <MudNumericField T="decimal"
                                     Value="context.Quantity"
                                     ValueChanged="@(v => OnQuantityChanged(context, v))"
                                     Min="1"
                                     Step="1"
                                     HideSpinButtons="false"
                                     Style="width:90px;"
                                     Disabled="_busy" />
                </MudTd>
                <MudTd Style="text-align:right">
                    <PriceDisplay Price="@(context.Price * context.Quantity)" PriceTypo="Typo.body2" />
                </MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Color="Color.Error"
                                   Size="Size.Small"
                                   OnClick="@(() => RemoveItem(context))"
                                   Disabled="_busy" />
                </MudTd>
            </RowTemplate>
        </MudTable>

        <!-- Cart Summary -->
        <MudPaper Class="pa-4" Elevation="1" Style="max-width:400px;margin-left:auto;">
            <MudStack Spacing="2">
                <MudStack Row="true" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.body2">Subtotal (@_items.Count item(s))</MudText>
                    <PriceDisplay Price="_subtotal" PriceTypo="Typo.body2" />
                </MudStack>
                <MudDivider />
                <MudStack Row="true" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.subtitle1" Style="font-weight:700;">Total</MudText>
                    <PriceDisplay Price="_subtotal" PriceTypo="Typo.subtitle1" />
                </MudStack>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large"
                           StartIcon="@Icons.Material.Filled.ShoppingCartCheckout"
                           Href="/portal/checkout"
                           Class="mt-2">
                    Proceed to Checkout
                </MudButton>
            </MudStack>
        </MudPaper>
    }
}

@code {
    private List<CartItemDto> _items = [];
    private bool _loading = true;
    private bool _busy;
    private int _userId;

    private decimal _subtotal => _items.Sum(x => x.Price * x.Quantity);

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);
        if (user is null) return;

        _userId = user.Id;
        await LoadCartAsync();
        _loading = false;
    }

    private async Task LoadCartAsync()
    {
        _items = await Mediator.Send(new GetCartQuery(_userId));
    }

    private async Task OnQuantityChanged(CartItemDto item, decimal newQty)
    {
        if (newQty < 1) return;
        _busy = true;
        await Mediator.Send(new UpdateCartItemCommand(_userId, item.Id, newQty));
        await LoadCartAsync();
        _busy = false;
    }

    private async Task RemoveItem(CartItemDto item)
    {
        _busy = true;
        await Mediator.Send(new RemoveCartItemCommand(_userId, item.Id));
        await LoadCartAsync();
        _busy = false;
    }

    private async Task ClearCart()
    {
        _busy = true;
        await Mediator.Send(new ClearCartCommand(_userId));
        _items = [];
        _busy = false;
    }
}
