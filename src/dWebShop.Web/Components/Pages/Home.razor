                <span class="arr">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14M13 5l7 7-7 7" />
                    </svg>
                </span>
            </a>
            <a href="/services" class="asg-svc-row">
                <span class="n">06</span>
                <span class="t">Stručno savjetovanje</span>
                <span class="d">Individualni pristup uz podršku certificiranih stručnjaka i aplikatora.</span>
                <span class="arr">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
