@page "/"
@layout LandingLayout

<PageTitle>ASGifiks d.o.o. - Profesionalna rješenja za gradnju</PageTitle>

<!-- ====================================================
     SECTION 1: HERO
     ==================================================== -->
<section class="hero-section">
    <div class="hero-section__bg"></div>
    <div class="hero-section__overlay"></div>

    <div class="hero-section__content">
        <img src="/images/logo-dark.png" alt="ASGifiks Logo" class="hero-section__logo" />
        <h1 class="hero-section__title">ZAŠTITITE, IZOLIRAJTE<br />I UKRASITE VAŠE OBJEKTE</h1>
        <p class="hero-section__subtitle">
            Ekskluzivni distributer svjetski poznatih brendova STO, XYPEX i CORTEC
            za tržište Bosne i Hercegovine. Profesionalna rješenja za gradnju od 1998. godine.
        </p>
        <div class="hero-section__actions">
            <a href="/shop" class="btn btn-light">Web Shop</a>
            <a href="#about" class="btn btn-outline-light">Saznajte Više</a>
        </div>
    </div>

    <div class="hero-section__scroll">
        <span>Skrolaj</span>
        <div class="hero-section__scroll-arrow"></div>
    </div>
</section>

<!-- ====================================================
     SECTION 2: STATS
     ==================================================== -->
<section class="stats-section">
    <div class="container">
        <div class="stats-section__grid">
            <div class="stats-section__item">
                <div class="stats-section__number">25+</div>
                <div class="stats-section__label">Godina Iskustva</div>
            </div>
            <div class="stats-section__item">
                <div class="stats-section__number">3</div>
                <div class="stats-section__label">Svjetska Brenda</div>
            </div>
            <div class="stats-section__item">
                <div class="stats-section__number">500+</div>
                <div class="stats-section__label">Zadovoljnih Klijenata</div>
            </div>
            <div class="stats-section__item">
                <div class="stats-section__number">1000+</div>
                <div class="stats-section__label">Realizovanih Projekata</div>
            </div>
        </div>
    </div>
</section>

<!-- ====================================================
     SECTION 3: ABOUT
     ==================================================== -->
<section class="about-section" id="about">
    <div class="container">
        <div class="about-section__grid">
            <div class="about-section__image-wrapper">
                <img src="/images/asgifiks_front.jpg" alt="ASGifiks poslovnica" class="about-section__image" />
                <div class="about-section__badge">
                    <div class="about-section__badge-year">1998</div>
                    <span class="about-section__badge-label">Osnivanje</span>
                </div>
            </div>

            <div class="about-section__text">
                <div class="section-header" style="text-align:left; margin-bottom:1.5rem;">
                    <span class="section-tag">O NAMA</span>
                    <h2 class="section-title">Naša Priča</h2>
                </div>
                <p class="lead-text">
                    ASGifiks d.o.o. je kompanija sa sjedištem u Tomislavgradu, osnovana 1998. godine
                    s vizijom pružanja vrhunskih građevinskih rješenja na tržištu Bosne i Hercegovine.
                </p>
                <p style="color: var(--color-gray); line-height: 1.8; margin-bottom: 1.5rem;">
                    Kao ekskluzivni distributer globalnih brendova STO, XYPEX i CORTEC, nudimo
                    cjelovita rješenja za fasadne sisteme, toplinsku izolaciju, hidroizolaciju betona
                    i zaštitu od korozije. Naš tim stručnjaka osigurava tehničku podršku i savjetovanje
                    na svakom koraku vašeg projekta.
                </p>

                <div class="about-section__features">
                    <div class="about-section__feature">
                        <div class="about-section__feature-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                        </div>
                        <div>
                            <p class="about-section__feature-title">Certificirani partneri</p>
                            <p class="about-section__feature-desc">Ovlašteni distributeri vodećih svjetskih brendova</p>
                        </div>
                    </div>
                    <div class="about-section__feature">
                        <div class="about-section__feature-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M13 10V3L4 14h7v7l9-11h-7z"/>
                            </svg>
                        </div>
                        <div>
                            <p class="about-section__feature-title">Brza dostava</p>
                            <p class="about-section__feature-desc">Pouzdana logistika i pravovremena isporuka</p>
                        </div>
                    </div>
                    <div class="about-section__feature">
                        <div class="about-section__feature-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/>
                            </svg>
                        </div>
                        <div>
                            <p class="about-section__feature-title">Tehnička podrška</p>
                            <p class="about-section__feature-desc">Stručni savjeti i projektna dokumentacija</p>
                        </div>
                    </div>
                    <div class="about-section__feature">
                        <div class="about-section__feature-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                        </div>
                        <div>
                            <p class="about-section__feature-title">Konkurentne cijene</p>
                            <p class="about-section__feature-desc">Povoljne cijene uz najviši kvalitet proizvoda</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ====================================================
     SECTION 4: BRANDS
     ==================================================== -->
<section class="brands-section">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">PARTNERI</span>
            <h2 class="section-title">Svjetski Brendovi</h2>
            <p class="section-description">
                Ekskluzivni distributer tri vodeća svjetska brenda u oblasti građevinskih materijala za BiH tržište.
            </p>
        </div>

        <div class="brands-section__grid">
            <!-- STO -->
            <a href="/sto" class="brands-section__card">
                <div class="brands-section__card-header">
                    <img src="/brand_images/sto-logo.svg" alt="STO Logo" class="brands-section__card-logo" />
                </div>
                <div class="brands-section__card-body">
                    <p class="brands-section__card-origin">Njema&#269;ka &bull; od 1955.</p>
                    <h3 class="brands-section__card-title">STO</h3>
                    <p class="brands-section__card-desc">
                        Svjetski lider u fasadnim sistemima i toplinskoj izolaciji.
                        Inovativna rješenja za energetsku efikasnost objekata.
                    </p>
                    <div class="brands-section__card-cta">
                        Saznajte više
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M5 12h14M12 5l7 7-7 7"/>
                        </svg>
                    </div>
                </div>
            </a>

            <!-- XYPEX -->
            <a href="/xypex" class="brands-section__card">
                <div class="brands-section__card-header">
                    <img src="/brand_images/xypex-logo.svg" alt="XYPEX Logo" class="brands-section__card-logo" />
                </div>
                <div class="brands-section__card-body">
                    <p class="brands-section__card-origin">Kanada &bull; od 1969.</p>
                    <h3 class="brands-section__card-title">XYPEX</h3>
                    <p class="brands-section__card-desc">
                        Revolucionarna kristalna hidroizolacija betona.
                        Trajna zaštita temelja, tunela i vodoopskrbnih objekata.
                    </p>
                    <div class="brands-section__card-cta">
                        Saznajte više
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M5 12h14M12 5l7 7-7 7"/>
                        </svg>
                    </div>
                </div>
            </a>

            <!-- CORTEC -->
            <a href="/cortec" class="brands-section__card">
                <div class="brands-section__card-header">
                    <img src="/brand_images/2ird1kix.mfw.png" alt="CORTEC Logo" class="brands-section__card-logo" />
                </div>
                <div class="brands-section__card-body">
                    <p class="brands-section__card-origin">SAD &bull; od 1973.</p>
                    <h3 class="brands-section__card-title">CORTEC</h3>
                    <p class="brands-section__card-desc">
                        Napredna rješenja za zaštitu od korozije zasnovana na VpCI tehnologiji.
                        Ekološki prihvatljivi proizvodi za industriju i građevinarstvo.
                    </p>
                    <div class="brands-section__card-cta">
                        Saznajte više
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M5 12h14M12 5l7 7-7 7"/>
                        </svg>
                    </div>
                </div>
            </a>
        </div>
    </div>
</section>

<!-- ====================================================
     SECTION 5: SERVICES
     ==================================================== -->
<section class="services-section">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">ŠTO NUDIMO</span>
            <h2 class="section-title">Naše Usluge</h2>
            <p class="section-description">
                Pružamo sveobuhvatna rješenja za sve faze gradnje — od tehničke dokumentacije do ugradnje i savjetovanja.
            </p>
        </div>

        <div class="services-section__grid">
            <!-- Fasadni Sistemi -->
            <div class="services-section__card">
                <div class="services-section__icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                        <polyline points="9 22 9 12 15 12 15 22"/>
                    </svg>
                </div>
                <h3 class="services-section__card-title">Fasadni Sistemi</h3>
                <p class="services-section__card-desc">
                    Kompletni ETICS sistemi i dekorativne žbuke za energetski efikasne fasade.
                </p>
            </div>

            <!-- Toplinska Izolacija -->
            <div class="services-section__card">
                <div class="services-section__icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <path d="M12 2a10 10 0 100 20A10 10 0 0012 2zm0 18a8 8 0 110-16 8 8 0 010 16z"/>
                        <path d="M12 6v6l4 2"/>
                    </svg>
                </div>
                <h3 class="services-section__card-title">Toplinska Izolacija</h3>
                <p class="services-section__card-desc">
                    EPS i mineralna vuna rješenja za smanjenje toplinskih gubitaka i energetsku uštedu.
                </p>
            </div>

            <!-- Tehnička Dokumentacija -->
            <div class="services-section__card">
                <div class="services-section__icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                        <line x1="16" y1="13" x2="8" y2="13"/>
                        <line x1="16" y1="17" x2="8" y2="17"/>
                        <polyline points="10 9 9 9 8 9"/>
                    </svg>
                </div>
                <h3 class="services-section__card-title">Tehnička Dokumentacija</h3>
                <p class="services-section__card-desc">
                    Izrada tehničke specifikacije, proračuna i projektne dokumentacije za vaš objekat.
                </p>
            </div>

            <!-- Stručno Savjetovanje -->
            <div class="services-section__card">
                <div class="services-section__icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 00-3-3.87"/>
                        <path d="M16 3.13a4 4 0 010 7.75"/>
                    </svg>
                </div>
                <h3 class="services-section__card-title">Stručno Savjetovanje</h3>
                <p class="services-section__card-desc">
                    Individualni pristup svakom projektu uz podršku certificiranih stručnjaka i aplikatora.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- ====================================================
     SECTION 6: CTA
     ==================================================== -->
<section class="cta-section">
    <div class="container">
        <h2 class="cta-section__title">Spremni za Novi Projekt?</h2>
        <p class="cta-section__desc">
            Kontaktirajte nas danas i saznajte kako naši proizvodi mogu unaprijediti vaš projekt.
        </p>
        <div class="cta-section__actions">
            <a href="/contact" class="btn btn-light">Kontaktirajte Nas</a>
            <a href="/shop" class="btn btn-outline-light">Web Shop</a>
        </div>
    </div>
</section>

<!-- ====================================================
     SECTION 7: INLINE FOOTER
     ==================================================== -->
