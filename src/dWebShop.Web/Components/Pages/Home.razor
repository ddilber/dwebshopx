@page "/"
@layout LandingLayout

<PageTitle>ASGifiks d.o.o. - Profesionalna rješenja za gradnju</PageTitle>

<!-- ====================================================
     SECTION 1: HERO
     ==================================================== -->
<section class="hero-section">
    <div class="hero-overlay"></div>

    <div class="hero-content">
        <div class="container">
            <div class="hero-text">
                <div class="hero-logo fade-in">
                    <img src="/images/logo-dark.svg" alt="ASGifiks Logo" />
                </div>
                <h1 class="hero-title fade-in-delay">ZAŠTITITE, IZOLIRAJTE<br />I OBNOVITE S VRHUNSKIM MATERIJALIMA</h1>
                <p class="hero-subtitle fade-in-delay-2">
                    Distribucija Xypex, STO i Cortec materijala uz tehničku podršku i savjetovanje
                </p>
                <div class="hero-buttons fade-in-delay-3">
                    <a href="/shop" class="btn btn-primary">Web Shop</a>
                    <a href="#about" class="btn btn-outline">Saznajte Više</a>
                </div>
            </div>
        </div>
    </div>

    <div class="scroll-indicator">
        <div class="mouse">
            <div class="wheel"></div>
        </div>
    </div>
</section>

<!-- ====================================================
     SECTION 2: STATS
     ==================================================== -->
<section class="stats-section">
    <div class="container">
        <div class="stats-grid">
            <div class="stat-item animate-on-scroll">
                <div class="stat-number">25+</div>
                <div class="stat-label">Godina Iskustva</div>
            </div>
            <div class="stat-item animate-on-scroll">
                <div class="stat-number">3</div>
                <div class="stat-label">Svjetska Brenda</div>
            </div>
            <div class="stat-item animate-on-scroll">
                <div class="stat-number">500+</div>
                <div class="stat-label">Zadovoljnih Klijenata</div>
            </div>
            <div class="stat-item animate-on-scroll">
                <div class="stat-number">1000+</div>
                <div class="stat-label">Realizovanih Projekata</div>
            </div>
        </div>
    </div>
</section>

<!-- ====================================================
     SECTION 3: ABOUT
     ==================================================== -->
<section class="about-section" id="about">
    <div class="container">
        <div class="about-content">
            <div class="about-image animate-on-scroll">
                <img src="/images/asgifiks_front.svg" alt="ASGifiks poslovnica" />
                <div class="image-badge">
                    <span class="badge-year">1998</span>
                    <span class="badge-text">Osnivanje</span>
                </div>
            </div>

            <div class="about-text animate-on-scroll">
                <div class="section-header" style="text-align:left; margin-bottom:1.5rem;">
                    <span class="section-tag">O NAMA</span>
                    <h2 class="section-title">Naša Priča</h2>
                </div>
                <p>
                    ASGifiks d.o.o. je kompanija sa sjedištem u Tomislavgradu, osnovana 1998. godine
                    s vizijom pružanja vrhunskih građevinskih rješenja na tržištu Bosne i Hercegovine.
                </p>
                <p>
                    Kao ekskluzivni distributer globalnih brendova STO, XYPEX i CORTEC, nudimo
                    cjelovita rješenja za fasadne sisteme, toplinsku izolaciju, hidroizolaciju betona
                    i zaštitu od korozije. Naš tim stručnjaka osigurava tehničku podršku i savjetovanje
                    na svakom koraku vašeg projekta.
                </p>

                <div class="features-list">
                    <div class="feature-item">
                        <svg class="feature-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        <span>Certificirani partneri</span>
                    </div>
                    <div class="feature-item">
                        <svg class="feature-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M13 10V3L4 14h7v7l9-11h-7z"/>
                        </svg>
                        <span>Brza dostava</span>
                    </div>
                    <div class="feature-item">
                        <svg class="feature-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/>
                        </svg>
                        <span>Tehnička podrška</span>
                    </div>
                    <div class="feature-item">
                        <svg class="feature-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        <span>Konkurentne cijene</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ====================================================
     SECTION 4: BRANDS
     ==================================================== -->
<section class="brands-section">
    <div class="container">
        <div class="section-header animate-on-scroll">
            <span class="section-tag">PARTNERI</span>
            <h2 class="section-title">Svjetski Brendovi</h2>
            <p class="section-description">
                Ekskluzivni distributer tri vodeća svjetska brenda u oblasti građevinskih materijala za BiH tržište.
            </p>
        </div>

        <div class="brands-grid">
            <!-- STO -->
            <a href="/sto" class="brand-card animate-on-scroll">
                <div class="brand-logo-wrapper">
                    <img src="/brand_images/sto-logo.svg" alt="STO Logo" class="brand-logo" />
                </div>
                <div class="brand-content">
                    <h3>STO</h3>
                    <span class="brand-origin">Njema&#269;ka &bull; od 1955.</span>
                    <p>Svjetski lider u fasadnim sistemima i toplinskoj izolaciji. Inovativna rješenja za energetsku efikasnost objekata.</p>
                    <ul class="brand-products">
                        <li>Fasadni sistemi</li>
                        <li>Toplinska izolacija</li>
                        <li>Dekorativne žbuke</li>
                        <li>Boje i premazi</li>
                    </ul>
                    <div class="brand-link">
                        Saznajte više
                        <svg class="link-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M5 12h14M12 5l7 7-7 7"/>
                        </svg>
                    </div>
                </div>
            </a>

            <!-- XYPEX -->
            <a href="/xypex" class="brand-card animate-on-scroll">
                <div class="brand-logo-wrapper">
                    <img src="/brand_images/xypex-logo.svg" alt="XYPEX Logo" class="brand-logo" />
                </div>
                <div class="brand-content">
                    <h3>XYPEX</h3>
                    <span class="brand-origin">Kanada &bull; od 1969.</span>
                    <p>Revolucionarna kristalna hidroizolacija betona. Trajna zaštita temelja, tunela i vodoopskrbnih objekata.</p>
                    <ul class="brand-products">
                        <li>Zaštita betona</li>
                        <li>Hidroizolacija</li>
                        <li>Sanacija pukotina</li>
                        <li>Produženje životnog vijeka</li>
                    </ul>
                    <div class="brand-link">
                        Saznajte više
                        <svg class="link-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M5 12h14M12 5l7 7-7 7"/>
                        </svg>
                    </div>
                </div>
            </a>

            <!-- CORTEC -->
            <a href="/cortec" class="brand-card animate-on-scroll">
                <div class="brand-logo-wrapper">
                    <img src="/brand_images/2ird1kix.mfw.png" alt="CORTEC Logo" class="brand-logo" />
                </div>
                <div class="brand-content">
                    <h3>CORTEC</h3>
                    <span class="brand-origin">SAD &bull; od 1973.</span>
                    <p>Napredna rješenja za zaštitu od korozije zasnovana na VpCI tehnologiji. Ekološki prihvatljivi proizvodi.</p>
                    <ul class="brand-products">
                        <li>VpCI tehnologija</li>
                        <li>Zaštita od korozije</li>
                        <li>Inhibitori korozije</li>
                        <li>Ekološka rješenja</li>
                    </ul>
                    <div class="brand-link">
                        Saznajte više
                        <svg class="link-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M5 12h14M12 5l7 7-7 7"/>
                        </svg>
                    </div>
                </div>
            </a>
        </div>
    </div>
</section>

<!-- ====================================================
     SECTION 5: SERVICES
     ==================================================== -->
<section class="services-section">
    <div class="container">
        <div class="section-header animate-on-scroll">
            <span class="section-tag">ŠTO NUDIMO</span>
            <h2 class="section-title">Naše Usluge</h2>
            <p class="section-description">
                Pružamo sveobuhvatna rješenja za sve faze gradnje — od tehničke dokumentacije do ugradnje i savjetovanja.
            </p>
        </div>

        <div class="services-grid">
            <div class="service-card animate-on-scroll">
                <div class="service-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                        <polyline points="9 22 9 12 15 12 15 22"/>
                    </svg>
                </div>
                <h3>Fasadni Sistemi</h3>
                <p>Kompletni ETICS sistemi i dekorativne žbuke za energetski efikasne fasade.</p>
            </div>

            <div class="service-card animate-on-scroll">
                <div class="service-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/>
                        <path d="M12 6v6l4 2"/>
                    </svg>
                </div>
                <h3>Toplinska Izolacija</h3>
                <p>EPS i mineralna vuna rješenja za smanjenje toplinskih gubitaka i energetsku uštedu.</p>
            </div>

            <div class="service-card animate-on-scroll">
                <div class="service-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                        <line x1="16" y1="13" x2="8" y2="13"/>
                        <line x1="16" y1="17" x2="8" y2="17"/>
                    </svg>
                </div>
                <h3>Tehnička Dokumentacija</h3>
                <p>Izrada tehničke specifikacije, proračuna i projektne dokumentacije za vaš objekat.</p>
            </div>

            <div class="service-card animate-on-scroll">
                <div class="service-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 00-3-3.87"/>
                        <path d="M16 3.13a4 4 0 010 7.75"/>
                    </svg>
                </div>
                <h3>Stručno Savjetovanje</h3>
                <p>Individualni pristup svakom projektu uz podršku certificiranih stručnjaka i aplikatora.</p>
            </div>
        </div>
    </div>
</section>

<!-- ====================================================
     SECTION 6: CTA
     ==================================================== -->
<section class="cta-section">
    <div class="container">
        <div class="cta-content animate-on-scroll">
            <h2>Spremni za Novi Projekt?</h2>
            <p>Kontaktirajte nas danas i saznajte kako naši proizvodi mogu unaprijediti vaš projekt.</p>
            <div class="cta-buttons">
                <a href="/contact" class="btn btn-primary">Kontaktirajte Nas</a>
                <a href="/shop" class="btn btn-outline">Web Shop</a>
            </div>
        </div>
    </div>
</section>

<!-- ====================================================
     SECTION 7: FOOTER
     ==================================================== -->
