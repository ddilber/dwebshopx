    <div class="container">
        <div class="footer-grid">
            <!-- Column 1: Company info + social -->
            <div class="footer-col">
                <img src="/images/logo-dark.svg" alt="ASGifiks Logo" style="width:120px; margin-bottom:1rem; filter:brightness(0) invert(1);" />
                <p>
                    Ekskluzivni distributer brendova STO, XYPEX i CORTEC za tržište
                    Bosne i Hercegovine. Profesionalna rješenja za gradnju od 1998.
                </p>
                <div class="footer-social">
                    <a href="https://www.facebook.com" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
                        </svg>
                    </a>
                    <a href="https://www.linkedin.com" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/>
                            <circle cx="4" cy="4" r="2"/>
                        </svg>
                    </a>
                </div>
            </div>

            <!-- Column 2: Quick links -->
            <div class="footer-col">
                <h4>Brze Veze</h4>
                <ul>
                    <li><a href="/about">O nama</a></li>
                    <li><a href="/services">Usluge</a></li>
                    <li><a href="/projects">Projekti</a></li>
                    <li><a href="/contact">Kontakt</a></li>
                </ul>
            </div>

            <!-- Column 3: Web Shop -->
            <div class="footer-col">
                <h4>Web Shop</h4>
                <ul>
                    <li><a href="/sto">STO Proizvodi</a></li>
                    <li><a href="/xypex">XYPEX Proizvodi</a></li>
                    <li><a href="/cortec">CORTEC Proizvodi</a></li>
                    <li><a href="/shop">Svi Proizvodi</a></li>
                </ul>
            </div>

            <!-- Column 4: Contact -->
            <div class="footer-col">
                <h4>Kontakt</h4>
                <ul class="footer-contact">
                    <li>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                            <circle cx="12" cy="10" r="3"/>
                        </svg>
                        <span>Zaobilaznica bb<br />80240 Tomislavgrad<br />Bosna i Hercegovina</span>
                    </li>
                    <li>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.8a19.79 19.79 0 01-3.07-8.67A2 2 0 012 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 8.92a16 16 0 006.17 6.17l1.29-1.29a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
                        </svg>
                        <span>+387 34 000 000</span>
                    </li>
                    <li>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                            <polyline points="22,6 12,13 2,6"/>
                        </svg>
                        <span>info&#64;asgifiks.ba</span>
                    </li>
                </ul>
            </div>
        </div>

        <div class="footer-bottom">
            <span>&copy; @DateTime.Now.Year ASGifiks d.o.o. Sva prava zadržana.</span>
            <div class="footer-links">
                <a href="/privacy">Politika Privatnosti</a>
                <a href="/terms">Uslovi Korištenja</a>
            </div>
        </div>
    </div>
</footer>
