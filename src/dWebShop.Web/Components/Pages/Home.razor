@page "/"
@layout MainLayout

<PageTitle>A&amp;S GIFIKS — Distribucija građevinskih sistema za BiH</PageTitle>
<HeadContent>
    <link rel="canonical" href="https://asgifiks.ba/" />
    <meta property="og:title" content="A&amp;S GIFIKS — Distribucija građevinskih sistema za BiH" />
    <meta property="og:description" content="Ovlašteni distributer STO, XYPEX i CORTEC sistema za BiH. Fasadni sistemi, kristalna hidroizolacija betona i antikorozivna zaštita." />
    <meta property="og:url" content="https://asgifiks.ba/" />
    @Seo.JsonLd(new JsonObject {
        ["@type"] = "Organization",
        ["name"] = "A&S GIFIKS",
        ["alternateName"] = "ASGifiks",
        ["url"] = "https://asgifiks.ba",
        ["logo"] = "https://asgifiks.ba/images/logo.png",
        ["description"] = "Ovlašteni distributer STO, XYPEX i CORTEC sistema za Bosnu i Hercegovinu.",
        ["foundingDate"] = "2008",
        ["address"] = new JsonObject {
            ["@type"] = "PostalAddress",
            ["addressLocality"] = "Tomislavgrad",
            ["addressCountry"] = "BA"
        },
        ["contactPoint"] = new JsonObject {
            ["@type"] = "ContactPoint",
            ["telephone"] = "+387 34 000 000",
            ["email"] = "info@asgifiks.ba",
            ["contactType"] = "sales",
            ["areaServed"] = "BA",
            ["availableLanguage"] = new JsonArray { "Bosanski", "Hrvatski", "Srpski" }
        }
    })
    @Seo.JsonLd(new JsonObject {
        ["@type"] = "LocalBusiness",
        ["name"] = "A&S GIFIKS",
        ["url"] = "https://asgifiks.ba",
        ["image"] = "https://asgifiks.ba/images/asgifiks_building.jpeg",
        ["telephone"] = "+387 34 000 000",
        ["email"] = "info@asgifiks.ba",
        ["priceRange"] = "$$",
        ["address"] = new JsonObject {
            ["@type"] = "PostalAddress",
            ["addressLocality"] = "Tomislavgrad",
            ["addressCountry"] = "BA"
        },
        ["openingHoursSpecification"] = new JsonObject {
            ["@type"] = "OpeningHoursSpecification",
            ["dayOfWeek"] = new JsonArray { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday" },
            ["opens"] = "08:00",
            ["closes"] = "16:00"
        },
        ["areaServed"] = new JsonObject {
            ["@type"] = "Country",
            ["name"] = "Bosnia and Herzegovina"
        }
    })
    @Seo.JsonLd(new JsonObject {
        ["@type"] = "FAQPage",
        ["mainEntity"] = new JsonArray(
            _faqs.Select(f => (JsonNode)new JsonObject {
                ["@type"] = "Question",
                ["name"] = f.Q,
                ["acceptedAnswer"] = new JsonObject {
                    ["@type"] = "Answer",
                    ["text"] = f.A
                }
            }).ToArray()
        )
    })
</HeadContent>

<div class="asg-page">

<!-- ====================================================
     HERO
     ==================================================== -->
<section class="asg-hero">
    <div class="asg-hero-grid asg-wrap">
        <div>
            <div class="asg-hero-eyebrow">
                <span class="b"></span>
                ASGifiks &middot; Distribucija &middot; Tomislavgrad — od 2008
            </div>
            <h1>
                Materijali koji <em>rade</em> generaciju duže od onoga što grade.
            </h1>
        </div>

        <div class="asg-hero-right">
            <p class="asg-hero-lede">
                Ovlašteni smo distributer za <b>STO</b>, <b>XYPEX</b> i <b>CORTEC</b> u Bosni i Hercegovini —
                fasadni sistemi, kristalna hidroizolacija betona i antikorozivna zaštita.
                Ne prodajemo pakovanja, prodajemo trajna rješenja.
            </p>

            <div class="asg-hero-cta">
                <a href="/services" class="asg-btn asg-btn-pri">
                    Pogledaj usluge
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14M13 5l7 7-7 7" />
                    </svg>
                </a>
                <a href="/contact" class="asg-btn asg-btn-sec">Zatraži tehničku konsultaciju</a>
            </div>

            <div class="asg-hero-meta">
                <div><div class="k">Sjedište</div><div class="v">Tomislavgrad</div></div>
                <div><div class="k">Iskustvo</div><div class="v">17 godina</div></div>
                <div><div class="k">Pokrivenost</div><div class="v">Cijela BiH</div></div>
            </div>
        </div>
    </div>

    <div class="asg-hero-figure asg-wrap">
        <div class="asg-ph ph-dark" style="height:520px">
            <img src="/images/asgifiks_building.png
" alt="ASGifiks — fasadni sistemi" style="width:100%;height:100%;object-fit:cover;display:block;" onerror="this.style.display='none'" />
            @* <span>[ hero / objekat sa STO fasadom ]</span> *@
        </div>
        <div class="cap">
            <span class="l">FIG. 01 / 03</span>
            <span class="c"><b>Stambeno-poslovni kompleks</b> — Tomislavgrad &middot; STO ETICS sistem</span>
            <span class="r">2024</span>
        </div>
    </div>
</section>

<!-- ====================================================
     MARQUEE
     ==================================================== -->
<div class="asg-marquee">
    <span><b>STO</b> Njemačka</span>
    <span>&middot;</span>
    <span><b>XYPEX</b> Kanada</span>
    <span>&middot;</span>
    <span><b>CORTEC</b> SAD</span>
    <span>&middot;</span>
    <span>Ovlašteni distributer za <b>BiH</b></span>
    <span>&middot;</span>
    <span>Tomislavgrad — od <b>2008</b></span>
</div>

<!-- ====================================================
     02 BRANDS
     ==================================================== -->
<section class="asg-section">
    <div class="asg-wrap">
        <div class="asg-shead">
            <div class="asg-num">02 — Brendovi</div>
            <div>
                <h2 class="asg-h2">Tri brenda. Tri kontinenta. Jedan standard kvaliteta.</h2>
                <p class="asg-lede">
                    Birali smo partnere po jednom kriteriju — proizvodi koji rade ono što obećavaju, godinama nakon ugradnje.
                </p>
            </div>
        </div>

        <div class="asg-bgrid">
            <a href="/brands/sto" class="asg-bcard">
                <div class="head">
                    <div class="name">STO</div>
                    <div class="origin">Njemačka<br/>od 1955</div>
                </div>
                <div class="asg-ph" style="height:120px;padding:0;overflow:hidden;">
                    <img src="/images/brands/sto-building.svg" alt="STO fasadni sistemi" style="width:100%;height:100%;object-fit:cover;display:block;" onerror="this.style.display='none'" />
                </div>
                <div class="tag">Fasadni sistemi i toplinska izolacija</div>
                <div class="desc">Svjetski lider u fasadnim sistemima i toplinskoj izolaciji. Inovativna rješenja za energetsku efikasnost objekata u skladu sa europskim standardima.</div>
                <div class="more">
                    Saznaj više
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14M13 5l7 7-7 7" />
                    </svg>
                </div>
            </a>

            <a href="/brands/xypex" class="asg-bcard">
                <div class="head">
                    <div class="name">XYPEX</div>
                    <div class="origin">Kanada<br/>od 1969</div>
                </div>
                <div class="asg-ph" style="height:120px;padding:0;overflow:hidden;">
                    <img src="/images/brands/xypex-concrete.svg" alt="XYPEX kristalna hidroizolacija betona" style="width:100%;height:100%;object-fit:cover;display:block;" onerror="this.style.display='none'" />
                </div>
                <div class="tag">Kristalna hidroizolacija betona</div>
                <div class="desc">Revolucionarna kristalna tehnologija koja pretvara beton u trajno hidroizolirani materijal. Aktivira se u kontaktu sa vodom i ponovo zatvara mikropukotine.</div>
                <div class="more">
                    Saznaj više
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14M13 5l7 7-7 7" />
                    </svg>
                </div>
            </a>

            <a href="/brands/cortec" class="asg-bcard">
                <div class="head">
                    <div class="name">CORTEC</div>
                    <div class="origin">SAD<br/>od 1977</div>
                </div>
                <div class="asg-ph" style="height:120px;padding:0;overflow:hidden;">
                    <img src="/images/brands/cortec-overview.svg" alt="CORTEC VpCI antikorozivna zaštita" style="width:100%;height:100%;object-fit:cover;display:block;" onerror="this.style.display='none'" />
                </div>
                <div class="tag">Zaštita od korozije — VpCI tehnologija</div>
                <div class="desc">Globalni lider u zaštiti metala od korozije pomoću isparljivih inhibitora (VpCI) — bez teških metala, ekološki prihvatljivo.</div>
                <div class="more">
                    Saznaj više
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14M13 5l7 7-7 7" />
                    </svg>
                </div>
            </a>
        </div>
    </div>
</section>

<!-- ====================================================
