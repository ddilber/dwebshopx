@page "/services"
@layout MainLayout

<PageTitle>Usluge — A&amp;S GIFIKS</PageTitle>
<HeadContent>
    <link rel="canonical" href="https://asgifiks.ba/services" />
    <meta name="description" content="Usluge ASGifiks — fasadni sistemi, toplinska izolacija, industrijski i epoksidni podovi, hidroizolacija betona, antikorozivna zaštita, tehnička dokumentacija i stručno savjetovanje za cijelu BiH." />
    <meta property="og:title" content="Usluge — A&amp;S GIFIKS" />
    <meta property="og:description" content="Sedam vrsta usluga: fasade, izolacija, industrijski podovi, hidroizolacija, antikorozija, tehnička dokumentacija, stručno savjetovanje." />
    <meta property="og:url" content="https://asgifiks.ba/services" />
</HeadContent>

<div class="asg-page">

<!-- Page header -->
<header class="asg-pageheader">
    <div class="asg-wrap">
        <div class="asg-pageheader-grid">
            <div>
                <div class="asg-eyebrow"><span class="dot"></span>Usluge &middot; Specifikacija &rarr; Isporuka &rarr; Nadzor</div>
                <h1>Materijali i <em>znanje</em> kako ih ugraditi.</h1>
                <p class="asg-lede">Ne prodajemo samo proizvode — pratimo projekat od idejne faze do finalne ugradnje. Sedam područja koja pokrivamo, sa konkretnim isporučivim rezultatima na kraju svake faze.</p>
            </div>
            <div class="asg-pageheader-meta">
                <div><span>Faze projekta</span><b>Spec &rarr; Nabavka &rarr; Ugradnja</b></div>
                <div><span>Prosječni rok</span><b>5–14 dana</b></div>
                <div><span>Tehnička podrška</span><b>Uključeno</b></div>
            </div>
        </div>
    </div>
</header>

<!-- Service detail rows -->
<section class="asg-section">
    <div class="asg-wrap">
        @foreach (var (svc, i) in _services.Select((s, i) => (s, i)))
        {
            <article class="asg-svcdetail">
                <div class="n">/ @((i + 1).ToString("D2"))</div>
                <div>
                    <h3>@svc.Title</h3>
                    <p class="short">@svc.Short</p>
                </div>
                <div>
                    <p class="long">@svc.Long</p>
                    <div class="asg-deliv">
                        <div class="deliv-head">Isporuka</div>
                        @foreach (var d in svc.Deliverables)
                        {
                            <div class="d">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M5 12.5l4.5 4.5L19 7.5" />
                                </svg>
                                <span>@d</span>
                            </div>
                        }
                    </div>
                </div>
            </article>
        }
    </div>
</section>

<!-- Process (dark) -->
<section class="asg-section asg-dark">
    <div class="asg-wrap">
        <div class="asg-shead">
            <div class="asg-num">04 — Proces</div>
            <div>
                <h2 class="asg-h2">Kako radimo.</h2>
                <p class="asg-lede">Četiri faze. Svaka ima jasan input, output i odgovornost.</p>
            </div>
        </div>
        <div class="asg-proc">
            <div class="step">
                <div class="num">01 / Upit</div>
                <h4>Razgovor i obilazak</h4>
                <p>Kratak razgovor o objektu i ciljevima. Po potrebi izlazimo na lokaciju.</p>
            </div>
            <div class="step">
                <div class="num">02 / Spec</div>
                <h4>Tehnička specifikacija</h4>
                <p>Inženjer izrađuje preporuku sistema, proračun količina i orijentacionu cijenu — u 24h.</p>
            </div>
            <div class="step">
                <div class="num">03 / Isporuka</div>
                <h4>Logistika i materijal</h4>
                <p>Iz centralnog skladišta u Tomislavgradu — 2–5 dana ovisno o lokaciji.</p>
            </div>
            <div class="step">
                <div class="num">04 / Nadzor</div>
                <h4>Tehnička podrška</h4>
                <p>Inženjer dostupan tokom ugradnje. Po potrebi obuka aplikatora na licu mjesta.</p>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="asg-section asg-dark asg-tight" style="background:var(--asg-ink); border-top:1px solid rgba(244,241,234,.12);">
    <div class="asg-wrap">
        <div style="display:grid; grid-template-columns:2fr 1fr; gap:64px; align-items:center;">
            <div>
                <h2 style="font-size:clamp(36px,4.5vw,64px); line-height:1; letter-spacing:-.025em; font-weight:700; margin:0; color:var(--asg-paper);">
                    Spreman si <em style="font-style:normal; color:var(--asg-slate);">specificirati</em> sistem?
                </h2>
                <p style="color:rgba(244,241,234,.7); font-size:17px; margin:16px 0 0; max-width:48ch;">
                    Pošalji nam tlocrt, presjek ili samo kratak opis projekta — vraćamo se u 24h sa preporukom materijala i orijentacionom cijenom.
                </p>
            </div>
            <div style="display:flex; flex-direction:column; gap:12px;">
                <a href="/contact" class="asg-btn asg-btn-pri">
                    Pošalji upit
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14M13 5l7 7-7 7" />
                    </svg>
                </a>
                <a href="tel:+38734352050" class="asg-btn asg-btn-sec">+387 34 352 050</a>
            </div>
        </div>
    </div>
</section>

</div>

<style>
    .asg-svcdetail { display: grid; grid-template-columns: 80px 1fr 1.5fr; gap: 48px;
        padding: 48px 0; border-bottom: 1px solid var(--asg-line); align-items: start; }
    .asg-svcdetail .n { font-family: var(--asg-mono); font-size: 13px; letter-spacing: .1em;
        color: var(--asg-accent); font-weight: 600; border-top: 2px solid var(--asg-accent); padding-top: 10px; }
    .asg-svcdetail h3 { font-size: 32px; font-weight: 600; letter-spacing: -.02em; margin: 0 0 16px; line-height: 1.1; }
    .asg-svcdetail .short { font-size: 17px; line-height: 1.5; color: var(--asg-ink); margin: 0; }
    .asg-svcdetail .long { font-size: 15px; color: var(--asg-muted); line-height: 1.7; margin: 0 0 24px; }
    .asg-deliv { display: grid; gap: 0; border-top: 1px solid var(--asg-line); }
    .asg-deliv .deliv-head { padding: 0 0 12px; font-family: var(--asg-mono); font-size: 11px;
        letter-spacing: .1em; text-transform: uppercase; color: var(--asg-muted); border-bottom: 1px solid var(--asg-line); }
    .asg-deliv .d { display: flex; align-items: center; gap: 14px; padding: 14px 0;
        border-bottom: 1px dashed var(--asg-line); font-size: 14px; }
    .asg-deliv .d svg { color: var(--asg-accent); flex-shrink: 0; }

    .asg-proc { display: grid; grid-template-columns: repeat(4,1fr); gap: 32px; }
    .asg-proc .step { padding: 32px 24px 32px 0; border-right: 1px solid rgba(244,241,234,.12); }
    .asg-proc .step:last-child { border-right: none; }
    .asg-proc .num { font-family: var(--asg-mono); font-size: 11px; letter-spacing: .1em;
        color: var(--asg-accent); margin-bottom: 18px; border-top: 2px solid var(--asg-accent);
        padding-top: 10px; display: inline-block; }
    .asg-proc h4 { font-size: 22px; font-weight: 600; color: var(--asg-paper); margin: 0 0 12px; letter-spacing: -.015em; }
    .asg-proc p { font-size: 14px; color: rgba(244,241,234,.6); line-height: 1.5; margin: 0; }

    @@media (max-width: 920px) {
        .asg-svcdetail { grid-template-columns: 1fr; gap: 24px; }
        .asg-proc { grid-template-columns: 1fr 1fr; }
        .asg-proc .step:nth-child(2) { border-right: none; }
    }
    @@media (max-width: 760px) {
        .asg-proc { grid-template-columns: 1fr; }
        .asg-proc .step { border-right: none; border-bottom: 1px solid rgba(244,241,234,.12); padding: 24px 0; }
    }
</style>

@code {
