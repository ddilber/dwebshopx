@page "/services"
@layout MainLayout

<PageTitle>Naše Usluge — ASGifiks</PageTitle>

<div style="padding: 4rem 0; background: linear-gradient(135deg, var(--color-dark) 0%, var(--secondary-color) 100%); color: white;">
    <div class="container">
        <span class="section-tag" style="background: rgba(255,255,255,0.15); color: white;">USLUGE</span>
        <h1 class="section-title" style="color: white; margin-top: 0.75rem;">Naše Usluge</h1>
        <p style="color: rgba(255,255,255,0.8); max-width: 600px; font-size: 1.1rem;">
            Pružamo sveobuhvatna rješenja za sve faze gradnje — od tehničke dokumentacije do ugradnje i savjetovanja.
        </p>
    </div>
</div>

<div class="container" style="padding: 4rem 20px;">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem;">

        <div style="background: var(--color-gray-light); border-radius: var(--border-radius-lg); padding: 2rem; border: 1px solid var(--color-border);">
            <div style="width: 56px; height: 56px; background: var(--color-primary-light); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 1.25rem; color: var(--color-primary);">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="18" rx="2"/><path d="M8 3v18M16 3v18M2 9h20M2 15h20"/></svg>
            </div>
            <h2 style="font-size: 1.1rem; font-weight: 700; color: var(--color-dark); margin: 0 0 0.75rem;">Fasadni Sistemi</h2>
            <p style="color: var(--color-gray); font-size: 0.9rem; line-height: 1.7; margin: 0;">
                Projektovanje i ugradnja kompletnih ETICS fasadnih sistema — od termo-izolacijskih ploča do završnih dekorativnih žbuka.
            </p>
        </div>

        <div style="background: var(--color-gray-light); border-radius: var(--border-radius-lg); padding: 2rem; border: 1px solid var(--color-border);">
            <div style="width: 56px; height: 56px; background: var(--color-primary-light); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 1.25rem; color: var(--color-primary);">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v6M12 22v-6M4.93 4.93l4.24 4.24M14.83 14.83l4.24 4.24M2 12h6M22 12h-6M4.93 19.07l4.24-4.24M14.83 9.17l4.24-4.24"/></svg>
            </div>
            <h2 style="font-size: 1.1rem; font-weight: 700; color: var(--color-dark); margin: 0 0 0.75rem;">Toplinska Izolacija</h2>
            <p style="color: var(--color-gray); font-size: 0.9rem; line-height: 1.7; margin: 0;">
                Savjetovanje i isporuka EPS i mineralne vune izolacijskih materijala za smanjenje toplinskih gubitaka.
            </p>
        </div>

        <div style="background: var(--color-gray-light); border-radius: var(--border-radius-lg); padding: 2rem; border: 1px solid var(--color-border);">
            <div style="width: 56px; height: 56px; background: var(--color-primary-light); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 1.25rem; color: var(--color-primary);">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            </div>
            <h2 style="font-size: 1.1rem; font-weight: 700; color: var(--color-dark); margin: 0 0 0.75rem;">Tehnička Dokumentacija</h2>
            <p style="color: var(--color-gray); font-size: 0.9rem; line-height: 1.7; margin: 0;">
                Izrada tehničke specifikacije, proračuna i projektne dokumentacije za vaš objekat prema europskim standardima.
            </p>
        </div>

        <div style="background: var(--color-gray-light); border-radius: var(--border-radius-lg); padding: 2rem; border: 1px solid var(--color-border);">
            <div style="width: 56px; height: 56px; background: var(--color-primary-light); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 1.25rem; color: var(--color-primary);">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
            </div>
            <h2 style="font-size: 1.1rem; font-weight: 700; color: var(--color-dark); margin: 0 0 0.75rem;">Stručno Savjetovanje</h2>
            <p style="color: var(--color-gray); font-size: 0.9rem; line-height: 1.7; margin: 0;">
                Individualni pristup svakom projektu uz podršku certificiranih stručnjaka, inženjera i ovlaštenih aplikatora.
            </p>
        </div>

    </div>

    <div style="margin-top: 3rem; text-align: center;">
        <a href="/contact" class="btn btn-primary">Zatražite Ponudu</a>
    </div>
</div>
