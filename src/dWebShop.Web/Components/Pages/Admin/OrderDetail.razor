@page "/admin/orders/{GuidStr}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@layout AdminLayout
@rendermode InteractiveServer
@using dWebShop.Application.Features.Orders.Commands
@using dWebShop.Application.Features.Orders.Queries
@using dWebShop.Domain.Entities.Orders
@inject IMediator Mediator

<PageTitle>Order Detail — Admin</PageTitle>

<LoadingSpinner Visible="_loading" />

@if (!_loading)
{
    @if (_order is null)
    {
        <MudAlert Severity="Severity.Error">Order not found.</MudAlert>
        <MudButton Href="/admin/orders" Class="mt-3">Back to Orders</MudButton>
    }
    else
    {
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
            <MudText Typo="Typo.h5">Order #@_order.Guid.ToString()[..8].ToUpper()</MudText>
            <MudSpacer />
            <MudSelect T="OrderStatus"
                       Value="_order.Status"
                       ValueChanged="UpdateStatus"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Label="Status"
                       Style="width:160px;">
                @foreach (var s in Enum.GetValues<OrderStatus>())
                {
                    <MudSelectItem T="OrderStatus" Value="@s">@s</MudSelectItem>
                }
            </MudSelect>
        </MudStack>

        <MudGrid>
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Elevation="1">
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Client</MudText>
                    <MudText Typo="Typo.body2"><strong>@_order.PartnerName</strong></MudText>
                    <MudText Typo="Typo.body2">@_order.PartnerEmail</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Elevation="1">
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Order Info</MudText>
                    <MudText Typo="Typo.body2"><strong>Placed:</strong> @_order.Created.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</MudText>
                    @if (!string.IsNullOrEmpty(_order.DeliveryAddress))
                    {
                        <MudText Typo="Typo.body2"><strong>Delivery:</strong> @_order.DeliveryAddress</MudText>
                    }
                    @if (!string.IsNullOrEmpty(_order.Notes))
                    {
                        <MudText Typo="Typo.body2"><strong>Notes:</strong> @_order.Notes</MudText>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudText Typo="Typo.h6" Class="mt-4 mb-2">Items</MudText>
        <MudTable Items="_order.Items" Dense="true" Outlined="true" Striped="true">
            <HeaderContent>
                <MudTh>Product</MudTh>
                <MudTh>SKU</MudTh>
                <MudTh Style="text-align:right">Unit Price</MudTh>
                <MudTh Style="text-align:center">Qty</MudTh>
                <MudTh Style="text-align:right">Line Total</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.ProductName</MudTd>
                <MudTd><MudText Typo="Typo.caption">@context.SKU</MudText></MudTd>
                <MudTd Style="text-align:right"><PriceDisplay Price="context.Price" PriceTypo="Typo.body2" /></MudTd>
                <MudTd Style="text-align:center">@context.Quantity.ToString("F2")</MudTd>
                <MudTd Style="text-align:right"><PriceDisplay Price="@(context.Price * context.Quantity)" PriceTypo="Typo.body2" /></MudTd>
            </RowTemplate>
            <FooterContent>
                <MudTd colspan="4" Style="text-align:right"><strong>Total</strong></MudTd>
                <MudTd Style="text-align:right">
                    <PriceDisplay Price="@_order.Items.Sum(i => i.Price * i.Quantity)" PriceTypo="Typo.subtitle1" />
                </MudTd>
            </FooterContent>
        </MudTable>

        <MudButton Variant="Variant.Text" Href="/admin/orders" Class="mt-4">← Back to Orders</MudButton>
    }
}

@code {
    [Parameter] public string GuidStr { get; set; } = string.Empty;

    private OrderDetailDto? _order;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        if (Guid.TryParse(GuidStr, out var guid))
            _order = await Mediator.Send(new GetOrderByGuidQuery(guid));
        _loading = false;
    }

    private async Task UpdateStatus(OrderStatus newStatus)
    {
        if (_order is null) return;
        await Mediator.Send(new UpdateOrderStatusCommand(_order.Id, newStatus));
        _order = await Mediator.Send(new GetOrderByGuidQuery(_order.Guid));
    }
}
