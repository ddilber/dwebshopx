@page "/admin/blog"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@layout AdminLayout
@rendermode InteractiveServer
@using dWebShop.Application.Features.Blog.Commands
@using dWebShop.Application.Features.Blog.Queries
@inject IMediator Mediator
@inject ISnackbar Snackbar

<PageTitle>Blog — Admin</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h5">Blog Posts</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Label"
               OnClick="@(() => _tabIndex = 1)" Class="mr-2">Categories &amp; Tags</MudButton>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
               OnClick="OpenCreate">New Post</MudButton>
</MudStack>

<MudTabs @bind-ActivePanelIndex="_tabIndex" Elevation="0">
    <MudTabPanel Text="Posts">
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-3 mb-3" Spacing="2">
            <MudTextField @bind-Value="_search" Placeholder="Search…" Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true" Style="width:260px" />
            <MudSelect @bind-Value="_statusFilter" Label="Status" Style="width:160px">
                <MudSelectItem Value="@((bool?)null)">All</MudSelectItem>
                <MudSelectItem Value="@((bool?)true)">Published</MudSelectItem>
                <MudSelectItem Value="@((bool?)false)">Draft</MudSelectItem>
            </MudSelect>
            <MudButton Variant="Variant.Outlined" OnClick="LoadAsync">Filter</MudButton>
        </MudStack>

        <LoadingSpinner Visible="_loading" />

        @if (!_loading)
        {
            @if (_posts.Count == 0)
            {
                <MudAlert Severity="Severity.Info">No posts found.</MudAlert>
            }
            else
            {
                <MudTable Items="_posts" Dense="true" Hover="true" Striped="true">
                    <HeaderContent>
                        <MudTh>Title</MudTh>
                        <MudTh>Slug</MudTh>
                        <MudTh>Categories</MudTh>
                        <MudTh>Tags</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Date</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.Title</MudTd>
                        <MudTd><MudText Typo="Typo.caption">@context.Slug</MudText></MudTd>
                        <MudTd><MudText Typo="Typo.caption">@string.Join(", ", context.CategoryNames)</MudText></MudTd>
                        <MudTd><MudText Typo="Typo.caption">@string.Join(", ", context.TagNames)</MudText></MudTd>
                        <MudTd>
                            @if (context.Published)
                            {
                                <MudChip T="string" Color="Color.Success" Size="Size.Small">Published</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Color="Color.Default" Size="Size.Small">Draft</MudChip>
                            }
                        </MudTd>
                        <MudTd><MudText Typo="Typo.caption">@context.CreatedDate?.ToString("yyyy-MM-dd")</MudText></MudTd>
                        <MudTd Style="text-align:right">
                            <MudIconButton Icon="@(context.Published ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                           Size="Size.Small" Title="@(context.Published ? "Unpublish" : "Publish")"
                                           OnClick="@(() => TogglePublishedAsync(context))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           OnClick="@(() => OpenEditAsync(context.Id))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                           OnClick="@(() => DeletePostAsync(context))" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        }
    </MudTabPanel>

    <MudTabPanel Text="Categories &amp; Tags">
        <MudGrid Spacing="4" Class="mt-2">
            <!-- Categories -->
            <MudItem xs="12" md="6">
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                    <MudText Typo="Typo.h6">Categories</MudText>
                    <MudSpacer />
                    <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.Add"
                               OnClick="OpenCreateCategory">Add</MudButton>
                </MudStack>
                <MudTable Items="_categories" Dense="true" Hover="true">
                    <HeaderContent>
                        <MudTh>Name</MudTh>
                        <MudTh>Slug</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.Name</MudTd>
                        <MudTd><MudText Typo="Typo.caption">@context.Slug</MudText></MudTd>
                        <MudTd Style="text-align:right">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                           OnClick="@(() => DeleteCategoryAsync(context))" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudItem>

            <!-- Tags -->
            <MudItem xs="12" md="6">
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                    <MudText Typo="Typo.h6">Tags</MudText>
                    <MudSpacer />
                    <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.Add"
                               OnClick="OpenCreateTag">Add</MudButton>
                </MudStack>
                <MudTable Items="_tags" Dense="true" Hover="true">
                    <HeaderContent>
                        <MudTh>Name</MudTh>
                        <MudTh>Slug</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.Name</MudTd>
                        <MudTd><MudText Typo="Typo.caption">@context.Slug</MudText></MudTd>
                        <MudTd Style="text-align:right">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                           OnClick="@(() => DeleteTagAsync(context))" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudItem>
        </MudGrid>
    </MudTabPanel>
</MudTabs>

<!-- Post Dialog -->
<MudDialog @bind-IsVisible="_postDialogOpen"
           Options="@(new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true })">
    <TitleContent>@(_editPostId.HasValue ? "Edit Post" : "New Post")</TitleContent>
    <DialogContent>
        <MudGrid Spacing="3">
            <MudItem xs="12" sm="8">
                <MudTextField @bind-Value="_postForm.Title" Label="Title" Required="true" Class="mb-3"
                              Immediate="true" OnInput="GenerateSlug" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudTextField @bind-Value="_postForm.Slug" Label="Slug" Required="true" Class="mb-3"
                              HelperText="lowercase, hyphens only" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_postForm.Summary" Label="Summary / Excerpt" Lines="2" Class="mb-3" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_postForm.Content" Label="Content (Markdown / HTML)" Lines="10"
                              Class="mb-3" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect T="int" MultiSelection="true" @bind-SelectedValues="_postForm.SelectedCategoryIds"
                           Label="Categories" Class="mb-3">
                    @foreach (var cat in _categories)
                    {
                        <MudSelectItem Value="cat.Id">@cat.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect T="int" MultiSelection="true" @bind-SelectedValues="_postForm.SelectedTagIds"
                           Label="Tags" Class="mb-3">
                    @foreach (var tag in _tags)
                    {
                        <MudSelectItem Value="tag.Id">@tag.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_postForm.MetaTitle" Label="Meta Title" Class="mb-3" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_postForm.MetaDescription" Label="Meta Description" Class="mb-3" />
            </MudItem>
            <MudItem xs="12">
                <MudSwitch @bind-Value="_postForm.Published" Label="Published" Color="Color.Success" />
            </MudItem>
        </MudGrid>
        @if (!string.IsNullOrWhiteSpace(_postErrorMsg))
        {
            <MudAlert Severity="Severity.Error" Class="mt-2">@_postErrorMsg</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _postDialogOpen = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SavePostAsync" Disabled="_saving">
            @(_saving ? "Saving…" : "Save")
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- Category Dialog -->
<MudDialog @bind-IsVisible="_catDialogOpen"
           Options="@(new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true })">
    <TitleContent>New Category</TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_catForm.Name" Label="Name" Required="true" Class="mb-3" />
        <MudTextField @bind-Value="_catForm.Slug" Label="Slug" HelperText="lowercase, hyphens only" Required="true" />
        @if (!string.IsNullOrWhiteSpace(_catErrorMsg))
        {
            <MudAlert Severity="Severity.Error" Class="mt-2">@_catErrorMsg</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _catDialogOpen = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveCategoryAsync" Disabled="_saving">
            @(_saving ? "Saving…" : "Save")
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- Tag Dialog -->
<MudDialog @bind-IsVisible="_tagDialogOpen"
           Options="@(new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true })">
    <TitleContent>New Tag</TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_tagForm.Name" Label="Name" Required="true" Class="mb-3" />
        <MudTextField @bind-Value="_tagForm.Slug" Label="Slug" HelperText="lowercase, hyphens only" Required="true" />
        @if (!string.IsNullOrWhiteSpace(_tagErrorMsg))
        {
            <MudAlert Severity="Severity.Error" Class="mt-2">@_tagErrorMsg</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _tagDialogOpen = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveTagAsync" Disabled="_saving">
            @(_saving ? "Saving…" : "Save")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private int _tabIndex;
    private bool _loading = true;
    private string _search = string.Empty;
    private bool? _statusFilter;

    private List<PostListItemDto> _posts = [];
    private List<PostCategoryDto> _categories = [];
    private List<PostTagDto> _tags = [];

    // Post dialog
    private bool _postDialogOpen;
    private int? _editPostId;
    private bool _saving;
    private string _postErrorMsg = string.Empty;
    private PostFormModel _postForm = new();

    // Category dialog
    private bool _catDialogOpen;
    private string _catErrorMsg = string.Empty;
    private TaxonomyFormModel _catForm = new();

    // Tag dialog
    private bool _tagDialogOpen;
    private string _tagErrorMsg = string.Empty;
    private TaxonomyFormModel _tagForm = new();

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        (_posts, _categories, _tags) = (
            await Mediator.Send(new GetPostsQuery(_statusFilter, string.IsNullOrWhiteSpace(_search) ? null : _search)),
            await Mediator.Send(new GetPostCategoriesQuery()),
            await Mediator.Send(new GetPostTagsQuery()));
        _loading = false;
    }

    // Post CRUD
    private void OpenCreate()
    {
        _editPostId = null;
        _postForm = new();
        _postErrorMsg = string.Empty;
        _postDialogOpen = true;
    }

    private async Task OpenEditAsync(int id)
    {
        var post = await Mediator.Send(new GetPostByIdQuery(id));
        if (post is null) return;
        _editPostId = id;
        _postForm = new PostFormModel
        {
            Title = post.Title,
            MetaTitle = post.MetaTitle,
            Slug = post.Slug,
            Summary = post.Summary,
            Content = post.Content,
            Published = post.Published,
            MetaDescription = post.MetaDescription,
            SelectedCategoryIds = post.Categories.Select(c => c.Id).ToHashSet(),
            SelectedTagIds = post.Tags.Select(t => t.Id).ToHashSet(),
        };
        _postErrorMsg = string.Empty;
        _postDialogOpen = true;
    }

    private void GenerateSlug(ChangeEventArgs e)
    {
        if (_editPostId.HasValue) return; // don't auto-generate when editing
        var title = e.Value?.ToString() ?? string.Empty;
        _postForm.Slug = System.Text.RegularExpressions.Regex.Replace(
            title.ToLowerInvariant().Replace(" ", "-"), "[^a-z0-9-]", string.Empty);
    }

    private async Task SavePostAsync()
    {
        _postErrorMsg = string.Empty;
        if (string.IsNullOrWhiteSpace(_postForm.Title) || string.IsNullOrWhiteSpace(_postForm.Slug))
        {
            _postErrorMsg = "Title and Slug are required.";
            return;
        }

        _saving = true;
        try
        {
            if (_editPostId.HasValue)
                await Mediator.Send(new UpdatePostCommand(
                    _editPostId.Value, _postForm.Title, _postForm.MetaTitle, _postForm.Slug,
                    _postForm.Summary, _postForm.Content, _postForm.Published,
                    _postForm.MetaDescription,
                    _postForm.SelectedCategoryIds.ToList(), _postForm.SelectedTagIds.ToList()));
            else
                await Mediator.Send(new CreatePostCommand(
                    _postForm.Title, _postForm.MetaTitle, _postForm.Slug,
                    _postForm.Summary, _postForm.Content, _postForm.Published,
                    _postForm.MetaDescription,
                    _postForm.SelectedCategoryIds.ToList(), _postForm.SelectedTagIds.ToList()));

            Snackbar.Add(_editPostId.HasValue ? "Post updated." : "Post created.", Severity.Success);
            _postDialogOpen = false;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _postErrorMsg = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task TogglePublishedAsync(PostListItemDto post)
    {
        try
        {
            var nowPublished = await Mediator.Send(new TogglePostPublishedCommand(post.Id));
            Snackbar.Add(nowPublished ? "Post published." : "Post unpublished.", Severity.Info);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task DeletePostAsync(PostListItemDto post)
    {
        try
        {
            await Mediator.Send(new DeletePostCommand(post.Id));
            Snackbar.Add("Post deleted.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    // Category CRUD
    private void OpenCreateCategory()
    {
        _catForm = new();
        _catErrorMsg = string.Empty;
        _catDialogOpen = true;
    }

    private async Task SaveCategoryAsync()
    {
        _catErrorMsg = string.Empty;
        if (string.IsNullOrWhiteSpace(_catForm.Name) || string.IsNullOrWhiteSpace(_catForm.Slug))
        {
            _catErrorMsg = "Name and Slug are required.";
            return;
        }
        _saving = true;
        try
        {
            await Mediator.Send(new CreatePostCategoryCommand(_catForm.Name, _catForm.Slug));
            Snackbar.Add("Category created.", Severity.Success);
            _catDialogOpen = false;
            _categories = await Mediator.Send(new GetPostCategoriesQuery());
        }
        catch (Exception ex) { _catErrorMsg = ex.Message; }
        finally { _saving = false; }
    }

    private async Task DeleteCategoryAsync(PostCategoryDto cat)
    {
        try
        {
            await Mediator.Send(new DeletePostCategoryCommand(cat.Id));
            Snackbar.Add("Category deleted.", Severity.Success);
            _categories = await Mediator.Send(new GetPostCategoriesQuery());
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    // Tag CRUD
    private void OpenCreateTag()
    {
        _tagForm = new();
        _tagErrorMsg = string.Empty;
        _tagDialogOpen = true;
    }

    private async Task SaveTagAsync()
    {
        _tagErrorMsg = string.Empty;
        if (string.IsNullOrWhiteSpace(_tagForm.Name) || string.IsNullOrWhiteSpace(_tagForm.Slug))
        {
            _tagErrorMsg = "Name and Slug are required.";
            return;
        }
        _saving = true;
        try
        {
            await Mediator.Send(new CreatePostTagCommand(_tagForm.Name, _tagForm.Slug));
            Snackbar.Add("Tag created.", Severity.Success);
            _tagDialogOpen = false;
            _tags = await Mediator.Send(new GetPostTagsQuery());
        }
        catch (Exception ex) { _tagErrorMsg = ex.Message; }
        finally { _saving = false; }
    }

    private async Task DeleteTagAsync(PostTagDto tag)
    {
        try
        {
            await Mediator.Send(new DeletePostTagCommand(tag.Id));
            Snackbar.Add("Tag deleted.", Severity.Success);
            _tags = await Mediator.Send(new GetPostTagsQuery());
        }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private class PostFormModel
    {
        public string Title { get; set; } = string.Empty;
        public string MetaTitle { get; set; } = string.Empty;
        public string Slug { get; set; } = string.Empty;
        public string Summary { get; set; } = string.Empty;
        public string Content { get; set; } = string.Empty;
        public bool Published { get; set; }
        public string MetaDescription { get; set; } = string.Empty;
        public IReadOnlyCollection<int> SelectedCategoryIds { get; set; } = new HashSet<int>();
        public IReadOnlyCollection<int> SelectedTagIds { get; set; } = new HashSet<int>();
    }

    private class TaxonomyFormModel
    {
        public string Name { get; set; } = string.Empty;
        public string Slug { get; set; } = string.Empty;
    }
}
