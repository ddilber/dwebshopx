@page "/admin/products/{ProductId:int}/skus"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@layout AdminLayout
@rendermode InteractiveServer
@using dWebShop.Application.Features.Products.Queries
@using dWebShop.Application.Features.ProductSkus.Commands
@using dWebShop.Application.Features.ProductSkus.Queries
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>SKUs — Admin</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-2" />

    <MudText Typo="Typo.h5" Class="mb-4">SKUs: @_productName</MudText>

    <!-- ── Options ──────────────────────────────────────────────────── -->
    <MudText Typo="Typo.h6" Class="mb-2">Product Options</MudText>
    <MudPaper Class="pa-3 mb-4" Elevation="0" Outlined="true">
        @foreach (var opt in _result!.Options)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                <MudChip T="string" Color="Color.Primary">@opt.Name @(opt.IsNamePart ? "(name part)" : "")</MudChip>
                @foreach (var val in opt.Values)
                {
                    <MudChip T="string" Color="Color.Default" Variant="Variant.Outlined" Size="Size.Small">
                        @val.Name
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                       OnClick="@(() => DeleteOptionValueAsync(val.Id))" />
                    </MudChip>
                }
                <MudIconButton Icon="@Icons.Material.Filled.AddCircleOutline" Size="Size.Small" Title="Add value"
                               OnClick="@(() => OpenAddValue(opt.Id))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" Title="Delete option"
                               OnClick="@(() => DeleteOptionAsync(opt.Id))" />
            </MudStack>
        }
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-3" Spacing="2">
            <MudTextField @bind-Value="_newOptionName" Label="New option name (e.g. Size)" Style="max-width:220px" />
            <MudCheckBox @bind-Value="_newOptionIsNamePart" Label="Part of SKU name" />
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Add" OnClick="AddOptionAsync">
                Add Option
            </MudButton>
        </MudStack>
    </MudPaper>

    <!-- ── SKUs ─────────────────────────────────────────────────────── -->
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        <MudText Typo="Typo.h6">SKU List</MudText>
        <MudSpacer />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   OnClick="OpenCreateSku">New SKU</MudButton>
    </MudStack>

    <MudTable Items="_result.Skus" Dense="true" Hover="true" Striped="true">
        <HeaderContent>
            <MudTh>SKU</MudTh>
            <MudTh>Name</MudTh>
            <MudTh>Price</MudTh>
            <MudTh>Tax</MudTh>
            <MudTh>Options</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd><MudText Typo="Typo.caption">@context.SKU</MudText></MudTd>
            <MudTd>@context.Name</MudTd>
            <MudTd>@context.Price.ToString("F2")</MudTd>
            <MudTd>@context.Tax.ToString("F2")</MudTd>
            <MudTd>
                @foreach (var o in context.Options)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Default">@o.OptionName: @o.OptionValueName</MudChip>
                }
            </MudTd>
            <MudTd Style="text-align:right">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEditSku(context))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteSkuAsync(context.Id))" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

<!-- SKU Dialog -->
<MudDialog @bind-IsVisible="_skuDialogOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>@(_editSkuId.HasValue ? "Edit SKU" : "New SKU")</TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_skuForm.SKU" Label="SKU Code" Required="true" Class="mb-3" />
        <MudTextField @bind-Value="_skuForm.Name" Label="Name" Class="mb-3" />
        <MudTextField @bind-Value="_skuForm.ExtRef" Label="External Ref" Class="mb-3" />
        <MudNumericField @bind-Value="_skuForm.Price" Label="Price" Format="F4" Min="0" Class="mb-3" />
        <MudNumericField @bind-Value="_skuForm.Tax" Label="Tax %" Format="F4" Min="0" Class="mb-3" />
        @if (!string.IsNullOrWhiteSpace(_skuError))
        {
            <MudAlert Severity="Severity.Error">@_skuError</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _skuDialogOpen = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveSkuAsync" Disabled="_savingSku">
            @(_savingSku ? "Saving…" : "Save")
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- Add option value dialog -->
<MudDialog @bind-IsVisible="_valueDialogOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true })">
    <TitleContent>Add Option Value</TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_newValueName" Label="Value name" Required="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _valueDialogOpen = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveOptionValueAsync">Add</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int ProductId { get; set; }

    private GetProductSkusResult? _result;
    private string _productName = string.Empty;
    private bool _loading = true;
    private List<BreadcrumbItem> _breadcrumbs = [];

    private bool _skuDialogOpen;
    private int? _editSkuId;
    private bool _savingSku;
    private string _skuError = string.Empty;
    private SkuFormModel _skuForm = new();

    private string _newOptionName = string.Empty;
    private bool _newOptionIsNamePart;

    private bool _valueDialogOpen;
    private int _addValueOptionId;
    private string _newValueName = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var product = await Mediator.Send(new GetProductByIdQuery(ProductId));
        _productName = product?.Name ?? ProductId.ToString();
        _breadcrumbs =
        [
            new BreadcrumbItem("Products", "/admin/products"),
            new BreadcrumbItem(_productName, $"/admin/products/{ProductId}"),
            new BreadcrumbItem("SKUs", null, disabled: true),
        ];
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _result = await Mediator.Send(new GetProductSkusQuery(ProductId));
        _loading = false;
    }

    private void OpenCreateSku()
    {
        _editSkuId = null;
        _skuForm = new();
        _skuError = string.Empty;
        _skuDialogOpen = true;
    }

    private void OpenEditSku(ProductSkuDto sku)
    {
        _editSkuId = sku.Id;
        _skuForm = new SkuFormModel { SKU = sku.SKU, Name = sku.Name, ExtRef = sku.ExtRef, Price = sku.Price, Tax = sku.Tax };
        _skuError = string.Empty;
        _skuDialogOpen = true;
    }

    private async Task SaveSkuAsync()
    {
        _skuError = string.Empty;
        if (string.IsNullOrWhiteSpace(_skuForm.SKU)) { _skuError = "SKU is required."; return; }
        _savingSku = true;
        try
        {
            if (_editSkuId.HasValue)
                await Mediator.Send(new UpdateSkuCommand(_editSkuId.Value, _skuForm.SKU, _skuForm.ExtRef, _skuForm.Name, _skuForm.Price, _skuForm.Tax, null));
            else
                await Mediator.Send(new CreateSkuCommand(ProductId, _skuForm.SKU, _skuForm.ExtRef, _skuForm.Name, _skuForm.Price, _skuForm.Tax, null, null));

            Snackbar.Add(_editSkuId.HasValue ? "SKU updated." : "SKU created.", Severity.Success);
            _skuDialogOpen = false;
            await LoadAsync();
        }
        catch (Exception ex) { _skuError = ex.Message; }
        finally { _savingSku = false; }
    }

    private async Task DeleteSkuAsync(int id)
    {
        try { await Mediator.Send(new DeleteSkuCommand(id)); Snackbar.Add("SKU deleted.", Severity.Success); await LoadAsync(); }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private async Task AddOptionAsync()
    {
        if (string.IsNullOrWhiteSpace(_newOptionName)) return;
        await Mediator.Send(new CreateProductOptionCommand(ProductId, _newOptionName, _newOptionIsNamePart));
        _newOptionName = string.Empty;
        _newOptionIsNamePart = false;
        await LoadAsync();
    }

    private async Task DeleteOptionAsync(int id)
    {
        try { await Mediator.Send(new DeleteProductOptionCommand(id)); await LoadAsync(); }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private void OpenAddValue(int optionId)
    {
        _addValueOptionId = optionId;
        _newValueName = string.Empty;
        _valueDialogOpen = true;
    }

    private async Task SaveOptionValueAsync()
    {
        if (string.IsNullOrWhiteSpace(_newValueName)) return;
        await Mediator.Send(new CreateProductOptionValueCommand(ProductId, _addValueOptionId, _newValueName));
        _valueDialogOpen = false;
        await LoadAsync();
    }

    private async Task DeleteOptionValueAsync(int id)
    {
        try { await Mediator.Send(new DeleteProductOptionValueCommand(id)); await LoadAsync(); }
        catch (Exception ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private class SkuFormModel
    {
        public string SKU { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string ExtRef { get; set; } = string.Empty;
        public decimal Price { get; set; }
        public decimal Tax { get; set; }
    }
}
