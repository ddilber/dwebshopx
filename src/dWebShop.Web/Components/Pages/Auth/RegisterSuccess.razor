@page "/register-success"

<PageTitle>Registration Submitted</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <h2>Registration Submitted</h2>
            <p class="mt-3">Thank you for registering. Your account is pending admin approval. You will receive an email once your account is approved.</p>
            <a href="/login" class="btn btn-primary mt-3">Back to Login</a>
        </div>
    </div>
</div>
