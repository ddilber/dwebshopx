@page "/register"
@layout MainLayout

@using dWebShop.Application.Common.Interfaces
@using dWebShop.Application.Services
@using dWebShop.Domain.Entities.Partners
@using dWebShop.Domain.Entities.Users
@using Microsoft.AspNetCore.Identity
@using Microsoft.Extensions.Configuration

@inject UserManager<ApplicationUser> UserManager
@inject IEmailService EmailService
@inject IConfiguration Configuration
@inject IAppDbContext Db
@inject NavigationManager Navigation

<PageTitle>Registracija — Web Shop</PageTitle>

<div class="asg-login-page">
    <div class="asg-modal" style="max-width:520px">
        <h2>Postanite partner</h2>
        <p>Registrujte se za pristup B2B cijenama, partnerskim rabatima i istoriji narudžbi.</p>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="asg-login-error">@_errorMessage</div>
        }

        <EditForm Model="Input!" FormName="register" OnValidSubmit="HandleRegisterAsync" method="post">
            <DataAnnotationsValidator />

            <div style="display:grid;gap:14px;margin-bottom:20px">

                <div style="font-family:var(--asg-mono);font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--asg-muted);padding-bottom:6px;border-bottom:1px solid var(--asg-line)">Podaci o partneru</div>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">
                    <div class="asg-field">
                        <label for="firstname">Ime</label>
                        <InputText id="firstname" @bind-Value="Input.FirstName" autocomplete="given-name" />
                        <ValidationMessage For="() => Input.FirstName" />
                    </div>
                    <div class="asg-field">
                        <label for="lastname">Prezime</label>
                        <InputText id="lastname" @bind-Value="Input.LastName" autocomplete="family-name" />
                        <ValidationMessage For="() => Input.LastName" />
                    </div>
                </div>

                <div class="asg-field">
                    <label for="company">Naziv firme</label>
                    <InputText id="company" @bind-Value="Input.CompanyName" autocomplete="organization" />
                    <ValidationMessage For="() => Input.CompanyName" />
                </div>

                <div class="asg-field">
                    <label for="phone">Telefon</label>
                    <InputText id="phone" @bind-Value="Input.Phone" type="tel" autocomplete="tel" />
                    <ValidationMessage For="() => Input.Phone" />
                </div>

                <div style="font-family:var(--asg-mono);font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--asg-muted);padding-bottom:6px;border-bottom:1px solid var(--asg-line);margin-top:6px">Podaci za prijavu</div>

                <div class="asg-field">
                    <label for="email">E-mail</label>
                    <InputText id="email" @bind-Value="Input.Email" type="email" autocomplete="email" />
                    <ValidationMessage For="() => Input.Email" />
                </div>
                <div class="asg-field">
                    <label for="password">Lozinka</label>
                    <InputText id="password" @bind-Value="Input.Password" type="password" autocomplete="new-password" />
                    <ValidationMessage For="() => Input.Password" />
                </div>
                <div class="asg-field">
                    <label for="confirm-password">Potvrda lozinke</label>
                    <InputText id="confirm-password" @bind-Value="Input.ConfirmPassword" type="password" autocomplete="new-password" />
                    <ValidationMessage For="() => Input.ConfirmPassword" />
                </div>
            </div>

            <button type="submit" class="asg-btn asg-btn-pri">
                Registruj se
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" style="width:14px;height:14px"><path d="M5 12H19M13 6l6 6-6 6"/></svg>
            </button>
        </EditForm>

        <div class="asg-login-footer">
            Već imate nalog? <a href="/login">Prijavite se</a>
        </div>
    </div>
</div>

@code {
    [CascadingParameter]
    public HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    public RegisterInputModel? Input { get; set; }

    private string? _errorMessage;

    protected override void OnParametersSet()
    {
        Input ??= new();
    }

    private async Task HandleRegisterAsync()
    {
        var partner = new Partner
        {
            FirstName = Input!.FirstName,
            LastName = Input.LastName,
            CompanyName = Input.CompanyName,
            Email = Input.Email,
            Phone = Input.Phone,
            CreatedDate = DateTime.UtcNow
        };
        Db.Partners.Add(partner);
        await Db.SaveChangesAsync();

        var user = new ApplicationUser
        {
            UserName = Input.Email,
            Email = Input.Email,
            IsApproved = false,
            PartnerId = partner.Id
        };

        var result = await UserManager.CreateAsync(user, Input.Password);

        if (result.Succeeded)
        {
            var adminEmail = Configuration["Seed:AdminEmail"] ?? "admin@dwebshop.local";
            try
            {
                await EmailService.SendRegistrationNotificationToAdminAsync(adminEmail, Input.Email, $"{Input.FirstName} {Input.LastName}");
            }
            catch { }

            Navigation.NavigateTo("/register-success", forceLoad: true);
            return;
        }

        // User creation failed — remove the partner row we just inserted
        Db.Partners.Remove(partner);
        await Db.SaveChangesAsync();

        _errorMessage = string.Join("; ", result.Errors.Select(e => e.Description));
    }

    public sealed class RegisterInputModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Ime je obavezno.")]
        [System.ComponentModel.DataAnnotations.StringLength(100)]
        public string FirstName { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Prezime je obavezno.")]
        [System.ComponentModel.DataAnnotations.StringLength(100)]
        public string LastName { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Naziv firme je obavezan.")]
        [System.ComponentModel.DataAnnotations.StringLength(200)]
        public string CompanyName { get; set; } = "";

        [System.ComponentModel.DataAnnotations.StringLength(50)]
        public string Phone { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "E-mail je obavezan.")]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        public string Email { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Lozinka je obavezna.")]
        [System.ComponentModel.DataAnnotations.StringLength(100, MinimumLength = 8)]
        [System.ComponentModel.DataAnnotations.DataType(System.ComponentModel.DataAnnotations.DataType.Password)]
        public string Password { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Potvrda lozinke je obavezna.")]
        [System.ComponentModel.DataAnnotations.Compare(nameof(Password), ErrorMessage = "Lozinke se ne podudaraju.")]
        [System.ComponentModel.DataAnnotations.DataType(System.ComponentModel.DataAnnotations.DataType.Password)]
        public string ConfirmPassword { get; set; } = "";
    }
}
