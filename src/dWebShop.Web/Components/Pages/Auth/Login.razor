@page "/login"
@layout MainLayout

@using dWebShop.Domain.Entities.Users
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Identity

@inject SignInManager<ApplicationUser> SignInManager
@inject NavigationManager Navigation

<PageTitle>Prijava — Web Shop</PageTitle>

<div class="asg-login-page">
    <div class="asg-modal">
        <h2>Prijava partnera</h2>
        <p>Pristupite B2B cijenama, partnerskim rabatima i istoriji narudžbi.</p>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="asg-login-error">@_errorMessage</div>
        }

        <EditForm Model="Input!" FormName="login" OnValidSubmit="HandleLoginAsync" method="post">
            <DataAnnotationsValidator />

            <div style="display:grid;gap:14px;margin-bottom:20px">
                <div class="asg-field">
                    <label for="email">E-mail</label>
                    <InputText id="email" @bind-Value="Input.Email" type="email" autocomplete="username" />
                    <ValidationMessage For="() => Input.Email" />
                </div>
                <div class="asg-field">
                    <label for="password">Lozinka</label>
                    <InputText id="password" @bind-Value="Input.Password" type="password" autocomplete="current-password" />
                    <ValidationMessage For="() => Input.Password" />
                </div>
            </div>

            <button type="submit" class="asg-btn asg-btn-pri">
                Prijavi se
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" style="width:14px;height:14px"><path d="M5 12H19M13 6l6 6-6 6"/></svg>
            </button>
        </EditForm>

        <div class="asg-login-footer">
            Nemate nalog? <a href="/register">Registrujte se</a>
        </div>
    </div>
</div>

@code {
    [CascadingParameter]
    public HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    public LoginInputModel? Input { get; set; }

    private string? _errorMessage;

    protected override void OnParametersSet()
    {
        Input ??= new();
    }

    private async Task HandleLoginAsync()
    {
        await HttpContext.SignOutAsync(IdentityConstants.ExternalScheme);

        var result = await SignInManager.PasswordSignInAsync(
            Input!.Email, Input.Password, isPersistent: false, lockoutOnFailure: false);

        if (result.Succeeded)
        {
            Navigation.NavigateTo("/account", forceLoad: true);
            return;
        }

        if (result.IsNotAllowed)
        {
            _errorMessage = "Vaš nalog čeka odobrenje administratora.";
            return;
        }

        _errorMessage = "Pogrešan e-mail ili lozinka.";
    }

    public sealed class LoginInputModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        public string Email { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.DataType(System.ComponentModel.DataAnnotations.DataType.Password)]
        public string Password { get; set; } = "";
    }
}
