@page "/sto"
@layout LandingLayout

<PageTitle>STO - Fasadni sistemi i toplinska izolacija | ASGifiks</PageTitle>

<!-- ====================================================
     SECTION 1: HERO
     ==================================================== -->
<section class="brand-hero-section" style="--brand-color-from: #00457C; --brand-color-to: #0073CF;">
    <div class="brand-hero-section__content">
        <div class="container">
            <img src="/brand_images/sto-logo.svg" alt="STO Logo" class="brand-hero-section__logo" />
            <h1 class="brand-hero-section__title">Fasadni Sistemi &amp; Izolacija</h1>
            <p style="color: rgba(255,255,255,0.85); font-size: 1.1rem; max-width: 600px; margin: 0 auto 1.5rem;">
                Ekskluzivni distributer STO fasadnih sistema i izolacijskih rješenja za Bosnu i Hercegovinu.
                Inovativne tehnologije za energetski efikasne objekte.
            </p>
            <div class="brand-hero-section__badges">
                <span class="brand-hero-section__badge">&#127465;&#127466; Njema&#269;ka</span>
                <span class="brand-hero-section__badge">Od 1955. godine</span>
                <span class="brand-hero-section__badge">40+ Zemalja</span>
                <span class="brand-hero-section__badge">BiH Ekskluzivni Distributer</span>
            </div>
        </div>
    </div>
</section>

<!-- ====================================================
     SECTION 2: OVERVIEW
     ==================================================== -->
<section class="brand-overview-section">
    <div class="container">
        <div class="brand-overview-section__grid">
            <div>
                <span class="section-tag">O BRENDU</span>
                <h2 class="section-title">O Kompaniji STO</h2>
                <p class="lead-text">
                    STO SE je globalni lider u razvoju i distribuciji fasadnih sistema, boja i premaza
                    te izolacijskih rješenja. Osnovan 1955. godine u Stühlingenu, Njema&#269;ka, STO danas
                    posluje u više od 40 zemalja sa 5.700+ zaposlenika.
                </p>
                <p style="color: var(--color-gray); line-height: 1.8;">
                    Kao ekskluzivni distributer za tržište Bosne i Hercegovine, ASGifiks d.o.o. donosi
                    cjelovitu STO paletu — od ETICS fasadnih sistema do dekorativnih žbuka i premaza
                    sa zaštitnim tehnologijama Lotus-Effect® i Dryonic®.
                </p>

                <div class="brand-overview-section__stats">
                    <div>
                        <div class="brand-overview-section__stat-number">1955</div>
                        <div class="brand-overview-section__stat-label">Godina osnivanja</div>
                    </div>
                    <div>
                        <div class="brand-overview-section__stat-number">5700+</div>
                        <div class="brand-overview-section__stat-label">Zaposlenika</div>
                    </div>
                    <div>
                        <div class="brand-overview-section__stat-number">40+</div>
                        <div class="brand-overview-section__stat-label">Zemalja</div>
                    </div>
                    <div>
                        <div class="brand-overview-section__stat-number">1.6 mlrd</div>
                        <div class="brand-overview-section__stat-label">EUR prihod</div>
                    </div>
                </div>
            </div>

            <div>
                <img src="/images/brands/sto-building.jpg"
                     alt="STO objekat"
                     class="brand-overview-section__image"
                     style="background: linear-gradient(135deg, #00457C22 0%, #0073CF22 100%);" />
            </div>
        </div>
    </div>
</section>

<!-- ====================================================
     SECTION 3: PRODUCTS
     ==================================================== -->
<section class="brand-products-section">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">PROIZVODI</span>
            <h2 class="section-title">STO Asortiman</h2>
            <p class="section-description">
                Kompletan asortiman STO sistema za fasade, izolaciju, žbuke i premaze.
            </p>
        </div>

        <div class="brand-products-section__grid">
            <!-- Fasadni Sistemi -->
            <div class="brand-products-section__card" style="border-top-color: #0073CF;">
                <div style="font-size: 2rem; margin-bottom: 1rem; color: #0073CF;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="2" y="3" width="20" height="18" rx="2"/><path d="M8 3v18M16 3v18M2 9h20M2 15h20"/>
                    </svg>
                </div>
                <h3 class="brand-products-section__card-title">Fasadni Sistemi (ETICS)</h3>
                <p style="color: var(--color-gray); font-size: 0.9rem; margin-bottom: 1rem;">
                    Kompletni sistemi vanjske toplinske izolacije za energetsku sanaciju i novogradnju.
                </p>
                <ul class="brand-products-section__product-list">
                    <li>StoTherm Classic</li>
                    <li>StoTherm Mineral</li>
                    <li>StoTherm Vario</li>
                    <li>StoTherm Wood</li>
                    <li>StoVentec</li>
                    <li>Sto-Systemprofile</li>
                </ul>
            </div>

            <!-- Toplinska Izolacija -->
            <div class="brand-products-section__card" style="border-top-color: #0073CF;">
                <div style="font-size: 2rem; margin-bottom: 1rem; color: #0073CF;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 2v6M12 22v-6M4.93 4.93l4.24 4.24M14.83 14.83l4.24 4.24M2 12h6M22 12h-6M4.93 19.07l4.24-4.24M14.83 9.17l4.24-4.24"/>
                    </svg>
                </div>
                <h3 class="brand-products-section__card-title">Toplinska Izolacija</h3>
                <p style="color: var(--color-gray); font-size: 0.9rem; margin-bottom: 1rem;">
                    EPS ploče i mineralna vuna rješenja za smanjenje toplinskih gubitaka.
                </p>
                <ul class="brand-products-section__product-list">
                    <li>EPS ploče</li>
                    <li>Mineralna vuna</li>
                    <li>StoResolver</li>
                    <li>StoTherm Resol</li>
                    <li>Sokl izolacija</li>
                    <li>Paropropusni slojevi</li>
                </ul>
            </div>

            <!-- Dekorativne Žbuke -->
            <div class="brand-products-section__card" style="border-top-color: #0073CF;">
                <div style="font-size: 2rem; margin-bottom: 1rem; color: #0073CF;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 20h9M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/>
                    </svg>
                </div>
                <h3 class="brand-products-section__card-title">Dekorativne Žbuke</h3>
                <p style="color: var(--color-gray); font-size: 0.9rem; margin-bottom: 1rem;">
                    Visokokvalitetne strukturne žbuke u granulacijama 1.0–3.0 mm, 800+ tonova.
                </p>
                <ul class="brand-products-section__product-list">
                    <li>StoSilco</li>
                    <li>StoSilko</li>
                    <li>StoNival</li>
                    <li>StoCreativ</li>
                    <li>Granulacije 1.0–3.0 mm</li>
                    <li>StoColor System (800+ tonova)</li>
                </ul>
            </div>

            <!-- Boje i Premazi -->
            <div class="brand-products-section__card" style="border-top-color: #0073CF;">
                <div style="font-size: 2rem; margin-bottom: 1rem; color: #0073CF;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M19 4l-7 7-7-7M5 4h14M12 11v9"/>
                    </svg>
                </div>
                <h3 class="brand-products-section__card-title">Boje i Premazi</h3>
                <p style="color: var(--color-gray); font-size: 0.9rem; margin-bottom: 1rem;">
                    Zaštitne boje sa inovativnim Lotus-Effect® i Dryonic® tehnologijama.
                </p>
                <ul class="brand-products-section__product-list">
                    <li>StoColor Silco</li>
                    <li>StoColor Lotusan (Lotus-Effect®)</li>
                    <li>StoColor Maxicryl</li>
                    <li>StoColor Sil Premium</li>
                    <li>StoColor Dryonic®</li>
                    <li>Grundirungen</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<!-- ====================================================
     SECTION 4: TECHNICAL ADVANTAGES
     ==================================================== -->
<section class="technical-section">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">TEHNOLOGIJE</span>
            <h2 class="section-title">Tehni&#269;ke Prednosti</h2>
            <p class="section-description">
                STO inovacije koje postavljaju standarde industrije.
            </p>
        </div>

        <div class="technical-section__grid">
            <div class="technical-section__item">
                <div class="technical-section__icon">⚡</div>
                <h3 class="technical-section__item-title">Energetska Efikasnost</h3>
                <p class="technical-section__item-desc">
                    StoTherm sistemi smanjuju gubitke topline do 60%, značajno snižavajući
                    troškove grijanja i hlađenja objekta.
                </p>
            </div>
            <div class="technical-section__item">
                <div class="technical-section__icon">🌿</div>
                <h3 class="technical-section__item-title">Lotus-Effect®</h3>
                <p class="technical-section__item-desc">
                    Samočisteća površina inspirisana lotusovim listom — voda i prljavština
                    klize s fasade, smanjujući troškove održavanja.
                </p>
            </div>
            <div class="technical-section__item">
                <div class="technical-section__icon">💧</div>
                <h3 class="technical-section__item-title">Dryonic®</h3>
                <p class="technical-section__item-desc">
                    Revolucionarna tehnologija koja odvodi vlagu s fasade kroz kapilarni
                    efekat, zadržavajući površinu trajno suhom.
                </p>
            </div>
            <div class="technical-section__item">
                <div class="technical-section__icon">✅</div>
                <h3 class="technical-section__item-title">ETA Certifikacija</h3>
                <p class="technical-section__item-desc">
                    Svi STO ETICS sistemi posjeduju Europsku tehni&#269;ku ocjenu (ETA),
                    garant vrhunske kvalitete i pouzdanosti.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- ====================================================
     SECTION 5: APPLICATIONS
     ==================================================== -->
<section class="applications-section">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">PRIMJENA</span>
            <h2 class="section-title">Podru&#269;ja Primjene</h2>
            <p class="section-description">
                STO rješenja primjenjuju se na svim vrstama objekata — od stambenih do javnih.
            </p>
        </div>

        <div class="applications-section__grid">
            <div class="applications-section__card">
                <img src="/images/brands/sto-residential.jpg"
                     alt="Stambeni objekti"
                     class="applications-section__card-image"
                     onerror="this.style.background='linear-gradient(135deg,#00457C22,#0073CF44)'; this.style.display='block'; this.removeAttribute('src');" />
                <div class="applications-section__card-body">
                    <h3 class="applications-section__card-title">Stambeni Objekti</h3>
                    <p class="applications-section__card-desc">Fasadna izolacija porodičnih kuća i stambenih zgrada.</p>
                </div>
            </div>
            <div class="applications-section__card">
                <img src="/images/brands/sto-commercial.jpg"
                     alt="Poslovni objekti"
                     class="applications-section__card-image"
                     onerror="this.style.background='linear-gradient(135deg,#00457C22,#0073CF44)'; this.style.display='block'; this.removeAttribute('src');" />
                <div class="applications-section__card-body">
                    <h3 class="applications-section__card-title">Poslovni Objekti</h3>
                    <p class="applications-section__card-desc">Moderna fasadna rješenja za poslovne i komercijalne zgrade.</p>
                </div>
            </div>
            <div class="applications-section__card">
                <img src="/images/brands/sto-public.jpg"
                     alt="Javni objekti"
                     class="applications-section__card-image"
                     onerror="this.style.background='linear-gradient(135deg,#00457C22,#0073CF44)'; this.style.display='block'; this.removeAttribute('src');" />
                <div class="applications-section__card-body">
                    <h3 class="applications-section__card-title">Javni Objekti</h3>
                    <p class="applications-section__card-desc">Škole, bolnice, institucije — dugotrajna zaštita fasade.</p>
                </div>
            </div>
            <div class="applications-section__card">
                <img src="/images/brands/sto-renovation.jpg"
                     alt="Renovacija"
                     class="applications-section__card-image"
                     onerror="this.style.background='linear-gradient(135deg,#00457C22,#0073CF44)'; this.style.display='block'; this.removeAttribute('src');" />
                <div class="applications-section__card-body">
                    <h3 class="applications-section__card-title">Renovacija</h3>
                    <p class="applications-section__card-desc">Energetska sanacija starih objekata i obnova fasada.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ====================================================
     SECTION 6: WHY CHOOSE
     ==================================================== -->
<section class="why-choose-section">
    <div class="container">
        <div class="section-header">
            <span class="section-tag" style="background: rgba(255,255,255,0.15); color: #fff;">ZAŠTO STO</span>
            <h2 class="section-title" style="color: var(--color-white);">Zašto Odabrati STO?</h2>
        </div>

        <div class="why-choose-section__grid">
            <div class="why-choose-section__item">
                <div class="why-choose-section__number">01</div>
                <div>
                    <h3 class="why-choose-section__item-title">70+ Godina Iskustva</h3>
                    <p class="why-choose-section__item-desc">Osnovan 1955. — decenije inovacija i dokazane pouzdanosti u industriji.</p>
                </div>
            </div>
            <div class="why-choose-section__item">
                <div class="why-choose-section__number">02</div>
                <div>
                    <h3 class="why-choose-section__item-title">Certificirani Sistemi</h3>
                    <p class="why-choose-section__item-desc">Svi ETICS sistemi posjeduju ETA certifikate i ispunjavaju EU standarde.</p>
                </div>
            </div>
            <div class="why-choose-section__item">
                <div class="why-choose-section__number">03</div>
                <div>
                    <h3 class="why-choose-section__item-title">Inovativne Tehnologije</h3>
                    <p class="why-choose-section__item-desc">Lotus-Effect® i Dryonic® — patentirane tehnologije samočišćenja i sušenja.</p>
                </div>
            </div>
            <div class="why-choose-section__item">
                <div class="why-choose-section__number">04</div>
                <div>
                    <h3 class="why-choose-section__item-title">Energetska Ušteda</h3>
                    <p class="why-choose-section__item-desc">Dokazano smanjenje troškova grijanja/hlađenja do 60% uz StoTherm sisteme.</p>
                </div>
            </div>
            <div class="why-choose-section__item">
                <div class="why-choose-section__number">05</div>
                <div>
                    <h3 class="why-choose-section__item-title">Lokalna Podrška</h3>
                    <p class="why-choose-section__item-desc">ASGifiks tim pruža tehni&#269;ko savjetovanje i podršku aplikatorima u BiH.</p>
                </div>
            </div>
            <div class="why-choose-section__item">
                <div class="why-choose-section__number">06</div>
                <div>
                    <h3 class="why-choose-section__item-title">Kompletno Rješenje</h3>
                    <p class="why-choose-section__item-desc">Od sidrenih pri&#269;vrša&#269;a do završnih premaza — sve iz jednog izvora.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ====================================================
     SECTION 7: CTA
     ==================================================== -->
<section class="brand-cta-section" style="--brand-color-from: #00457C; --brand-color-to: #0073CF;">
    <div class="container">
        <h2 class="brand-cta-section__title">Zainteresirani za STO Proizvode?</h2>
        <p class="brand-cta-section__desc">
            Kontaktirajte nas za tehni&#269;ke informacije, cijene i projektnu dokumentaciju.
        </p>
        <div class="brand-cta-section__actions">
            <a href="/contact" class="btn btn-light">Kontaktirajte Nas</a>
            <a href="/shop" class="btn btn-outline-light">STO Proizvodi</a>
        </div>
    </div>
</section>

