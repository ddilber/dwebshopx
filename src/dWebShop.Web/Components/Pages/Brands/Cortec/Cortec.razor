@page "/cortec"
@layout LandingLayout

<PageTitle>CORTEC - Zaštita od korozije VpCI tehnologijom | ASGifiks</PageTitle>

<!-- ====================================================
     SECTION 1: HERO
     ==================================================== -->
<section class="brand-hero-section cortec-green">
    <div class="brand-hero-section__content">
        <div class="container">
            <img src="/brand_images/2ird1kix.mfw.png" alt="CORTEC Logo" class="brand-hero-section__logo" />
            <h1 class="brand-hero-section__title">Zaštita od Korozije<br />VpCI Tehnologijom</h1>
            <p style="color: rgba(255,255,255,0.85); font-size: 1.1rem; max-width: 600px; margin: 0 auto 1.5rem;">
                Lider u ekološki prihvatljivim rješenjima za zaštitu metala od korozije.
                VpCI (Vapour phase Corrosion Inhibitor) tehnologija zaštićena u više od 80 zemalja.
            </p>
            <div class="brand-hero-section__badges">
                <span class="brand-hero-section__badge">&#127482;&#127480; SAD</span>
                <span class="brand-hero-section__badge">Od 1973. godine</span>
                <span class="brand-hero-section__badge">80+ Zemalja</span>
                <span class="brand-hero-section__badge">BiH Ekskluzivni Distributer</span>
            </div>
        </div>
    </div>
</section>

<!-- ====================================================
     SECTION 2: OVERVIEW
     ==================================================== -->
<section class="brand-overview-section">
    <div class="container">
        <div class="brand-overview-section__grid">
            <div>
                <span class="section-tag">O BRENDU</span>
                <h2 class="section-title">O Kompaniji CORTEC</h2>
                <p class="lead-text">
                    CORTEC Corporation je ameri&#269;ka kompanija sa sjedištem u St. Paulu, Minnesota,
                    osnovana 1973. godine. Pioniri su u razvoju VpCI (Vapour phase Corrosion Inhibitor)
                    tehnologije — revolucionarnog pristupa zaštiti metala od korozije.
                </p>
                <p style="color: var(--color-gray); line-height: 1.8;">
                    Za razliku od konvencionalnih premaza, VpCI molekule isparavaju i formiraju
                    zaštitni monomolekularni sloj na svim metalnim površinama unutar zatvorenog
                    prostora — uklju&#269;ujući nepristupa&#269;na mjesta i udubine.
                </p>

                <div class="brand-overview-section__stats">
                    <div>
                        <div class="brand-overview-section__stat-number">1973</div>
                        <div class="brand-overview-section__stat-label">Godina osnivanja</div>
                    </div>
                    <div>
                        <div class="brand-overview-section__stat-number">80+</div>
                        <div class="brand-overview-section__stat-label">Zemalja distribucije</div>
                    </div>
                    <div>
                        <div class="brand-overview-section__stat-number">400+</div>
                        <div class="brand-overview-section__stat-label">VpCI proizvoda</div>
                    </div>
                    <div>
                        <div class="brand-overview-section__stat-number">50+</div>
                        <div class="brand-overview-section__stat-label">Godina iskustva</div>
                    </div>
                </div>
            </div>

            <div>
                <div class="brand-overview-section__image"
                     style="background: linear-gradient(135deg, #1a5c2e 0%, #2e8b4a 100%); display: flex; align-items: center; justify-content: center; min-height: 300px; border-radius: var(--border-radius-lg);">
                    <div style="text-align: center; color: white; padding: 2rem;">
                        <div style="font-size: 4rem; margin-bottom: 1rem;">🛡️</div>
                        <div style="font-size: 1.2rem; font-weight: 700;">VpCI® Zaštita</div>
                        <div style="opacity: 0.8; margin-top: 0.5rem;">Isparljivi inhibitori korozije</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

