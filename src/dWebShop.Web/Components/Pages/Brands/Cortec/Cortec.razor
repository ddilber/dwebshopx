<!-- ====================================================
     SECTION 4: ENVIRONMENTAL (CORTEC-SPECIFIC)
     ==================================================== -->
<section class="environmental-section">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">EKOLOGIJA</span>
            <h2 class="section-title">Ekološka Odgovornost</h2>
            <p class="section-description">
                CORTEC je pionir zelene kemije — svi VpCI proizvodi su biorazgradivi i RoHS kompatibilni.
            </p>
        </div>

        <div class="environmental-section__grid">
            <div class="environmental-section__item">
                <div class="cortec-icon" style="font-size: 3rem; margin-bottom: 1rem;">🌱</div>
                <h3 style="font-size: 1.1rem; font-weight: 700; margin-bottom: 0.75rem;">Biorazgradivi Sastojci</h3>
                <p style="font-size: 0.9rem; opacity: 0.85; line-height: 1.6;">
                    VpCI inhibitori bazirani su na prirodnim aminokiselinama i biljnim derivatima,
                    sigurni za okoliš i ljude.
                </p>
            </div>
            <div class="environmental-section__item">
                <div class="cortec-icon" style="font-size: 3rem; margin-bottom: 1rem;">♻️</div>
                <h3 style="font-size: 1.1rem; font-weight: 700; margin-bottom: 0.75rem;">RoHS &amp; REACH Kompatibilnost</h3>
                <p style="font-size: 0.9rem; opacity: 0.85; line-height: 1.6;">
                    Ne sadrže teške metale niti halogene. Ispunjavaju EU direktive o ograničavanju
                    opasnih supstanci.
                </p>
            </div>
            <div class="environmental-section__item">
                <div class="cortec-icon" style="font-size: 3rem; margin-bottom: 1rem;">🏆</div>
                <h3 style="font-size: 1.1rem; font-weight: 700; margin-bottom: 0.75rem;">Zelena Kemija</h3>
                <p style="font-size: 0.9rem; opacity: 0.85; line-height: 1.6;">
