<!-- ====================================================
     SECTION 5: SPECIFICATIONS (XYPEX-SPECIFIC)
     ==================================================== -->
<section class="specifications-section">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">SPECIFIKACIJE</span>
            <h2 class="section-title">Tehni&#269;ke Specifikacije</h2>
            <p class="section-description">
                Dokazane performanse potvrđene me&#273;unarodnim testovima i certifikatima.
            </p>
        </div>

        <div class="specs-grid">
            <div class="spec-card">
                <div class="spec-card__icon" style="color: #2e6db4;">≤</div>
                <h3 class="spec-card__title">Vodonepropusnost</h3>
                <p class="spec-card__desc">Testiran prema DIN 1048 / EN 12390-8</p>
                <div class="spec-card__value">140 m</div>
            </div>
            <div class="spec-card">
                <div class="spec-card__icon" style="color: #2e6db4;">⟳</div>
                <h3 class="spec-card__title">Samozarastanje</h3>
                <p class="spec-card__desc">Automatsko zatvaranje pukotina</p>
                <div class="spec-card__value">do 0.5 mm</div>
            </div>
            <div class="spec-card">
                <div class="spec-card__icon" style="color: #2e6db4;">∞</div>
                <h3 class="spec-card__title">Trajnost</h3>
                <p class="spec-card__desc">Traje koliko i beton sam</p>
                <div class="spec-card__value">Doživotna</div>
            </div>
            <div class="spec-card">
                <div class="spec-card__icon" style="color: #2e6db4;">pH</div>
                <h3 class="spec-card__title">Hemijska Otpornost</h3>
                <p class="spec-card__desc">Široki raspon pH vrijednosti</p>
                <div class="spec-card__value">pH 3–11</div>
            </div>
            <div class="spec-card">
                <div class="spec-card__icon" style="color: #2e6db4;">✓</div>
                <h3 class="spec-card__title">Certifikati</h3>
                <p class="spec-card__desc">Me&#273;unarodne akreditacije</p>
                <div class="spec-card__value" style="font-size: 0.85rem;">NSF/ANSI 61, EN 1504-2</div>
            </div>
            <div class="spec-card">
                <div class="spec-card__icon" style="color: #2e6db4;">♻</div>
                <h3 class="spec-card__title">Održivost</h3>
                <p class="spec-card__desc">Ekološki prihvatljivo rješenje</p>
                <div class="spec-card__value" style="font-size: 0.85rem;">LEED / EPD</div>
            </div>
        </div>
    </div>
</section>

