                <div style="font-size: 2rem; margin-bottom: 1rem; color: #2e6db4;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/>
                    </svg>
                </div>
                <h3 class="brand-products-section__card-title">Popravke i Pribor (Repair)</h3>
                <p style="color: var(--color-gray); font-size: 0.9rem; margin-bottom: 1rem;">
                    Brzovezuju&#263;i materijali za sanaciju aktivnih propuštanja i pukotina.
                </p>
                <ul class="brand-products-section__product-list">
                    <li>Patch'n Plug</li>
                    <li>Megamix Series</li>
                    <li>FCM 80</li>
                    <li>Gamma Cure</li>
                    <li>Xycrylic Admix</li>
                    <li>Quickset</li>
                </ul>
            </div>
