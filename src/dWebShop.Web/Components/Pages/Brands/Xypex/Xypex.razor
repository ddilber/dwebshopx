                <h3 class="brand-products-section__card-title">Aditivi (Admixtures)</h3>
                <p style="color: var(--color-gray); font-size: 0.9rem; margin-bottom: 1rem;">
                    Mješaju se direktno u beton za integralnu hidroizolaciju tokom betoniranja.
                </p>
                <ul class="brand-products-section__product-list">
                    <li>Admix C-Series</li>
                    <li>Admix C-1000 NF</li>
                    <li>Admix C-500 NF</li>
                    <li>Admix C-2000 NF</li>
                    <li>Bio-San C500</li>
                </ul>
            </div>

            <!-- Površinski Premazi -->
            <div class="brand-products-section__card" style="border-top-color: #2e6db4;">
                <div style="font-size: 2rem; margin-bottom: 1rem; color: #2e6db4;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M3 15h18M9 3v18M15 3v18"/>
                    </svg>
                </div>
                <h3 class="brand-products-section__card-title">Površinski Premazi (Coatings)</h3>
                <p style="color: var(--color-gray); font-size: 0.9rem; margin-bottom: 1rem;">
                    Nanose se na svježi ili o&#269;vrsnuli beton za retroaktivnu zaštitu površine.
                </p>
                <ul class="brand-products-section__product-list">
                    <li>Xypex Concentrate</li>
                    <li>Xypex Modified</li>
                </ul>
            </div>

            <!-- Popravke i Pribor -->
