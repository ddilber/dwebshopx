@page "/xypex"
@layout LandingLayout

<PageTitle>XYPEX - Kristalna hidroizolacija betona | ASGifiks</PageTitle>

<!-- ====================================================
     SECTION 1: HERO
     ==================================================== -->
<section class="brand-hero-section" style="--brand-color-from: #1a3c6e; --brand-color-to: #2e6db4;">
    <div class="brand-hero-section__content">
        <div class="container">
            <img src="/brand_images/xypex-logo.svg" alt="XYPEX Logo" class="brand-hero-section__logo" />
            <h1 class="brand-hero-section__title">Concrete Waterproofing<br />by Crystallization™</h1>
            <p style="color: rgba(255,255,255,0.85); font-size: 1.1rem; max-width: 600px; margin: 0 auto 1.5rem;">
                Revolucionarna tehnologija kristalne hidroizolacije betona. Trajna zaštita za temelje,
                tunele, vodoprivredne objekte i industrijsku infrastrukturu.
            </p>
            <div class="brand-hero-section__badges">
                <span class="brand-hero-section__badge">&#127464;&#127462; Kanada</span>
                <span class="brand-hero-section__badge">Od 1969. godine</span>
                <span class="brand-hero-section__badge">90+ Zemalja</span>
                <span class="brand-hero-section__badge">BiH Ekskluzivni Distributer</span>
            </div>
        </div>
    </div>
</section>

<!-- ====================================================
     SECTION 2: OVERVIEW
     ==================================================== -->
<section class="brand-overview-section">
    <div class="container">
        <div class="brand-overview-section__grid">
            <div>
                <span class="section-tag">O BRENDU</span>
                <h2 class="section-title">O Kompaniji XYPEX</h2>
                <p class="lead-text">
                    XYPEX Chemical Corporation je kanadska kompanija osnovana 1969. godine, globalni
                    lider u oblasti kristalne hidroizolacije betona. Njihova patentirana tehnologija
                    koristi se u više od 90 zemalja na najzahtjevnijim infrastrukturnim projektima.
                </p>
                <p style="color: var(--color-gray); line-height: 1.8;">
                    Za razliku od površinskih membrana, XYPEX kemikalije prodiru duboko u beton i
                    formiraju inertne kristale koji trajno blokiraju kapilarnu vodu — &#269;ak i pod
                    negativnim hidrostatskim pritiskom.
                </p>

                <div class="brand-overview-section__stats">
                    <div>
                        <div class="brand-overview-section__stat-number">1969</div>
                        <div class="brand-overview-section__stat-label">Godina osnivanja</div>
                    </div>
                    <div>
                        <div class="brand-overview-section__stat-number">90+</div>
                        <div class="brand-overview-section__stat-label">Zemalja primjene</div>
                    </div>
                    <div>
                        <div class="brand-overview-section__stat-number">10000+</div>
                        <div class="brand-overview-section__stat-label">Projekata</div>
                    </div>
                    <div>
                        <div class="brand-overview-section__stat-number">55+</div>
                        <div class="brand-overview-section__stat-label">Godina iskustva</div>
                    </div>
                </div>
            </div>

            <div>
                <img src="/images/brands/xypex-concrete.jpg"
                     alt="XYPEX kristalizacija betona"
                     class="brand-overview-section__image"
                     style="background: linear-gradient(135deg, #1a3c6e22 0%, #2e6db422 100%);" />
            </div>
        </div>
    </div>
</section>

<!-- ====================================================
     SECTION 3: HOW IT WORKS (XYPEX-SPECIFIC)
     ==================================================== -->
<section class="how-it-works-section">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">TEHNOLOGIJA</span>
            <h2 class="section-title">Kako Djeluje Kristalizacija?</h2>
            <p class="section-description">
                4 koraka od aplikacije do trajne zaštite betona od vode.
            </p>
        </div>

        <div class="how-it-works-section__steps">
            <div class="how-it-works-section__step">
                <div class="how-it-works-section__step-number">01</div>
                <div class="how-it-works-section__step-icon">🖌️</div>
                <h3 class="how-it-works-section__step-title">Aplikacija</h3>
                <p class="how-it-works-section__step-desc">
                    Nanosi se kao premaz na površinu betona ili miješa direktno u betonsku mješavinu.
                </p>
            </div>
            <div class="how-it-works-section__step">
                <div class="how-it-works-section__step-number">02</div>
                <div class="how-it-works-section__step-icon">⚗️</div>
                <h3 class="how-it-works-section__step-title">Hemijska Reakcija</h3>
                <p class="how-it-works-section__step-desc">
                    Aktivne kemikalije reaguju s hidratatcijskim nusproizvodima cementa i vodom u betonu.
                </p>
            </div>
            <div class="how-it-works-section__step">
                <div class="how-it-works-section__step-number">03</div>
                <div class="how-it-works-section__step-icon">🔬</div>
                <h3 class="how-it-works-section__step-title">Formiranje Kristala</h3>
                <p class="how-it-works-section__step-desc">
                    Nerastvorivi kristali rastu unutar kapilarnih pora i mikropukotina, blokirajući vodu.
                </p>
            </div>
            <div class="how-it-works-section__step">
                <div class="how-it-works-section__step-number">04</div>
                <div class="how-it-works-section__step-icon">🛡️</div>
                <h3 class="how-it-works-section__step-title">Trajna Zaštita</h3>
                <p class="how-it-works-section__step-desc">
                    Kristali ostaju dormantni, reakiviraju se pri kontaktu s vodom i zatvore pukotine do 0.5 mm.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- ====================================================
     SECTION 4: PRODUCTS
     ==================================================== -->
<section class="brand-products-section">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">PROIZVODI</span>
            <h2 class="section-title">XYPEX Asortiman</h2>
            <p class="section-description">
                Tri linije XYPEX proizvoda za svaki tip hidroizolacijske primjene.
            </p>
        </div>

        <div class="brand-products-section__grid">
