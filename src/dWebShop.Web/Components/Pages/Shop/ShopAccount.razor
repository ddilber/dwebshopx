@page "/account"
@layout MainLayout
@rendermode InteractiveServer

@using dWebShop.Application.Common.Interfaces
@using dWebShop.Domain.Entities.Partners
@using dWebShop.Domain.Entities.Users
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore

<PageTitle>Moj nalog — Web Shop</PageTitle>

<div class="asg-account">
    <div class="asg-wrap">
        @if (!_initialized)
        {
            <div style="padding:80px 0;color:var(--asg-muted);font-family:var(--asg-mono);font-size:12px;letter-spacing:.1em;text-transform:uppercase">
                Učitavanje...
            </div>
        }
        else if (_user is null)
        {
            <div class="asg-listing-head" style="margin-bottom:32px">
                <div>
                    <h1>Moj nalog</h1>
                    <p class="asg-lede">Prijavite se za pregled vaših narudžbi i partnerskih cijena.</p>
                </div>
            </div>
            <div class="asg-cart-empty">
                <p>Niste prijavljeni.</p>
                <a class="asg-btn asg-btn-pri" href="/login">
                    Prijavi se
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" style="width:14px;height:14px"><path d="M5 12 H19 M13 6 L19 12 L13 18"/></svg>
                </a>
            </div>
        }
        else
        {
            <nav class="asg-shop-crumbs">
                <a href="/shop">Web Shop</a>
                <span class="sep">/</span>
                <span class="cur">Moj nalog</span>
            </nav>

            <div class="asg-listing-head" style="margin-bottom:32px">
                <div>
                    <div class="asg-eyebrow"><span class="dot"></span><span>@_user.PartnerType</span></div>
                    <h1 style="margin-top:12px">Dobrodošli, @_user.Name.Split(' ')[0]</h1>
                    <p class="asg-lede">Pregled vašeg partnerskog naloga, narudžbi i adresa.</p>
                </div>
            </div>

            <div class="asg-account-grid">
                <aside class="asg-account-side">
                    <h3>@_user.Company</h3>
                    <div style="font-size:13px;color:var(--asg-muted)">@_user.Name · @_user.Email</div>
                    <div class="meta">
                        <div><span>Tip naloga</span><b>@_user.PartnerType</b></div>
                        <div><span>Tier</span><b>@_user.Tier</b></div>
                        <div><span>Partner od</span><b>@_user.Since</b></div>
                    </div>
                    <a class="asg-btn asg-btn-sec" href="/logout">Odjava</a>
                </aside>

                <div>
                    <h3 style="font-family:var(--asg-mono);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--asg-muted);margin:0 0 16px;padding-bottom:8px;border-bottom:1px solid var(--asg-line)">
                        Istorija narudžbi
                    </h3>
                    <div class="asg-account-orders">
                        @foreach (var order in ShopData.SampleOrders)
                        {
                            <div class="asg-account-order">
                                <div class="id">
                                    #@order.Id
                                    <small>@order.Date</small>
                                </div>
                                <div class="items">
                                    @foreach (var item in order.Items)
                                    {
                                        <div><b>@item.Qty×</b> @item.Name</div>
                                    }
                                    <div style="margin-top:6px;font-family:var(--asg-mono);font-size:11px;letter-spacing:.05em">@order.Po</div>
                                </div>
                                <div class="status @(order.Status == "Isporučeno" ? "is-delivered" : "is-pending")">@order.Status</div>
                                <div class="total">@ShopData.FmtPrice(order.Total)</div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;
    [Inject] private UserManager<ApplicationUser> UserManager { get; set; } = default!;
    [Inject] private IAppDbContext Db { get; set; } = default!;

    private ShopData.ShopUser? _user;
    private bool _initialized;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState;
        if (!auth.User.Identity?.IsAuthenticated ?? true)
        {
            _initialized = true;
            return;
        }

        var appUser = await UserManager.GetUserAsync(auth.User);
        if (appUser?.PartnerId is { } partnerId)
        {
            var partner = await Db.Partners
                .AsNoTracking()
                .FirstOrDefaultAsync(p => p.Id == partnerId);

            if (partner is not null)
            {
                _user = new ShopData.ShopUser(
                    Name: $"{partner.FirstName} {partner.LastName}",
                    Company: partner.CompanyName,
                    Email: appUser.Email ?? partner.Email,
                    PartnerType: partner.PartnerType,
                    Tier: partner.Tier,
                    Since: partner.CreatedDate?.ToString("yyyy") ?? "—"
                );
            }
        }

        _initialized = true;
    }
}
