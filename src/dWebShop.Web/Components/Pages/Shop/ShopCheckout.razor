@page "/checkout"
@layout MainLayout
@rendermode InteractiveServer
@implements IDisposable
@using dWebShop.Web.Services
@using dWebShop.Application.Features.ShoppingCart.Queries
@using dWebShop.Application.Features.Orders.Commands
@using dWebShop.Application.Features.Profile.Queries
@using MediatR
@using Microsoft.AspNetCore.Components.Web

<PageTitle>B2B Checkout — Web Shop</PageTitle>

@if (!_initialized)
{
    <div class="asg-wrap" style="padding:80px 0;color:var(--asg-muted);font-family:var(--asg-mono);font-size:12px;letter-spacing:.1em;text-transform:uppercase">
        Učitavanje...
    </div>
}
else if (!_isLoggedIn || _cart.Count == 0)
{
    <div class="asg-wrap" style="padding:80px 0">
        <p style="color:var(--asg-muted)">
            @(!_isLoggedIn ? "Prijavite se za nastavak na checkout." : "Vaša korpa je prazna.")
        </p>
        <a href="/cart" class="asg-btn asg-btn-pri" style="margin-top:16px;display:inline-flex">Nazad na korpu</a>
    </div>
}
else
{
    var subtotal = _cart.Sum(i => i.Quantity * i.Price);
    var tax = subtotal * 0.17m;
    var deliveryCost = _delivery == "express" ? 80m : _delivery == "pickup" ? 0m : 45m;
    var total = subtotal + tax + deliveryCost;

    <div class="asg-checkout">
        <div class="asg-wrap">
            <nav class="asg-shop-crumbs">
                <a href="/shop">Web Shop</a><span class="sep">/</span>
                <a href="/cart">Korpa</a><span class="sep">/</span>
                <span class="cur">B2B Checkout</span>
            </nav>

            <div class="asg-listing-head" style="margin-bottom:32px">
                <div>
                    <div class="asg-eyebrow"><span class="dot"></span><span>B2B Narudžba</span></div>
                    <h1 style="margin-top:12px">Završetak narudžbe</h1>
                    <p class="asg-lede">Narudžba se procesuira ručno — naš tim će vam poslati potvrdu sa rokom isporuke u roku od 4h.</p>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(_error))
            {
                <div style="background:#fdecea;border:1px solid #f5c2bd;color:#8a2422;padding:14px 18px;border-radius:6px;margin-bottom:24px;font-size:14px">
                    @_error
                </div>
            }

            <div class="asg-checkout-grid">
                <div>
                    <section class="asg-checkout-section">
                        <h3><span class="num">1</span>Adresa isporuke</h3>
                        @if (_addresses.Count > 0)
                        {
                            <div class="asg-radio-grp">
                                @foreach (var addr in _addresses)
                                {
                                    var a = addr;
                                    <label class="@(_selectedAddressId == a.Id ? "active" : "")">
                                        <input type="radio" name="addr" value="@a.Id"
                                               checked="@(_selectedAddressId == a.Id)"
                                               @onchange="() => _selectedAddressId = a.Id" />
                                        <div style="flex:1">
                                            <div style="font-weight:600">@(string.IsNullOrEmpty(a.Label) ? "Adresa" : a.Label)</div>
                                            <div class="meta">@a.Address1, @a.ZipCode @a.City, @a.Country</div>
                                        </div>
                                    </label>
                                }
                            </div>
                        }
                        else
                        {
                            <p style="color:var(--asg-muted);font-size:13px">
                                Nema sačuvanih adresa. <a href="/account">Dodajte adresu isporuke</a> na profilu.
                            </p>
                        }
                    </section>

                    <section class="asg-checkout-section">
                        <h3><span class="num">2</span>Način isporuke</h3>
                        <div class="asg-radio-grp">
                            @foreach (var opt in _deliveryOptions)
                            {
                                var o = opt;
                                <label class="@(_delivery == o.Val ? "active" : "")">
                                    <input type="radio" name="delivery" value="@o.Val"
                                           checked="@(_delivery == o.Val)"
                                           @onchange="() => _delivery = o.Val" />
                                    <div style="flex:1">
                                        <div style="font-weight:600">@o.Title</div>
                                        <div class="meta">@o.Sub</div>
                                    </div>
                                    <div style="font-family:var(--asg-mono);font-size:12px;font-weight:600">@o.Cost</div>
                                </label>
                            }
                        </div>
                    </section>

                    <section class="asg-checkout-section">
                        <h3><span class="num">3</span>Detalji narudžbe</h3>
                        <div class="asg-form-grid">
                            <div class="asg-field full">
                                <label>Napomena</label>
                                <textarea @bind="_notes" placeholder="Posebne instrukcije, kontakt na lokaciji, PO broj…"></textarea>
                            </div>
                        </div>
                    </section>
                </div>

                <aside class="asg-cart-summary">
                    <h4>Sažetak narudžbe</h4>
                    <div style="display:grid;gap:8px;margin-bottom:12px;padding-bottom:12px;border-bottom:1px dashed var(--asg-line)">
                        @foreach (var it in _cart)
                        {
                            <div style="display:flex;justify-content:space-between;font-size:12px;gap:12px">
                                <span style="flex:1">@it.Name <span style="color:var(--asg-muted)">× @((int)it.Quantity)</span></span>
                                <span style="font-variant-numeric:tabular-nums;font-family:var(--asg-mono)">@ShopFormatting.FmtPrice(it.Quantity * it.Price)</span>
                            </div>
                        }
                    </div>
                    <div class="line"><span>Međuzbir</span><span>@ShopFormatting.FmtPrice(subtotal)</span></div>
                    <div class="line"><span>Dostava</span><span>@(deliveryCost == 0 ? "—" : ShopFormatting.FmtPrice(deliveryCost))</span></div>
                    <div class="line"><span>PDV (17%)</span><span>@ShopFormatting.FmtPrice(tax)</span></div>
                    <div class="line total"><span>Ukupno</span><span>@ShopFormatting.FmtPrice(total)</span></div>
                    <button class="asg-btn asg-btn-pri" @onclick="Submit" disabled="@(_submitting || _partnerId is null)">
                        @(_submitting ? "Slanje..." : "Pošalji narudžbu")
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" style="width:14px;height:14px"><path d="M5 12 H19 M13 6 L19 12 L13 18"/></svg>
                    </button>
                    <div style="font-family:var(--asg-mono);font-size:10px;letter-spacing:.08em;text-transform:uppercase;color:var(--asg-muted);margin-top:14px;text-align:center">
                        Bez online plaćanja · Račun po isporuci
                    </div>
                </aside>
            </div>
        </div>
    </div>
}

@code {
    [Inject] CurrentUser CurrentUser { get; set; } = default!;
    [Inject] IMediator Mediator { get; set; } = default!;
    [Inject] NavigationManager Nav { get; set; } = default!;
    [Inject] PersistentComponentState ApplicationState { get; set; } = default!;

    private List<CartItemDto> _cart = [];
    private List<DeliveryAddressDto> _addresses = [];
    private int? _selectedAddressId;
    private bool _isLoggedIn;
    private bool _initialized;
    private bool _submitting;
    private int? _userId;
    private int? _partnerId;
    private string? _error;

    private string _notes = "";
    private string _delivery = "standard";

    private PersistingComponentStateSubscription _persistSubscription;
    private record PersistedCheckout(List<CartItemDto> Cart, List<DeliveryAddressDto> Addresses);

    private record DeliveryOpt(string Val, string Title, string Sub, string Cost);
    private readonly DeliveryOpt[] _deliveryOptions =
    [
        new("standard", "Standardna isporuka",         "2–5 radnih dana · BiH",            "45.00 KM"),
        new("express",  "Express isporuka",            "24h · samo za stavke na zalihi",   "80.00 KM"),
        new("pickup",   "Preuzimanje u Tomislavgradu", "Skladište · Kralja Tomislava bb",  "Bez naknade"),
    ];

    protected override async Task OnInitializedAsync()
    {
        _persistSubscription = ApplicationState.RegisterOnPersisting(PersistState);
        _isLoggedIn = await CurrentUser.IsAuthenticatedAsync();
        if (_isLoggedIn)
        {
            _userId = await CurrentUser.GetUserIdAsync();
            _partnerId = await CurrentUser.GetPartnerIdAsync();

            if (ApplicationState.TryTakeFromJson<PersistedCheckout>("checkout", out var persisted) && persisted is not null)
            {
                _cart = persisted.Cart;
                _addresses = persisted.Addresses;
                _selectedAddressId = _addresses.FirstOrDefault()?.Id;
            }
            else if (_userId is not null)
            {
                _cart = await Mediator.Send(new GetCartQuery(_userId.Value));
                if (_partnerId is not null)
                {
                    var profile = await Mediator.Send(new GetProfileQuery(_partnerId.Value));
                    if (profile is not null)
                    {
                        _addresses = profile.DeliveryAddresses;
                        _selectedAddressId = _addresses.FirstOrDefault()?.Id;
                    }
                }
            }
        }
        _initialized = true;
    }

    private Task PersistState()
    {
        if (_isLoggedIn)
            ApplicationState.PersistAsJson("checkout", new PersistedCheckout(_cart, _addresses));
        return Task.CompletedTask;
    }

    public void Dispose() => _persistSubscription.Dispose();

    private async Task Submit()
    {
        if (_cart.Count == 0 || !_isLoggedIn || _userId is null || _partnerId is null) return;
        _error = null;
        _submitting = true;
        StateHasChanged();

        try
        {
            var orderGuid = await Mediator.Send(new PlaceOrderCommand(
                UserId: _userId.Value,
                PartnerId: _partnerId.Value,
                DeliveryAddressId: _selectedAddressId,
                Notes: _notes));

            Nav.NavigateTo($"/order-confirmation/{orderGuid}");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _submitting = false;
            StateHasChanged();
        }
    }
}
