@page "/order-confirmation/{orderGuid:guid}"
@layout MainLayout
@rendermode InteractiveServer
@implements IDisposable
@using dWebShop.Web.Services
@using dWebShop.Application.Features.Orders.Queries
@using MediatR
@using Microsoft.AspNetCore.Components.Web

<PageTitle>Narudžba potvrđena — Web Shop</PageTitle>

@if (!_initialized)
{
    <div class="asg-wrap" style="padding:80px 0;color:var(--asg-muted);font-family:var(--asg-mono);font-size:12px;letter-spacing:.1em;text-transform:uppercase">
        Učitavanje...
    </div>
}
else if (_order is null)
{
    <div class="asg-order-conf">
        <div class="asg-wrap">
            <p style="color:var(--asg-muted)">Narudžba nije pronađena. <a href="/shop">Idi na shop</a>.</p>
        </div>
    </div>
}
else
{
    var total = _order.Items.Sum(i => i.Price * i.Quantity);

    <div class="asg-order-conf">
        <div class="asg-wrap">
            <div class="asg-order-conf-card">
                <div class="asg-order-conf-eyebrow">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                         style="width:14px;height:14px;padding:2px;background:var(--asg-accent);color:var(--asg-paper);border-radius:50%">
                        <path d="M5 12 L10 17 L19 7"/>
                    </svg>
                    Narudžba zaprimljena
                </div>
                <h1>Hvala — vaša narudžba je u pripremi.</h1>
                <p>Poslali smo potvrdu na vaš e-mail. Naš tim će vas kontaktirati u roku od 4 radna sata sa potvrđenim rokom isporuke.</p>

                <div class="asg-order-conf-meta">
                    <div><div class="l">Broj narudžbe</div><div class="v">#@_order.Id</div></div>
                    <div><div class="l">Datum</div><div class="v">@_order.Created.ToString("yyyy-MM-dd")</div></div>
                    <div><div class="l">Status</div><div class="v">@_order.Status</div></div>
                    <div><div class="l">Ukupno</div><div class="v">@ShopFormatting.FmtPrice(total)</div></div>
                </div>

                <div class="asg-order-conf-actions">
                    <a href="/account" class="asg-btn asg-btn-pri">
                        Pregledaj narudžbe
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" style="width:14px;height:14px"><path d="M5 12 H19 M13 6 L19 12 L13 18"/></svg>
                    </a>
                    <a href="/shop" class="asg-btn asg-btn-sec">Nastavi kupovinu</a>
                </div>

                <div class="asg-order-conf-next">
                    <h3>Šta slijedi</h3>
                    <div class="asg-order-conf-steps">
                        <div>
                            <span class="num">01</span>
                            <span><b>Potvrda · u roku od 4h</b><br /><span style="color:var(--asg-muted)">Naš tim provjerava dostupnost i šalje potvrđeni rok isporuke.</span></span>
                        </div>
                        <div>
                            <span class="num">02</span>
                            <span><b>Priprema · 1–2 radna dana</b><br /><span style="color:var(--asg-muted)">Roba se priprema u skladištu i izdaje otpremnica.</span></span>
                        </div>
                        <div>
                            <span class="num">03</span>
                            <span><b>Isporuka · 2–5 radnih dana</b><br /><span style="color:var(--asg-muted)">Dostava na navedenu adresu, račun ide poštom ili e-mailom.</span></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Inject] CurrentUser CurrentUser { get; set; } = default!;
    [Inject] IMediator Mediator { get; set; } = default!;
    [Inject] PersistentComponentState ApplicationState { get; set; } = default!;

    [Parameter] public Guid OrderGuid { get; set; }

    private OrderDetailDto? _order;
    private bool _initialized;
    private PersistingComponentStateSubscription _persistSubscription;
    private Guid _loadedGuid;

    protected override void OnInitialized()
    {
        _persistSubscription = ApplicationState.RegisterOnPersisting(PersistState);
    }

    protected override async Task OnParametersSetAsync()
    {
        if (OrderGuid == _loadedGuid && _order is not null) return;
        _loadedGuid = OrderGuid;
        _initialized = false;

        var key = $"order:{OrderGuid}";
        if (ApplicationState.TryTakeFromJson<OrderDetailDto>(key, out var persisted) && persisted is not null)
        {
            _order = persisted;
        }
        else
        {
            var partnerId = await CurrentUser.GetPartnerIdAsync();
            // Scope the lookup to the signed-in partner so a guessed Guid can't
            // reveal another partner's order. Falls through to null if anonymous.
            _order = await Mediator.Send(new GetOrderByGuidQuery(OrderGuid, partnerId));
        }
        _initialized = true;
    }

    private Task PersistState()
    {
        if (_order is not null)
            ApplicationState.PersistAsJson($"order:{OrderGuid}", _order);
        return Task.CompletedTask;
    }

    public void Dispose() => _persistSubscription.Dispose();
}
