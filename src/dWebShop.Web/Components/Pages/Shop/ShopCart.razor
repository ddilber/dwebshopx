@page "/cart"
@layout MainLayout
@rendermode InteractiveServer
@implements IDisposable
@using dWebShop.Web.Services
@using dWebShop.Application.Features.ShoppingCart.Queries
@using dWebShop.Application.Features.ShoppingCart.Commands
@using MediatR
@using Microsoft.AspNetCore.Components.Web

<PageTitle>Korpa — Web Shop</PageTitle>

<div class="asg-cart-page">
    <div class="asg-wrap">
        <nav class="asg-shop-crumbs">
            <a href="/shop">Web Shop</a>
            <span class="sep">/</span>
            <span class="cur">Korpa</span>
        </nav>

        <div class="asg-listing-head" style="margin-bottom:32px">
            <div>
                <div class="asg-eyebrow"><span class="dot"></span><span>Korpa</span></div>
                <h1 style="margin-top:12px">Pregled narudžbe</h1>
                <p class="asg-lede">Provjerite stavke prije nastavka na B2B checkout.</p>
            </div>
            <div class="meta">@_cart.Count @(_cart.Count == 1 ? "stavka" : "stavki")</div>
        </div>

        @if (!_initialized)
        {
            <div style="padding:40px 0;color:var(--asg-muted);font-family:var(--asg-mono);font-size:12px;letter-spacing:.1em;text-transform:uppercase">
                Učitavanje...
            </div>
        }
        else if (!_isLoggedIn)
        {
            <div class="asg-cart-empty">
                <p>Korpa zahtijeva prijavu kao B2B partner.</p>
                <a href="/login?returnUrl=%2Fcart" class="asg-btn asg-btn-pri">
                    Prijavi se
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" style="width:14px;height:14px"><path d="M5 12 H19 M13 6 L19 12 L13 18"/></svg>
                </a>
            </div>
        }
        else if (_cart.Count == 0)
        {
            <div class="asg-cart-empty">
                <p>Vaša korpa je prazna.</p>
                <a href="/shop" class="asg-btn asg-btn-pri">
                    Pregledaj proizvode
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" style="width:14px;height:14px"><path d="M5 12 H19 M13 6 L19 12 L13 18"/></svg>
                </a>
            </div>
        }
        else
        {
            var subtotal = _cart.Sum(i => i.Quantity * i.Price);
            var tax = subtotal * 0.17m;
            var total = subtotal + tax;

            <div class="asg-cart-grid">
                <div class="asg-cart-table">
                    @foreach (var item in _cart)
                    {
                        var it = item;
                        <div class="asg-cart-row">
                            <div class="asg-cart-img"></div>
                            <div class="asg-cart-info">
                                <h5><a href="/shop/p/@it.ProductSlug">@it.Name</a></h5>
                            </div>
                            <div class="asg-cart-qty">
                                <button type="button" @onclick="() => UpdateQty(it, (int)it.Quantity - 1)">−</button>
                                <input value="@((int)it.Quantity)" @onchange="e => UpdateQtyFromInput(it, e.Value?.ToString())" />
                                <button type="button" @onclick="() => UpdateQty(it, (int)it.Quantity + 1)">+</button>
                            </div>
                            <div class="asg-cart-price">
                                @($"{ShopFormatting.FmtPrice(it.Price)}{(string.IsNullOrEmpty(it.Uom) ? "" : $" / {it.Uom}")}")
                            </div>
                            <div class="asg-cart-line">
                                @ShopFormatting.FmtPrice(it.Quantity * it.Price)
                            </div>
                            <button class="asg-cart-rm" @onclick="() => RemoveItem(it)" title="Ukloni">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" style="width:16px;height:16px">
                                    <path d="M5 7 H19 M9 7 V4 H15 V7 M7 7 L8 20 H16 L17 7"/>
                                </svg>
                            </button>
                        </div>
                    }
                </div>

                <aside class="asg-cart-summary">
                    <h4>Sažetak</h4>
                    <div class="line"><span>Međuzbir</span><span>@ShopFormatting.FmtPrice(subtotal)</span></div>
                    <div class="line"><span>PDV (17%)</span><span>@ShopFormatting.FmtPrice(tax)</span></div>
                    <div class="line"><span>Dostava</span><span>Po dogovoru</span></div>
                    <div class="line total"><span>Ukupno</span><span>@ShopFormatting.FmtPrice(total)</span></div>
                    <a href="/checkout" class="asg-btn asg-btn-pri">
                        Nastavi na checkout
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" style="width:14px;height:14px"><path d="M5 12 H19 M13 6 L19 12 L13 18"/></svg>
                    </a>
                    <a href="/shop" class="asg-btn asg-btn-sec" style="margin-top:8px">Nastavi kupovinu</a>
                </aside>
            </div>
        }
    </div>
</div>

@code {
    [Inject] CurrentUser CurrentUser { get; set; } = default!;
    [Inject] IMediator Mediator { get; set; } = default!;
    [Inject] PersistentComponentState ApplicationState { get; set; } = default!;

    private List<CartItemDto> _cart = [];
    private bool _isLoggedIn;
    private bool _initialized;
    private int? _userId;
    private PersistingComponentStateSubscription _persistSubscription;

    protected override async Task OnInitializedAsync()
    {
        _persistSubscription = ApplicationState.RegisterOnPersisting(PersistState);
        _isLoggedIn = await CurrentUser.IsAuthenticatedAsync();
        if (_isLoggedIn)
        {
            _userId = await CurrentUser.GetUserIdAsync();
            // Restore SSR-pass result if present, otherwise hit the DB.
            if (ApplicationState.TryTakeFromJson<List<CartItemDto>>("cart", out var persisted) && persisted is not null)
            {
                _cart = persisted;
            }
            else
            {
                await LoadCart();
            }
        }
        _initialized = true;
    }

    private async Task LoadCart()
    {
        if (_userId is null) return;
        _cart = await Mediator.Send(new GetCartQuery(_userId.Value));
    }

    private Task PersistState()
    {
        if (_isLoggedIn) ApplicationState.PersistAsJson("cart", _cart);
        return Task.CompletedTask;
    }

    public void Dispose() => _persistSubscription.Dispose();

    private async Task UpdateQty(CartItemDto item, int newQty)
    {
        if (_userId is null) return;
        if (newQty <= 0)
        {
            await Mediator.Send(new RemoveCartItemCommand(_userId.Value, item.Id));
        }
        else
        {
            await Mediator.Send(new UpdateCartItemCommand(_userId.Value, item.Id, newQty));
        }
        await LoadCart();
    }

    private async Task UpdateQtyFromInput(CartItemDto item, string? val)
    {
        var qty = int.TryParse(val, out var v) ? Math.Max(1, v) : 1;
        await UpdateQty(item, qty);
    }

    private async Task RemoveItem(CartItemDto item)
    {
        if (_userId is null) return;
        await Mediator.Send(new RemoveCartItemCommand(_userId.Value, item.Id));
        await LoadCart();
    }
}
