@page "/shop/{brand}"
@page "/shop/{brand}/{cat}"
@layout MainLayout
@rendermode InteractiveServer
@implements IDisposable
@using dWebShop.Web.Services
@using Microsoft.AspNetCore.Components.Web

<PageTitle>@_title — Web Shop</PageTitle>

@if (_brand is null)
{
    <div class="asg-wrap" style="padding:80px 0">Brand nije pronađen.</div>
}
else
{
    <div class="asg-shop-listing">
        <div class="asg-wrap">
            <nav class="asg-shop-crumbs">
                <a href="/shop">Web Shop</a>
                <span class="sep">/</span>
                @if (_ancestors.Count == 0)
                {
                    <span class="cur">@_brand.Name</span>
                }
                else
                {
                    <a href="/shop/@Brand">@_brand.Name</a>
                    @for (int i = 0; i < _ancestors.Count; i++)
                    {
                        var anc = _ancestors[i];
                        var isLast = i == _ancestors.Count - 1;
                        <span class="sep">/</span>
                        @if (isLast)
                        {
                            <span class="cur">@anc.Name</span>
                        }
                        else
                        {
                            <a href="/shop/@Brand/@anc.Slug">@anc.Name</a>
                        }
                    }
                }
            </nav>

            <div class="asg-listing-head">
                <div>
                    <div class="asg-eyebrow"><span class="dot"></span>
                        <span>@_brand.Name@(string.IsNullOrEmpty(_brand.Origin) ? "" : $" · {_brand.Origin}")</span>
                    </div>
                    <h1 style="margin-top:12px">@(_category is not null ? _category.Name : $"{_brand.Name} proizvodi")</h1>
                    <p class="asg-lede">@(_category is not null ? _category.Description : _brand.Tagline)</p>
                </div>
                <div class="meta">
                    <div>@_filtered.Count @(_filtered.Count == 1 ? "proizvod" : "proizvoda")</div>
                    @if (!string.IsNullOrEmpty(_brand.Origin) || !string.IsNullOrEmpty(_brand.Since))
                    {
                        <div style="margin-top:6px">@_brand.Origin@(string.IsNullOrEmpty(_brand.Since) ? "" : $" · od {_brand.Since}")</div>
                    }
                </div>
            </div>

            <div class="asg-listing-grid">
                <aside class="asg-filters">
                    @* Category sidebar — drill-down nav, not a multi-select
                       filter. At brand root, show top-level (root) categories.
                       Inside a category, show a "<< parent" back link plus the
                       current category's direct children. The URL is the
                       single source of truth for which category is active. *@
                    <div class="asg-filter-grp">
                        <h5>Shop kategorije</h5>
                        <ul class="asg-cat-nav">
                            @if (_category is null)
                            {
                                @foreach (var root in _cats)
                                {
                                    <li><a href="/shop/@Brand/@root.Slug">▸ @root.Name</a></li>
                                }
                            }
                            else
                            {
                                // Parent link goes back one level. If the
                                // current category is a root (no real parent
                                // in the tree), the back link returns to the
                                // brand landing.
                                var hasParent = _ancestors.Count >= 2;
                                var parentSlug = hasParent ? _ancestors[^2].Slug : null;
                                var parentName = hasParent ? _ancestors[^2].Name : _brand!.Name;
                                var parentUrl = parentSlug is not null
                                    ? $"/shop/{Brand}/{parentSlug}"
                                    : $"/shop/{Brand}";
                                <li><a href="@parentUrl" class="back">« @parentName</a></li>
                                @foreach (var child in _category.Children)
                                {
                                    <li><a href="/shop/@Brand/@child.Slug">▸ @child.Name</a></li>
                                }
                            }
                        </ul>
                    </div>
                    @if (_allTags.Count > 0)
                    {
                        <div class="asg-filter-grp">
                            <h5>Namjena / Tag</h5>
                            <ul>
                                @foreach (var t in _allTags)
                                {
                                    var cnt = _baseProducts.Count(p => p.Tags.Contains(t));
                                    <li>
                                        <label>
                                            <span><input type="checkbox" checked="@_filterTags.Contains(t)"
                                                         @onchange="() => ToggleTag(t)" />@t</span>
                                            <span class="count">@cnt</span>
                                        </label>
                                    </li>
                                }
                            </ul>
                        </div>
                    }
                    @if (_filterTags.Count > 0)
                    {
                        <button class="asg-filter-clear" @onclick="ClearFilters">✕ Očisti filtere</button>
                    }
                </aside>

                <div>
                    <div class="asg-listing-toolbar">
                        <span>@_filtered.Count rezultata</span>
                        <select @bind="_sortBy" @bind:after="ApplyFilters">
                            <option value="default">Sortiraj — Preporučeno</option>
                            <option value="name">Naziv (A–Z)</option>
                            <option value="price-asc">Cijena (rastuće)</option>
                            <option value="price-desc">Cijena (opadajuće)</option>
                        </select>
                    </div>
                    @if (_filtered.Count == 0)
                    {
                        <div style="padding:80px 0;text-align:center;color:var(--asg-muted)">
                            Nema proizvoda po izabranim filterima.
                        </div>
                    }
                    else
                    {
                        <div class="asg-listing-products">
                            @foreach (var p in _filtered)
                            {
                                <ShopProductCard Product="p" IsLoggedIn="_isLoggedIn" />
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Inject] ShopCatalogService Catalog { get; set; } = default!;
    [Inject] CurrentUser CurrentUser { get; set; } = default!;
    [Inject] PersistentComponentState ApplicationState { get; set; } = default!;

    [Parameter] public string Brand { get; set; } = "";
    [Parameter] public string? Cat { get; set; }

    private ShopBrandVm? _brand;
    private ShopCategoryVm? _category;
    private IReadOnlyList<ShopCategoryVm> _cats = [];
    // Path from root to current category (inclusive). Empty when no category
    // is selected. Drives the breadcrumb and the "<< parent" sidebar link.
    private IReadOnlyList<ShopCategoryVm> _ancestors = [];
    private List<ShopProductCardVm> _baseProducts = [];
    private List<ShopProductCardVm> _filtered = [];
    private List<string> _allTags = [];
    private HashSet<string> _filterTags = [];
    private string _sortBy = "default";
    private bool _isLoggedIn;
    private string _title = "Web Shop";
    private PersistingComponentStateSubscription _persistSubscription;
    private string _loadedKey = "";

    private record PersistedBrandPage(
        ShopBrandVm? Brand,
        List<ShopCategoryVm> Cats,
        List<ShopProductCardVm> BaseProducts);

    protected override void OnInitialized()
    {
        _persistSubscription = ApplicationState.RegisterOnPersisting(PersistState);
    }

    protected override async Task OnParametersSetAsync()
    {
        var key = $"brandpage:{Brand}:{Cat ?? ""}";
        if (key == _loadedKey) return;
        _loadedKey = key;

        _isLoggedIn = await CurrentUser.IsAuthenticatedAsync();

        if (ApplicationState.TryTakeFromJson<PersistedBrandPage>(key, out var persisted) && persisted is not null)
        {
            _brand = persisted.Brand;
            _cats = persisted.Cats;
            _category = _cats.FindBySlug(Cat);
            _baseProducts = persisted.BaseProducts;
        }
        else
        {
            var partnerId = _isLoggedIn ? await CurrentUser.GetPartnerIdAsync() : null;

            var brands = await Catalog.GetBrandsAsync();
            _brand = brands.FirstOrDefault(b => string.Equals(b.Slug, Brand, StringComparison.OrdinalIgnoreCase));

            var categoriesByBrand = await Catalog.GetCategoriesByBrandAsync();
            _cats = categoriesByBrand.GetValueOrDefault(Brand, []);
            _category = _cats.FindBySlug(Cat);

            _baseProducts = _brand is null
                ? []
                : (await Catalog.GetProductsAsync(brandSlug: Brand, categorySlug: Cat, partnerId: partnerId)).ToList();
        }

        _ancestors = _cats.AncestorPath(Cat);
        _title = _category?.Name ?? (_brand is not null ? $"{_brand.Name} proizvodi" : "Web Shop");
        _allTags = _baseProducts.SelectMany(p => p.Tags).Distinct().ToList();
        _filterTags.Clear();
        ApplyFilters();
    }

    private Task PersistState()
    {
        ApplicationState.PersistAsJson(_loadedKey, new PersistedBrandPage(
            _brand,
            _cats.ToList(),
            _baseProducts));
        return Task.CompletedTask;
    }

    public void Dispose() => _persistSubscription.Dispose();

    private void ApplyFilters()
    {
        // Category narrowing happens via the URL — the listing service already
        // returns the category subtree's products. Tags are the only sidebar
        // facet remaining.
        var list = _baseProducts.AsEnumerable();
        if (_filterTags.Count > 0) list = list.Where(p => p.Tags.Any(t => _filterTags.Contains(t)));
        list = _sortBy switch
        {
            "price-asc"  => list.OrderBy(p => p.MinPrice ?? decimal.MaxValue),
            "price-desc" => list.OrderByDescending(p => p.MinPrice ?? decimal.MinValue),
            "name"       => list.OrderBy(p => p.Name),
            _            => list,
        };
        _filtered = list.ToList();
    }

    private void ToggleTag(string tag)
    {
        if (!_filterTags.Remove(tag)) _filterTags.Add(tag);
        ApplyFilters();
    }

    private void ClearFilters()
    {
        _filterTags.Clear();
        ApplyFilters();
    }
}
