@page "/shop/{brand}"
@page "/shop/{brand}/{cat}"
@layout MainLayout
@rendermode InteractiveServer

<PageTitle>@_title — Web Shop</PageTitle>

@if (_brand is null)
{
    <div class="asg-wrap" style="padding:80px 0">Brand nije pronađen.</div>
}
else
{
    <div class="asg-shop-listing">
        <div class="asg-wrap">
            <nav class="asg-shop-crumbs">
                <a href="/shop">Web Shop</a>
                <span class="sep">/</span>
                @if (_category is not null)
                {
                    <a href="/shop/@Brand">@_brand.Name</a>
                    <span class="sep">/</span>
                    <span class="cur">@_category.Name</span>
                }
                else
                {
                    <span class="cur">@_brand.Name</span>
                }
            </nav>

            <div class="asg-listing-head">
                <div>
                    <div class="asg-eyebrow"><span class="dot"></span><span>@_brand.Name · @_brand.Origin</span></div>
                    <h1 style="margin-top:12px">@(_category is not null ? _category.Name : $"{_brand.Name} proizvodi")</h1>
                    <p class="asg-lede">@(_category is not null ? _category.Desc : _brand.Tagline)</p>
                </div>
                <div class="meta">
                    <div>@_filtered.Count @(_filtered.Count == 1 ? "proizvod" : "proizvoda")</div>
                    <div style="margin-top:6px">@_brand.Origin · od @_brand.Since</div>
                </div>
            </div>

            <div class="asg-listing-grid">
                <aside class="asg-filters">
                    @if (string.IsNullOrEmpty(Cat) && _cats.Length > 0)
                    {
                        <div class="asg-filter-grp">
                            <h5>Kategorija</h5>
                            <ul>
                                @foreach (var c in _cats)
                                {
                                    var cnt = _baseProducts.Count(p => p.Category == c.Slug);
                                    <li>
                                        <label>
                                            <span><input type="checkbox" checked="@_filterCats.Contains(c.Slug)"
                                                         @onchange="() => ToggleCat(c.Slug)" />@c.Name</span>
                                            <span class="count">@cnt</span>
                                        </label>
                                    </li>
                                }
                            </ul>
                        </div>
                    }
                    @if (_allTags.Count > 0)
                    {
                        <div class="asg-filter-grp">
                            <h5>Namjena / Tag</h5>
                            <ul>
                                @foreach (var t in _allTags)
                                {
                                    var cnt = _baseProducts.Count(p => p.Tags.Contains(t));
                                    <li>
                                        <label>
                                            <span><input type="checkbox" checked="@_filterTags.Contains(t)"
                                                         @onchange="() => ToggleTag(t)" />@t</span>
                                            <span class="count">@cnt</span>
                                        </label>
                                    </li>
                                }
                            </ul>
                        </div>
                    }
                    @if (_filterCats.Count > 0 || _filterTags.Count > 0)
                    {
                        <button class="asg-filter-clear" @onclick="ClearFilters">✕ Očisti filtere</button>
                    }
                </aside>

                <div>
                    <div class="asg-listing-toolbar">
                        <span>@_filtered.Count rezultata</span>
                        <select @bind="_sortBy">
                            <option value="default">Sortiraj — Preporučeno</option>
                            <option value="name">Naziv (A–Z)</option>
                            <option value="price-asc">Cijena (rastuće)</option>
                            <option value="price-desc">Cijena (opadajuće)</option>
                        </select>
                    </div>
                    @if (_filtered.Count == 0)
                    {
                        <div style="padding:80px 0;text-align:center;color:var(--asg-muted)">
                            Nema proizvoda po izabranim filterima.
                        </div>
                    }
                    else
                    {
                        <div class="asg-listing-products">
                            @foreach (var p in _filtered)
                            {
                                <ShopProductCard Product="p" IsLoggedIn="_isLoggedIn" />
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Inject] IJSRuntime JS { get; set; } = default!;

    [Parameter] public string Brand { get; set; } = "";
    [Parameter] public string? Cat { get; set; }

    private ShopData.Brand? _brand;
    private ShopData.Category? _category;
    private ShopData.Category[] _cats = [];
    private List<ShopData.Product> _baseProducts = [];
    private List<ShopData.Product> _filtered = [];
    private List<string> _allTags = [];
    private HashSet<string> _filterCats = [];
    private HashSet<string> _filterTags = [];
    private string _sortBy = "default";
    private bool _isLoggedIn;
    private string _title = "Web Shop";

    protected override void OnParametersSet()
    {
        _brand = ShopData.FindBrand(Brand);
        _category = string.IsNullOrEmpty(Cat) ? null : ShopData.FindCategory(Brand, Cat);
        _cats = ShopData.Categories.GetValueOrDefault(Brand, []);
        _title = _category?.Name ?? (_brand is not null ? $"{_brand.Name} proizvodi" : "Web Shop");

        _baseProducts = ShopData.Products
            .Where(p => p.Brand == Brand && (string.IsNullOrEmpty(Cat) || p.Category == Cat))
            .ToList();

        _allTags = _baseProducts.SelectMany(p => p.Tags).Distinct().ToList();
        _filterCats.Clear();
        _filterTags.Clear();
        ApplyFilters();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var userJson = await JS.InvokeAsync<string>("window.asgShop.getUserJson");
        _isLoggedIn = userJson != "null";
        StateHasChanged();
    }

    private void ApplyFilters()
    {
        var list = _baseProducts.AsEnumerable();
        if (_filterCats.Count > 0) list = list.Where(p => _filterCats.Contains(p.Category));
        if (_filterTags.Count > 0) list = list.Where(p => p.Tags.Any(t => _filterTags.Contains(t)));
        list = _sortBy switch
        {
            "price-asc"  => list.OrderBy(p => p.Skus.Min(s => s.Price)),
            "price-desc" => list.OrderByDescending(p => p.Skus.Min(s => s.Price)),
            "name"       => list.OrderBy(p => p.Name),
            _            => list,
        };
        _filtered = list.ToList();
    }

    private void ToggleCat(string slug)
    {
        if (!_filterCats.Remove(slug)) _filterCats.Add(slug);
        ApplyFilters();
    }

    private void ToggleTag(string tag)
    {
        if (!_filterTags.Remove(tag)) _filterTags.Add(tag);
        ApplyFilters();
    }

    private void ClearFilters()
    {
        _filterCats.Clear();
        _filterTags.Clear();
        ApplyFilters();
    }
}
