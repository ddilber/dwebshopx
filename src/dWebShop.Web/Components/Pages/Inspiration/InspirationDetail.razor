@page "/brands/{brandSlug}/inspiracija/{articleSlug}"
@layout MainLayout
@using MediatR
@using dWebShop.Application.Features.Inspirations.Queries
@inject IMediator Mediator

@if (_item == null)
{
    <PageTitle>Članak nije pronađen — A&amp;S GIFIKS</PageTitle>
    <div class="asg-page" style="padding:120px 0">
        <div class="asg-wrap" style="text-align:center">
            <h2 class="asg-h2">Članak nije pronađen</h2>
            <p class="asg-lede" style="margin-top:16px">
                Vratite se na <a href="/brands/@BrandSlug/inspiracija" style="color:var(--asg-accent)">Inspiraciju</a>.
            </p>
        </div>
    </div>
}
else
{
    <PageTitle>@_item.Title — A&amp;S GIFIKS</PageTitle>

    <article class="asg-page asg-insp-detail">

        <header class="asg-insp-hero">
            <div class="asg-wrap">
                <nav class="asg-shop-crumbs" style="margin-bottom:24px">
                    <a href="/brands">Brendovi</a>
                    <span class="sep">/</span>
                    <a href="/brands/@BrandSlug">@_brandName</a>
                    <span class="sep">/</span>
                    <a href="/brands/@BrandSlug/inspiracija">Inspiracija</a>
                    <span class="sep">/</span>
                    <span class="cur">@_typeInfo.Label</span>
                </nav>

                <div class="asg-insp-hero-eyebrow">
                    <span class="t">@_typeInfo.Label</span>
                    <span>&middot;</span>
                    <span>@_item.PublishedAt</span>
                    <span>&middot;</span>
                    <span>@_item.ReadMin min čitanja</span>
                </div>

                <h1>@_item.Title</h1>
                <p class="asg-insp-hero-lede">@_item.Lede</p>

                <div class="asg-insp-hero-meta">
                    <div>
                        <div class="k">Autor</div>
                        <div class="v">@string.Join(" · ", _item.Authors)</div>
                    </div>
                    <div>
                        <div class="k">Brend</div>
                        <div class="v">@_brandName</div>
                    </div>
                    <div>
                        <div class="k">Tagovi</div>
                        <div class="v" style="display:flex;gap:6px;flex-wrap:wrap">
                            @foreach (var tag in _item.Tags)
                            {
                                <em>@tag</em>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <!-- Hero / cover image -->
        <div class="asg-insp-hero-img-wrap">
            <div class="asg-wrap">
                @if (!string.IsNullOrWhiteSpace(_item.CoverImage))
                {
                    <img src="/@_item.CoverImage" alt="@_item.Title"
                         style="width:100%;height:560px;object-fit:cover;border-radius:4px;display:block;" />
                }
                else
                {
                    <div class="asg-insp-hero-img">[ @_item.HeroLabel ]</div>
                }
            </div>
        </div>

        @{
            // Last non-empty body group renders inside the sidebar grid so the
            // sidebar is alongside body text, not just the endcard.
            int _lastBgIdx = -1;
            for (int _i = _groups.Count - 1; _i >= 0; _i--)
            {
                if (_groups[_i] is BodyGroup { Sections.Count: > 0 }) { _lastBgIdx = _i; break; }
            }
        }

        <!-- Body groups (all except last) interleaved with full-width split blocks -->
        @for (int _gi = 0; _gi < _groups.Count; _gi++)
        {
            var _group = _groups[_gi];
            @if (_group is BodyGroup _bg && _bg.Sections.Count > 0 && _gi != _lastBgIdx)
            {
                <div class="asg-insp-body-narrow">
                    <div class="asg-wrap">
                        <div class="asg-insp-body">
                            @foreach (var s in _bg.Sections)
                            {
                                switch (s.Type)
                                {
                                    case "paragraph":
                                        <p>@s.Text</p>
                                        break;
                                    case "heading":
                                        <h3>@s.Text</h3>
                                        break;
                                    case "bulletlist":
                                        <ul>
                                            @foreach (var li in s.Items ?? [])
                                            {
                                                <li>@li</li>
                                            }
                                        </ul>
                                        break;
                                    case "callout":
                                        <aside class="asg-insp-callout">
                                            <div class="lbl">@s.Label</div>
                                            <p>@s.Text</p>
                                        </aside>
                                        break;
                                }
                            }
                        </div>
                    </div>
                </div>
            }
            else if (_group is SplitGroup _sg)
            {
                var s = _sg.Section;
                var bgStyle = string.IsNullOrWhiteSpace(s.BgColor) ? "" : $"background:{s.BgColor}";
                <div class="asg-insp-split @(s.ImageLeft ? "" : "asg-insp-split--rev")" style="@bgStyle">
                    @if (!string.IsNullOrWhiteSpace(s.Image))
                    {
                        <div class="asg-insp-split-img">
                            <img src="/@s.Image" alt="" />
                        </div>
                    }
                    <div class="asg-insp-split-text">
                        <div class="asg-insp-split-text-inner">
                            @foreach (var para in (s.Text ?? "").Split("\n\n", StringSplitOptions.RemoveEmptyEntries))
                            {
                                <p>@para</p>
                            }
                        </div>
                    </div>
                </div>
            }
        }

        <!-- Gallery -->
        @if (_item.Gallery.Length > 0)
        {
            <div class="asg-insp-gallery">
                <div class="asg-wrap">
                    <div class="asg-insp-gallery-grid">
                        @foreach (var img in _item.Gallery)
                        {
                            <figure class="asg-insp-gallery-item">
                                <img src="/@img.Url" alt="@img.Caption" loading="lazy" />
                                @if (!string.IsNullOrWhiteSpace(img.Caption))
                                {
                                    <figcaption>@img.Caption</figcaption>
                                }
                            </figure>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- Last body group + endcard + sidebar in a 2-column grid -->
        <section class="asg-insp-body-section">
            <div class="asg-wrap">
                <div class="asg-insp-body-grid">
                    <div class="asg-insp-body">
                        @if (_lastBgIdx >= 0 && _groups[_lastBgIdx] is BodyGroup _lastBg)
                        {
                            @foreach (var s in _lastBg.Sections)
                            {
                                switch (s.Type)
                                {
                                    case "paragraph":
                                        <p>@s.Text</p>
                                        break;
                                    case "heading":
                                        <h3>@s.Text</h3>
                                        break;
                                    case "bulletlist":
                                        <ul>
                                            @foreach (var li in s.Items ?? [])
                                            {
                                                <li>@li</li>
                                            }
                                        </ul>
                                        break;
                                    case "callout":
                                        <aside class="asg-insp-callout">
                                            <div class="lbl">@s.Label</div>
                                            <p>@s.Text</p>
                                        </aside>
                                        break;
                                }
                            }
                        }
                        <div class="asg-insp-endcard">
                            <div>
                                <div class="k">Pitanja o konkretnom projektu?</div>
                                <p>Inženjer iz ASGifiks tima može izaći na lokaciju i napraviti specifikaciju sistema bez naknade. Javljamo se isti radni dan.</p>
                            </div>
                            <a href="/contact" class="asg-btn asg-btn-pri">
                                Pošalji upit
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M5 12h14M13 5l7 7-7 7"/>
                                </svg>
                            </a>
                        </div>
                    </div>

                    <aside class="asg-insp-side">
                        @if (_linkedProducts.Count > 0)
                        {
                            <div class="asg-insp-side-block">
                                <h4>Spomenuti proizvodi</h4>
                                <div class="asg-insp-side-products">
                                    @foreach (var p in _linkedProducts)
                                    {
                                        <a href="/shop/p/@p.Slug" class="asg-insp-side-product">
                                            <div class="asg-insp-side-product-img">@p.Name.ToLower()</div>
                                            <div class="asg-insp-side-product-info">
                                                <div class="b">@p.Brand.ToUpper()</div>
                                                <div class="n">@p.Name</div>
                                                <div class="s">@p.Short</div>
                                            </div>
                                        </a>
                                    }
                                </div>
                            </div>
                        }

                        <div class="asg-insp-side-block">
                            <h4>Podijeli članak</h4>
                            <div class="asg-insp-share">
                                <button>LinkedIn</button>
                                <button>Email</button>
                                <button>Kopiraj URL</button>
                            </div>
                        </div>
                    </aside>
                </div>
            </div>
        </section>

        @if (_related.Count > 0)
        {
            <section class="asg-section asg-soft">
                <div class="asg-wrap">
                    <div class="asg-shead">
                        <div class="asg-num">→ Sljedeće čitanje</div>
                        <div><h2 class="asg-h2">Iz iste kategorije.</h2></div>
                    </div>
                    <div class="asg-insp-grid">
                        @foreach (var r in _related)
                        {
                            <InspirationCardComponent BrandSlug="@BrandSlug" Item="@r" Size="std" />
                        }
                    </div>
                </div>
            </section>
        }

    </article>
}

@code {
    [Parameter] public string BrandSlug { get; set; } = "";
    [Parameter] public string ArticleSlug { get; set; } = "";

    private InspirationDetailDto? _item;
    private InspirationData.ContentTypeInfo _typeInfo = InspirationData.Types[Domain.Entities.Inspirations.InspirationContentType.Story];
    private List<InspirationListItemDto> _related = [];
    private List<ShopData.Product> _linkedProducts = [];
    private string _brandName = "";
    private List<SectionGroup> _groups = [];

    private abstract record SectionGroup;
    private record BodyGroup(List<InspirationSectionDto> Sections) : SectionGroup;
    private record SplitGroup(InspirationSectionDto Section) : SectionGroup;

    private static readonly IReadOnlyDictionary<string, string> BrandNames = new Dictionary<string, string>
    {
        ["sto"]    = "STO",
        ["xypex"]  = "XYPEX",
        ["cortec"] = "CORTEC",
    };

    protected override async Task OnParametersSetAsync()
    {
        var brand = BrandSlug?.ToLower() ?? "";
        BrandNames.TryGetValue(brand, out var name);
        _brandName = name ?? brand.ToUpper();

        _item = await Mediator.Send(new GetInspirationBySlugQuery(brand, ArticleSlug ?? ""));
        if (_item == null) return;

        _typeInfo = InspirationData.Types[_item.ContentType];
        _groups = BuildGroups(_item.Sections);

        var allForBrand = await Mediator.Send(new GetPublishedInspirationsByBrandQuery(brand));
        _related = allForBrand
            .Where(x => x.Slug != _item.Slug && x.ContentType == _item.ContentType)
            .Take(3)
            .ToList();

        _linkedProducts = _item.LinkedProductSlugs
            .Select(s => ShopData.Products.FirstOrDefault(p => p.Slug == s))
            .Where(p => p != null)
            .Select(p => p!)
            .ToList();
    }

    private static List<SectionGroup> BuildGroups(InspirationSectionDto[] sections)
    {
        var groups = new List<SectionGroup>();
        var bodyBuffer = new List<InspirationSectionDto>();

        foreach (var s in sections)
        {
            if (s.Type == "split")
            {
                if (bodyBuffer.Count > 0)
                {
                    groups.Add(new BodyGroup(new List<InspirationSectionDto>(bodyBuffer)));
                    bodyBuffer.Clear();
                }
                groups.Add(new SplitGroup(s));
            }
            else
            {
                bodyBuffer.Add(s);
            }
        }

        if (bodyBuffer.Count > 0)
            groups.Add(new BodyGroup(bodyBuffer));

        return groups;
    }
}
