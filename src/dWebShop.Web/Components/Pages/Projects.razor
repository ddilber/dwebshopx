@page "/projects"
@layout MainLayout

<PageTitle>Projekti — A&amp;S GIFIKS</PageTitle>
<HeadContent>
    <link rel="canonical" href="https://asgifiks.ba/projects" />
    <meta name="description" content="Realizovani projekti ASGifiks — stambeni i poslovni objekti, hidroelektrane, javne zgrade i industrijska postrojenja širom BiH." />
    <meta property="og:title" content="Projekti — A&amp;S GIFIKS" />
    <meta property="og:description" content="1.000+ realizovanih projekata sa STO, XYPEX i CORTEC sistemima — od Mostara do Tuzle." />
    <meta property="og:url" content="https://asgifiks.ba/projects" />
</HeadContent>

<div class="asg-page">

<!-- Page header -->
<header class="asg-pageheader">
    <div class="asg-wrap">
        <div class="asg-pageheader-grid">
            <div>
                <div class="asg-eyebrow"><span class="dot"></span>Projekti &middot; 1.000+ realizacija od 1998</div>
                <h1>Šta smo <em>napravili</em>.</h1>
                <p class="asg-lede">Selekcija recentnih projekata — od stambenih kompleksa do industrijskih postrojenja. Svaki je realizovan sa materijalima iz našeg portfelja, uz tehničku podršku tima.</p>
            </div>
            <div class="asg-pageheader-meta">
                <div><span>Ukupno projekata</span><b>1.000+</b></div>
                <div><span>Najveći</span><b>12.000 m²</b></div>
                <div><span>Pokrivenost</span><b>BiH</b></div>
            </div>
        </div>
    </div>
</header>

<!-- Projects grid with filter -->
<section class="asg-section">
    <div class="asg-wrap">
        <div class="asg-pfilt">
            @foreach (var kind in _kinds)
            {
                <button class="@(_filter == kind ? "active" : "")" @onclick="() => _filter = kind">@kind</button>
            }
        </div>

        <div class="asg-pgrid">
            @foreach (var (proj, i) in FilteredProjects.Select((p, i) => (p, i)))
            {
                <article class="asg-prow">
                    <div class="asg-ph" style="height:360px;padding:0;overflow:hidden;">
                        <img src="@proj.Img" alt="@proj.Title" style="width:100%;height:100%;object-fit:cover;display:block;" onerror="this.style.display='none'" />
                    </div>
                    <div class="meta">
                        <span>@proj.Kind / @((i + 1).ToString("D3"))</span>
                        <span>@proj.Year</span>
                    </div>
                    <h3>@proj.Title</h3>
                    <div class="specs">
                        <span><b>Sistem:</b> @proj.Sys</span>
                        <span><b>@proj.Size</b></span>
                    </div>
                </article>
            }
        </div>
    </div>
</section>

<!-- XYPEX REFERENCE TABLE -->
<section class="asg-section asg-soft">
    <div class="asg-wrap">
        <div class="asg-shead">
            <div class="asg-num">XYPEX — Reference</div>
            <div>
                <h2 class="asg-h2">Realizirani XYPEX projekti.</h2>
                <p class="asg-lede">Preko @_xypexRefs.Length realiziranih objekata sa XYPEX kristalnom hidroizolacijom širom Bosne i Hercegovine, 2011.–2026.</p>
            </div>
        </div>

        <div class="asg-xref-controls">
            <input class="asg-xref-search" type="text" placeholder="Pretraži objekt…" @bind="_xSearch" @bind:event="oninput" />
            <select class="asg-xref-select" @bind="_xCity">
                <option value="">Sve lokacije</option>
                @foreach (var c in _xCities)
                {
                    <option value="@c">@c</option>
                }
            </select>
            <select class="asg-xref-select" @bind="_xYear">
                <option value="">Sve godine</option>
                @foreach (var y in _xYears)
                {
                    <option value="@y">@y</option>
                }
            </select>
            <span class="asg-xref-count">@FilteredXrefs.Count() / @_xypexRefs.Length</span>
        </div>

        <div class="asg-xref-tablewrap">
            <table class="asg-xref-table">
                <thead>
                    <tr><th>Objekt</th><th>Lokacija</th><th>Godina</th></tr>
                </thead>
                <tbody>
                    @foreach (var r in FilteredXrefs)
                    {
                        <tr>
                            <td>
                                <span class="obj">@r.Obj</span>
                                @if (!string.IsNullOrEmpty(r.Desc))
                                {
                                    <span class="desc">@r.Desc</span>
                                }
                            </td>
                            <td>@r.City</td>
                            <td class="y">@r.Year</td>
                        </tr>
                    }
                </tbody>
            </table>
            @if (!FilteredXrefs.Any())
            {
                <div class="asg-xref-empty">Nema rezultata za odabrane filtere.</div>
            }
        </div>
    </div>
</section>

<!-- CTA -->
<section class="asg-section asg-dark asg-tight">
    <div class="asg-wrap">
        <div style="display:grid; grid-template-columns:2fr 1fr; gap:64px; align-items:center;">
            <div>
                <h2 style="font-size:clamp(36px,4.5vw,64px); line-height:1; letter-spacing:-.025em; font-weight:700; margin:0; color:var(--asg-paper);">
                    Spreman si <em style="font-style:normal; color:var(--asg-slate);">specificirati</em> sistem?
                </h2>
                <p style="color:rgba(244,241,234,.7); font-size:17px; margin:16px 0 0; max-width:48ch;">
                    Pošalji nam tlocrt, presjek ili samo kratak opis projekta — vraćamo se u 24h.
                </p>
            </div>
            <div style="display:flex; flex-direction:column; gap:12px;">
                <a href="/contact" class="asg-btn asg-btn-pri">
                    Pošalji upit
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14M13 5l7 7-7 7" />
                    </svg>
                </a>
                <a href="tel:+38734352050" class="asg-btn asg-btn-sec">+387 34 352 050</a>
            </div>
        </div>
    </div>
</section>

</div>

<style>
    .asg-ph { background: repeating-linear-gradient(135deg, #e8e3d8 0 14px, rgba(0,0,0,.04) 14px 28px);
        color: rgba(0,0,0,.45); display: flex; align-items: flex-end; padding: 18px;
        font-family: var(--asg-mono); font-size: 11px; letter-spacing: .06em; text-transform: lowercase; }

    .asg-pfilt { display: flex; gap: 0; margin-bottom: 48px; border-bottom: 1px solid var(--asg-line);
        font-family: var(--asg-mono); font-size: 11px; letter-spacing: .1em; text-transform: uppercase; }
    .asg-pfilt button { background: transparent; border: none; padding: 14px 24px 14px 0;
        color: var(--asg-muted); cursor: pointer; font-family: inherit; font-size: inherit;
        letter-spacing: inherit; text-transform: inherit; border-bottom: 2px solid transparent;
        margin-bottom: -1px; transition: all .15s; }
    .asg-pfilt button:hover { color: var(--asg-ink); }
    .asg-pfilt button.active { color: var(--asg-accent); border-bottom-color: var(--asg-accent); }

    .asg-pgrid { display: grid; grid-template-columns: repeat(2,1fr); gap: 48px 32px; }
    .asg-prow { display: grid; grid-template-columns: 1fr; gap: 0; }
    .asg-prow .meta { display: flex; justify-content: space-between; padding: 18px 0 14px;
        border-bottom: 1px dashed var(--asg-line); font-family: var(--asg-mono);
        font-size: 11px; letter-spacing: .1em; text-transform: uppercase; color: var(--asg-muted); }
    .asg-prow h3 { font-size: 24px; font-weight: 600; margin: 18px 0 10px; letter-spacing: -.015em; line-height: 1.2; }
    .asg-prow .specs { display: grid; grid-template-columns: 1fr auto; gap: 16px; font-size: 13px; color: var(--asg-muted); }
    .asg-prow .specs b { color: var(--asg-ink); font-weight: 500; }

    /* XYPEX reference table */
    .asg-xref-controls { display: flex; gap: 12px; flex-wrap: wrap; align-items: center; margin-bottom: 24px; }
    .asg-xref-search, .asg-xref-select { font-family: var(--asg-mono); font-size: 12px; letter-spacing: .04em;
        padding: 10px 14px; border: 1px solid var(--asg-line); background: #fff; color: var(--asg-ink); }
    .asg-xref-search { flex: 1; min-width: 200px; }
    .asg-xref-count { font-family: var(--asg-mono); font-size: 11px; letter-spacing: .1em;
        text-transform: uppercase; color: var(--asg-muted); margin-left: auto; }
    .asg-xref-tablewrap { border-top: 1px solid var(--asg-line); }
    .asg-xref-table { width: 100%; border-collapse: collapse; font-size: 14px; }
    .asg-xref-table th { text-align: left; font-family: var(--asg-mono); font-size: 11px; letter-spacing: .1em;
        text-transform: uppercase; color: var(--asg-muted); padding: 14px 16px 14px 0;
        border-bottom: 1px solid var(--asg-line); font-weight: 500; }
    .asg-xref-table td { padding: 14px 16px 14px 0; border-bottom: 1px solid var(--asg-line);
        color: var(--asg-ink); vertical-align: top; line-height: 1.4; }
    .asg-xref-table td .obj { display: block; font-weight: 500; }
    .asg-xref-table td .desc { display: block; margin-top: 4px; font-size: 13px; color: var(--asg-muted); line-height: 1.45; }
    .asg-xref-table td.y { font-family: var(--asg-mono); font-size: 12px; color: var(--asg-muted); white-space: nowrap; }
    .asg-xref-table tbody tr:hover { background: rgba(0,51,94,.04); }
    .asg-xref-table th:last-child, .asg-xref-table td.y { text-align: right; padding-right: 0; }
    .asg-xref-empty { padding: 32px 0; color: var(--asg-muted); font-size: 14px; }

    @@media (max-width: 760px) {
        .asg-pgrid { grid-template-columns: 1fr; }
        .asg-xref-count { margin-left: 0; width: 100%; }
    }
</style>

