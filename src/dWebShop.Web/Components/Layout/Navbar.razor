@inject NavigationManager Nav

<nav class="asg-nav">
    <a href="/" class="asg-brand">
        <svg class="asg-brand-mark" viewBox="0 0 80 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="A&amp;S Gifiks">
            <path d="M36 30 L54 14 L72 30 L72 50 L62 50 L62 36 L54 36 L54 50 L36 50 Z" fill="#8796b3" />
            <rect x="36" y="50" width="36" height="6" fill="#afb1b0" />
            <rect x="6" y="10" width="40" height="40" stroke="#00335e" stroke-width="7" fill="#f4f1ea" />
        </svg>
        <span class="asg-brand-words">
            <span class="light">A&amp;S</span>
            <span class="bold">GIFIKS</span>
        </span>
        <small>BiH</small>
    </a>

    <ul>
        <li><a href="/" class="@IsActive("/")">Početna</a></li>
        <li><a href="/about" class="@IsActive("/about")">O Nama</a></li>
        <li><a href="/services" class="@IsActive("/services")">Usluge</a></li>
        <li><a href="/projects" class="@IsActive("/projects")">Projekti</a></li>
        <li><a href="/brands" class="@IsActive("/brands")">Brendovi</a></li>
        <li><a href="/shop" class="@IsActive("/shop")">Web Shop</a></li>
        <li><a href="/contact" class="@IsActive("/contact")">Kontakt</a></li>
    </ul>

    <div class="asg-nav-right">
        <div class="asg-nav-utils">
            <a href="/cart" class="asg-cart-btn" title="Korpa">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" style="width:14px;height:14px">
                    <path d="M3 4 H6 L8 17 H20 L22 7 H7"/><circle cx="9" cy="21" r="1.3"/><circle cx="18" cy="21" r="1.3"/>
                </svg>
                <span class="asg-cart-badge" id="asg-cart-badge-count" style="display:none">0</span>
            </a>
            <button class="asg-login-chip" id="asg-login-chip">
                <span class="dot"></span>
                <span id="asg-login-chip-label">Prijava</span>
            </button>
        </div>
        <a href="/contact" class="asg-nav-cta">
            Zatraži ponudu
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M13 5l7 7-7 7" />
            </svg>
        </a>
    </div>

    <button class="asg-nav-hamburger @(_menuOpen ? "open" : "")" @onclick="ToggleMenu" aria-label="Meni">
        <span></span>
        <span></span>
        <span></span>
    </button>

    @if (_menuOpen)
    {
        <div class="asg-nav-mobile">
            <a href="/" @onclick="CloseMenu">Početna</a>
            <a href="/about" @onclick="CloseMenu">O Nama</a>
            <a href="/services" @onclick="CloseMenu">Usluge</a>
            <a href="/projects" @onclick="CloseMenu">Projekti</a>
            <a href="/brands" @onclick="CloseMenu">Brendovi</a>
            <a href="/shop" @onclick="CloseMenu">Web Shop</a>
            <a href="/cart" @onclick="CloseMenu">Korpa</a>
            <a href="/contact" @onclick="CloseMenu">Kontakt</a>
            <a href="/contact" class="asg-btn asg-btn-pri" @onclick="CloseMenu">Zatraži ponudu</a>
        </div>
    }
</nav>

@code {
    private bool _menuOpen = false;

    private string IsActive(string path)
    {
        var current = "/" + Nav.ToBaseRelativePath(Nav.Uri);
        return current == path ? "active" : "";
    }

    private void ToggleMenu() => _menuOpen = !_menuOpen;
    private void CloseMenu() => _menuOpen = false;
}
