@inject NavigationManager Nav
@inject CurrentUser CurrentUser
@inject IMediator Mediator
@using dWebShop.Application.Features.ShoppingCart.Queries
@using dWebShop.Web.Services
@using MediatR

<nav class="asg-nav">
	<a href="/" class="asg-brand">
		<img class="asg-brand-mark"
			 src="/images/logo.svg"
			 alt="A&S Gifiks" />
		<span class="asg-brand-words">
			<span class="light">A&amp;S</span>
			<span class="bold">GIFIKS</span>
		</span>
        <small>BiH</small>
    </a>

    <ul>
        <li><a href="/" class="@IsActive("/")">Početna</a></li>
        <li><a href="/about" class="@IsActive("/about")">O Nama</a></li>
        <li><a href="/services" class="@IsActive("/services")">Usluge</a></li>
        <li><a href="/projects" class="@IsActive("/projects")">Projekti</a></li>
        <li><a href="/brands" class="@IsActive("/brands")">Brendovi</a></li>
        <li><a href="/shop" class="@IsActive("/shop")">Web Shop</a></li>
        <li><a href="/contact" class="@IsActive("/contact")">Kontakt</a></li>
    </ul>

    <div class="asg-nav-utils">
        <a href="/cart" class="asg-cart-btn" title="Korpa">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" style="width:14px;height:14px">
                <path d="M3 4 H6 L8 17 H20 L22 7 H7"/><circle cx="9" cy="21" r="1.3"/><circle cx="18" cy="21" r="1.3"/>
            </svg>
            @if (_cartCount > 0)
            {
                <span class="asg-cart-badge">@_cartCount</span>
            }
        </a>
        @if (_isAuthenticated)
        {
            <a href="/account" class="asg-login-chip is-in" title="Moj nalog">
                <span class="dot"></span>
                <span>@_chipLabel</span>
            </a>
        }
        else
        {
            <a href="/login" class="asg-login-chip" title="Prijava">
                <span class="dot"></span>
                <span>Prijava</span>
            </a>
        }
    </div>

    <button class="asg-nav-hamburger @(_menuOpen ? "open" : "")" @onclick="ToggleMenu" aria-label="Meni">
        <span></span>
        <span></span>
        <span></span>
    </button>

    @if (_menuOpen)
    {
        <div class="asg-nav-mobile">
            <a href="/" @onclick="CloseMenu">Početna</a>
            <a href="/about" @onclick="CloseMenu">O Nama</a>
            <a href="/services" @onclick="CloseMenu">Usluge</a>
            <a href="/projects" @onclick="CloseMenu">Projekti</a>
            <a href="/brands" @onclick="CloseMenu">Brendovi</a>
            <a href="/shop" @onclick="CloseMenu">Web Shop</a>
            <a href="/cart" @onclick="CloseMenu">Korpa</a>
            <a href="/contact" @onclick="CloseMenu">Kontakt</a>
        </div>
    }
</nav>

@code {
    private bool _menuOpen = false;
    private bool _isAuthenticated;
    private string _chipLabel = "Prijava";
    private int _cartCount;

    protected override async Task OnInitializedAsync()
    {
        // Static SSR navbar: state below is computed once per request render.
        // For anonymous visitors we skip the cart query entirely so marketing
        // pages don't take a DB hit they don't need.
        _isAuthenticated = await CurrentUser.IsAuthenticatedAsync();
        if (!_isAuthenticated) return;

        var name = await CurrentUser.GetDisplayNameAsync();
        if (!string.IsNullOrWhiteSpace(name))
        {
            // Strip email-style names (foo@bar.com → foo) and take the first
            // word so the chip stays compact.
            var firstToken = name.Split('@', ' ').FirstOrDefault(t => !string.IsNullOrWhiteSpace(t));
            _chipLabel = string.IsNullOrWhiteSpace(firstToken) ? "Račun" : firstToken!;
        }
        else
        {
            _chipLabel = "Račun";
        }

        var userId = await CurrentUser.GetUserIdAsync();
        if (userId is not null)
        {
            var cart = await Mediator.Send(new GetCartQuery(userId.Value));
            // Cart quantities are decimal in the schema but always whole units
            // for this catalogue — round so the badge shows a clean integer.
            _cartCount = (int)Math.Round(cart.Sum(c => c.Quantity));
        }
    }

    private string IsActive(string path)
    {
        var current = "/" + Nav.ToBaseRelativePath(Nav.Uri);
        return current == path ? "active" : "";
    }

    private void ToggleMenu() => _menuOpen = !_menuOpen;
    private void CloseMenu() => _menuOpen = false;
}
