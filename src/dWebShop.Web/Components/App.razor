    <HeadOutlet />
    <script>
        // Disable browser scroll restoration as early as possible (before any layout/paint).
        if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
    </script>
</head>

<body>
    <Routes />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script>
        window.scrollToTop = function() { window.scrollTo({ top: 0, behavior: "instant" }); };

        // Scroll to top on navigation and reload. We cover three navigation paths:
        //  1. Initial page load / F5  — direct scrollTo (browser restoration already disabled in <head>).
        //  2. Enhanced SSR navigation — fires `enhancedload`.
        //  3. InteractiveServer / NavigationManager — calls history.pushState (monkey-patched).
        // popstate (back/forward) intentionally not handled here; with manual restoration the page
        // simply starts at top, which the user explicitly wants.
        (function() {
            function toTop() { window.scrollTo({ top: 0, behavior: 'instant' }); }
            toTop();
            window.addEventListener('load', toTop);

            document.addEventListener('enhancedload', toTop);

            var origPush = history.pushState;
            history.pushState = function() {
                var ret = origPush.apply(this, arguments);
                toTop();
                return ret;
            };

            window.addEventListener('popstate', toTop);
        })();

        // Scroll-triggered animations for .animate-on-scroll elements
        (function() {
            function initScrollAnimations() {
                var elements = document.querySelectorAll('.animate-on-scroll');
                if (!elements.length) return;
                if (!('IntersectionObserver' in window)) {
                    elements.forEach(function(el) { el.classList.add('animated'); });
                    return;
                }
                var observer = new IntersectionObserver(function(entries) {
                    entries.forEach(function(entry) {
                        if (entry.isIntersecting) {
                            entry.target.classList.add('animated');
                            observer.unobserve(entry.target);
                        }
                    });
                }, { threshold: 0.1 });
                elements.forEach(function(el) { observer.observe(el); });
            }
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', initScrollAnimations);
            } else {
                initScrollAnimations();
            }
            // Re-run after Blazor enhanced navigation
            document.addEventListener('enhancedload', initScrollAnimations);
        })();
    </script>
</body>

</html>

