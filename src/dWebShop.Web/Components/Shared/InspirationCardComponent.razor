@* Reusable card for InspirationHub and InspirationDetail (related) *@

<a href="/brands/@BrandSlug/inspiracija/@Item.Slug" class="asg-insp-card asg-insp-card--@Size">
    <div class="asg-insp-card-img">
        <div class="asg-insp-img-ph">[ @Item.HeroLabel ]</div>
        <span class="asg-insp-card-type">@InspirationData.Types[Item.Type].Label</span>
    </div>
    <div class="asg-insp-card-body">
        <div class="asg-insp-card-meta">
            <span>@Item.PublishedAt</span>
            <span>&middot;</span>
            <span>@Item.ReadMin min čitanja</span>
        </div>
        <h3>@Item.Title</h3>
        <p>@Item.Lede</p>
        <div class="asg-insp-card-foot">
            <span class="asg-insp-card-tags">
                @foreach (var tag in Item.Tags.Take(2))
                {
                    <em>@tag</em>
                }
            </span>
            <span class="asg-insp-card-arrow">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14M13 5l7 7-7 7"/>
                </svg>
            </span>
        </div>
    </div>
</a>

<style>
    .asg-insp-img-ph {
        position: absolute;
        inset: 0;
        background: repeating-linear-gradient(135deg, #16161a 0 14px, rgba(255,255,255,.04) 14px 28px);
        color: rgba(255,255,255,.45);
        font-family: var(--asg-mono);
        font-size: 11px;
        letter-spacing: .06em;
        text-transform: lowercase;
        display: flex;
        align-items: flex-end;
        padding: 14px;
    }
</style>

@code {
    [Parameter, EditorRequired] public string BrandSlug { get; set; } = "";
    [Parameter, EditorRequired] public InspirationData.InspirationItem Item { get; set; } = default!;
    [Parameter] public string Size { get; set; } = "std";
}
