@using dWebShop.Domain.Entities.Users
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider

@if (_initialized)
{
    @if (!_isAuthenticated)
    {
        <MudText Typo="Typo.caption" Class="mud-text-secondary">
            <MudLink Href="/login">Login to see pricing</MudLink>
        </MudText>
    }
    else if (!_isApproved)
    {
        <MudText Typo="Typo.caption" Color="Color.Warning">Pending approval</MudText>
    }
    else if (Price.HasValue)
    {
        <MudText Typo="@PriceTypo" Style="font-weight:600;" Color="Color.Primary">
            @(Prefix)@Price.Value.ToString("N2") KM
        </MudText>
    }
    else
    {
        <MudText Typo="Typo.caption" Class="mud-text-secondary">Price on request</MudText>
    }
}

@code {
    [Parameter] public decimal? Price { get; set; }
    [Parameter] public string Prefix { get; set; } = string.Empty;
    [Parameter] public Typo PriceTypo { get; set; } = Typo.body1;

    private bool _initialized;
    private bool _isAuthenticated;
    private bool _isApproved;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _isAuthenticated = authState.User.Identity?.IsAuthenticated ?? false;

        if (_isAuthenticated)
        {
            if (authState.User.IsInRole("Admin"))
            {
                _isApproved = true;
            }
            else
            {
                var user = await UserManager.GetUserAsync(authState.User);
                _isApproved = user?.IsApproved ?? false;
            }
        }

        _initialized = true;
    }
}
