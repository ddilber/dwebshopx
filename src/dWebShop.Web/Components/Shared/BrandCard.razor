@using dWebShop.Application.Features.Brands.Queries

<MudCard Outlined="true" Class="@($"brand-card {Class}")" Style="cursor:pointer"
         @onclick="Navigate">
    @if (!string.IsNullOrWhiteSpace(Brand.LogoImage))
    {
        <div class="d-flex justify-center align-center pa-4" style="height:120px; background: var(--mud-palette-surface);">
            <img src="/product_images/brands/@Brand.LogoImage"
                 alt="@Brand.Name logo"
                 style="max-height:80px; max-width:100%; object-fit:contain;" />
        </div>
    }
    else
    {
        <div class="d-flex justify-center align-center pa-4" style="height:120px; background: var(--mud-palette-surface);">
            <MudIcon Icon="@Icons.Material.Filled.Store" Size="Size.Large" Color="Color.Primary" />
        </div>
    }
    <MudCardContent>
        <MudText Typo="Typo.h6">@Brand.Name</MudText>
        @if (!string.IsNullOrWhiteSpace(Brand.Description))
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary mt-1">
                @(Brand.Description.Length > 100 ? Brand.Description[..100] + "…" : Brand.Description)
            </MudText>
        }
    </MudCardContent>
    <MudCardActions>
        <MudButton Variant="Variant.Text" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowForward"
                   Href="@($"/brands/{Brand.Slug}")">
            View Products
        </MudButton>
    </MudCardActions>
</MudCard>

@inject NavigationManager Nav

@code {
    [Parameter, EditorRequired] public BrandDto Brand { get; set; } = default!;
    [Parameter] public string Class { get; set; } = string.Empty;

    private void Navigate() => Nav.NavigateTo($"/brands/{Brand.Slug}");
}
