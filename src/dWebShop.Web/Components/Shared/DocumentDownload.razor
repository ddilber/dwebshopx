@using dWebShop.Application.Features.Products.Queries

@if (Documents.Any())
{
    <MudText Typo="Typo.subtitle1" Class="mb-2" Style="font-weight:600;">
        <MudIcon Icon="@Icons.Material.Filled.AttachFile" Class="mr-1" />
        Documents
    </MudText>
    <MudList T="ProductDocumentDto" Dense="true">
        @foreach (var doc in Documents)
        {
            <MudListItem T="ProductDocumentDto" Value="doc"
                         Icon="@Icons.Material.Filled.PictureAsPdf">
                <MudLink Href="@($"/product_docs/{doc.Path}")" Target="_blank" Underline="Underline.Hover">
                    @(!string.IsNullOrWhiteSpace(doc.Name) ? doc.Name : doc.Path)
                </MudLink>
                @if (!string.IsNullOrWhiteSpace(doc.Description))
                {
                    <MudText Typo="Typo.caption" Class="mud-text-secondary ml-2">— @doc.Description</MudText>
                }
            </MudListItem>
        }
    </MudList>
}

@code {
    [Parameter, EditorRequired] public List<ProductDocumentDto> Documents { get; set; } = [];
}
