@using dWebShop.Application.Features.Products.Queries

<MudCard Outlined="true" Class="@($"product-card {Class}")" Style="cursor:pointer"
         @onclick="Navigate">
    @if (!string.IsNullOrWhiteSpace(Product.PrimaryImage))
    {
        <div style="height:180px; overflow:hidden; background:#f5f5f5; display:flex; align-items:center; justify-content:center;">
            <img src="/product_images/@Product.PrimaryImage"
                 alt="@Product.Name"
                 style="max-height:180px; max-width:100%; object-fit:contain;" />
        </div>
    }
    else
    {
        <div class="d-flex justify-center align-center" style="height:180px; background: var(--mud-palette-surface);">
            <MudIcon Icon="@Icons.Material.Filled.Inventory2" Size="Size.Large" Color="Color.Secondary" />
        </div>
    }
    <MudCardContent Class="pb-0">
        <MudText Typo="Typo.subtitle1" Style="font-weight:600;">@Product.Name</MudText>
        @if (!string.IsNullOrWhiteSpace(Product.SKU))
        {
            <MudText Typo="Typo.caption" Class="mud-text-secondary">SKU: @Product.SKU</MudText>
        }
        @if (!string.IsNullOrWhiteSpace(Product.BrandName))
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined" Class="mt-1">@Product.BrandName</MudChip>
        }
    </MudCardContent>
    <MudCardActions>
        <MudButton Variant="Variant.Text" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowForward"
                   Href="@($"/products/{Product.Slug}")">
            Details
        </MudButton>
    </MudCardActions>
</MudCard>

@inject NavigationManager Nav

@code {
    [Parameter, EditorRequired] public ProductListItemDto Product { get; set; } = default!;
    [Parameter] public string Class { get; set; } = string.Empty;

    private void Navigate() => Nav.NavigateTo($"/products/{Product.Slug}");
}
