@using dWebShop.Web.Services

<a href="/shop/p/@Product.Slug" class="asg-pcard">
    <div class="asg-pcard-img">
        <span class="asg-pcard-brand">@(Product.BrandSlug?.ToUpperInvariant() ?? Product.BrandName?.ToUpperInvariant() ?? "")</span>
        @{
            var (stockLabel, stockColor) = ShopFormatting.StockLabel(Product.StockBucket);
        }
        <span class="asg-pcard-stock">
            <span class="dot" style="background:@stockColor"></span>
            @stockLabel
        </span>
        @if (!string.IsNullOrEmpty(Product.PrimaryImagePath))
        {
            <img src="@Product.PrimaryImagePath" alt="@Product.Name" loading="lazy" />
        }
        else
        {
            <span class="ph">Slika proizvoda</span>
        }
    </div>
    <div class="asg-pcard-body">
        <div class="asg-pcard-cat">@(Product.CategoryName ?? "")</div>
        <h4>@Product.Name</h4>
        <p>@Product.Short</p>
        <div class="asg-pcard-foot">
            <div class="asg-pcard-price">
                <span class="from">Cijena od</span>
                @if (IsLoggedIn && Product.MinPrice.HasValue)
                {
                    <span class="val">@ShopFormatting.FmtPrice(Product.MinPrice.Value)</span>
                }
                else
                {
                    <span class="login">Prijava za cijenu</span>
                }
            </div>
            <div class="asg-pcard-arrow">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" style="width:14px;height:14px">
                    <path d="M5 12 H19 M13 6 L19 12 L13 18"/>
                </svg>
            </div>
        </div>
    </div>
</a>

@code {
    [Parameter] public ShopProductCardVm Product { get; set; } = default!;
    [Parameter] public bool IsLoggedIn { get; set; }
}
